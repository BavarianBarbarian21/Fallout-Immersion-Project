  </BiomeDef>

  <BiomeDef ParentName="Repconn_Nature">
    <defName>Repconn_Divide</defName>
    <label>divide</label>
    <description>Low to medium elevation hot-country biome.</description>
    <workerClass>FIP.Repconn.BiomeWorker_Divide</workerClass>
    <texture>World/Biomes/Desert</texture>
  </BiomeDef>

  <BiomeDef ParentName="Repconn_Nature">
    <defName>Repconn_Mesa</defName>
    <label>mesa</label>
    <description>High-elevation hot-country biome.</description>
    <workerClass>FIP.Repconn.BiomeWorker_Mesa</workerClass>
    <texture>World/Biomes/Desert</texture>
  </BiomeDef>

  <BiomeDef ParentName="Repconn_Urban">
    <defName>Repconn_Crater</defName>
    <label>crater</label>
    <description>Central seed biome for the crater, ruin, and wasteland ring structure.</description>
    <texture>World/Biomes/Scarlands</texture>
    <pollutionOffset>0.04</pollutionOffset>
  </BiomeDef>

  <BiomeDef ParentName="Repconn_Urban">
    <defName>Repconn_Ruin</defName>
    <label>ruin</label>
    <description>Guaranteed first ring surrounding craters, with a small chance to expand outward.</description>
    <texture>World/Biomes/Desert</texture>
    <pollutionOffset>0.02</pollutionOffset>
  </BiomeDef>

  <BiomeDef ParentName="Repconn_Urban">
    <defName>Repconn_Wasteland</defName>
    <label>wasteland</label>
    <description>Guaranteed outer ring surrounding ruins, with a moderate chance to expand outward.</description>
    <texture>World/Biomes/Scarlands</texture>
    <pollutionOffset>0.01</pollutionOffset>
  </BiomeDef>

  <BiomeDef ParentName="Repconn_Nature">
    <defName>Repconn_Malpais</defName>
    <label>malpais</label>
    <description>Repconn 3 malpais using the vanilla lava field worker.</description>
    <workerClass>BiomeWorker_LavaField</workerClass>
    <texture>World/Biomes/LavaFields</texture>
  </BiomeDef>

  <BiomeDef ParentName="Repconn_Nature">
    <defName>Repconn_CranberryBog</defName>
    <label>cranberry bog</label>
    <description>Repconn 3 cranberry bog using the vanilla glowforest worker.</description>
    <workerClass>BiomeWorker_Glowforest</workerClass>
    <texture>World/Biomes/Glowforest</texture>
    <lakeBeachTerrain>Marsh</lakeBeachTerrain>
    <mudTerrain>Marsh</mudTerrain>
  </BiomeDef>
</Defs>