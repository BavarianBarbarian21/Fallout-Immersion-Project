<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <BiomeDef Name="Repconn_Nature" Abstract="True">
    <animalDensity>0</animalDensity>
    <plantDensity>0</plantDensity>
    <settlementSelectionWeight>0.5</settlementSelectionWeight>
    <campSelectionWeight>0.1</campSelectionWeight>
    <movementDifficulty>1</movementDifficulty>
    <lakeBeachTerrain>Sand</lakeBeachTerrain>
    <riverbankTerrain>Riverbank</riverbankTerrain>
    <riverbankSizeRange>6~8</riverbankSizeRange>
    <forageability>0</forageability>
    <wildPlantRegrowDays>60</wildPlantRegrowDays>
    <maxFishPopulation>0</maxFishPopulation>
    <baseWeatherCommonalities>
      <Clear>12</Clear>
      <Fog>1</Fog>
      <Rain>1</Rain>
      <SnowGentle>1</SnowGentle>
    </baseWeatherCommonalities>
    <terrainsByFertility>
      <li>
        <terrain>Soil</terrain>
        <min>-999</min>
        <max>0.87</max>
      </li>
      <li>
        <terrain>SoilRich</terrain>
        <min>0.87</min>
        <max>999</max>
      </li>
    </terrainsByFertility>
  </BiomeDef>

  <BiomeDef Name="Repconn_Urban" ParentName="Repconn_Nature" Abstract="True">
    <canAutoChoose>false</canAutoChoose>
    <generatesNaturally>false</generatesNaturally>
  </BiomeDef>

  <BiomeDef ParentName="Repconn_Nature">
    <defName>Repconn_SeaIce</defName>
    <label>sea ice</label>
    <description>Repconn 3 arctic sea ice using the vanilla sea ice worker.</description>
    <workerClass>BiomeWorker_SeaIce</workerClass>
    <isWaterBiome>true</isWaterBiome>
    <canBuildBase>false</canBuildBase>
    <allowRoads>false</allowRoads>
    <allowRivers>false</allowRivers>
    <hasVirtualPlants>false</hasVirtualPlants>
    <texture>World/Biomes/IceSheetOcean</texture>
    <impassable>true</impassable>
    <isBackgroundBiome>true</isBackgroundBiome>
    <lakeBeachTerrain>Ice</lakeBeachTerrain>
    <mudTerrain>Ice</mudTerrain>
    <coastalBeachTerrain>Ice</coastalBeachTerrain>
    <terrainPatchMakers>
      <li>
        <perlinFrequency>0.015</perlinFrequency>
        <isPond>true</isPond>
        <thresholds>
          <li>
            <terrain>WaterShallow</terrain>
            <min>0.76</min>
            <max>999</max>
          </li>
        </thresholds>
      </li>
    </terrainPatchMakers>
  </BiomeDef>

  <BiomeDef ParentName="Repconn_Nature">
    <defName>Repconn_IceSheet</defName>
    <label>ice sheet</label>
    <description>Repconn 3 ice sheet using the vanilla ice sheet worker.</description>
    <workerClass>BiomeWorker_IceSheet</workerClass>
    <texture>World/Biomes/IceSheet</texture>
    <lakeBeachTerrain>Ice</lakeBeachTerrain>
    <mudTerrain>Ice</mudTerrain>
    <terrainsByFertility>
      <li>
        <terrain>Ice</terrain>
        <min>-999</min>
        <max>999</max>
      </li>
    </terrainsByFertility>
  </BiomeDef>

  <BiomeDef ParentName="Repconn_Nature">
    <defName>Repconn_GlacialPlain</defName>
    <label>glacial plain</label>
    <description>Repconn 3 glacial plain using the vanilla glacial plain worker.</description>
    <workerClass>BiomeWorker_GlacialPlain</workerClass>
    <texture>World/Biomes/GlacialPlains</texture>
    <lakeBeachTerrain>Ice</lakeBeachTerrain>
    <mudTerrain>Ice</mudTerrain>
    <coastalBeachTerrain>Ice</coastalBeachTerrain>
    <terrainsByFertility>
      <li>
        <terrain>Ice</terrain>
        <min>-999</min>
        <max>999</max>
      </li>
    </terrainsByFertility>
  </BiomeDef>

  <BiomeDef ParentName="Repconn_Nature">
    <defName>Repconn_Tundra</defName>
    <label>tundra</label>
    <description>Repconn 3 tundra using the vanilla tundra worker.</description>
    <workerClass>BiomeWorker_Tundra</workerClass>
    <texture>World/Biomes/Tundra</texture>
    <lakeBeachTerrain>Gravel</lakeBeachTerrain>
    <mudTerrain>Gravel</mudTerrain>
    <riverbankTerrain>Gravel</riverbankTerrain>
  </BiomeDef>

  <BiomeDef ParentName="Repconn_Nature">
    <defName>Repconn_Preserve</defName>
    <label>preserve</label>
    <description>Boreal lowland and upland preserve.</description>
    <workerClass>FIP.Repconn.BiomeWorker_Preserve</workerClass>
    <texture>World/Biomes/BorealForest</texture>
  </BiomeDef>

  <BiomeDef ParentName="Repconn_Nature">
    <defName>Repconn_Ceek</defName>
    <label>ceek</label>
    <description>River-fed boreal ceekland that replaces about half of eligible preserve river tiles.</description>
    <workerClass>FIP.Repconn.BiomeWorker_Ceek</workerClass>
    <texture>World/Biomes/BorealForest</texture>
  </BiomeDef>

  <BiomeDef ParentName="Repconn_Nature">
    <defName>Repconn_CentralValley</defName>
    <label>central valley</label>
    <description>Temperate low-elevation central valley terrain.</description>
    <workerClass>FIP.Repconn.BiomeWorker_CentralValley</workerClass>
    <texture>World/Biomes/Grasslands</texture>
  </BiomeDef>

  <BiomeDef ParentName="Repconn_Nature">
    <defName>Repconn_BrahminWoods</defName>
    <label>brahmin woods</label>
    <description>Temperate medium-elevation woodland.</description>
    <workerClass>FIP.Repconn.BiomeWorker_BrahminWoods</workerClass>
    <texture>World/Biomes/TemperateForest</texture>
  </BiomeDef>

  <BiomeDef ParentName="Repconn_Nature">
    <defName>Repconn_Aqueduct</defName>
    <label>aqueduct</label>
    <description>Temperate river-bearing central valley and brahmin woods tiles increasingly become aqueducts as river size grows, unless floodplains overrides them.</description>
    <workerClass>FIP.Repconn.BiomeWorker_Aqueduct</workerClass>
    <texture>World/Biomes/Grasslands</texture>
  </BiomeDef>

  <BiomeDef ParentName="Repconn_Nature">
    <defName>Repconn_Floodplains</defName>
    <label>floodplains</label>
    <description>Large-river floodplain variant layered on top of aqueduct terrain.</description>
    <workerClass>FIP.Repconn.BiomeWorker_Floodplains</workerClass>
    <texture>World/Biomes/Grasslands</texture>
  </BiomeDef>

  <BiomeDef ParentName="Repconn_Nature">
    <defName>Repconn_Mojave</defName>
    <label>mojave</label>
    <description>Arid low to medium elevation mojave terrain.</description>
    <workerClass>FIP.Repconn.BiomeWorker_Mojave</workerClass>
    <texture>World/Biomes/AridShrubland</texture>
  </BiomeDef>

  <BiomeDef ParentName="Repconn_Nature">
    <defName>Repconn_Canyon</defName>
    <label>canyon</label>
    <description>River-bearing mojave terrain, replacing about half of eligible mojave river tiles.</description>
    <workerClass>FIP.Repconn.BiomeWorker_Canyon</workerClass>
    <texture>World/Biomes/Scarlands</texture>
  </BiomeDef>

  <BiomeDef ParentName="Repconn_Nature">
    <defName>Repconn_Marina</defName>
    <label>marina</label>
    <description>Coastal low-elevation tiles from boreal through arid, appearing at about half of eligible coastal tiles.</description>
    <workerClass>FIP.Repconn.BiomeWorker_Marina</workerClass>
    <texture>World/Biomes/TemperateForest</texture>
  </BiomeDef>

  <BiomeDef ParentName="Repconn_Nature">
    <defName>Repconn_Redwood</defName>
    <label>redwood</label>
    <description>High-elevation cool mountain forest from boreal through the lower half of temperate climates.</description>
    <workerClass>FIP.Repconn.BiomeWorker_Redwood</workerClass>
    <texture>World/Biomes/TemperateForest</texture>
  </BiomeDef>

  <BiomeDef ParentName="Repconn_Nature">
