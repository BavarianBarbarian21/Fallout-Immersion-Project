<?xml version="1.0" encoding="utf-8" ?>
<Patch>
  <Operation Class="PatchOperationSequence" MayRequire="VanillaExpanded.Ideo.Dryads">
    <operations>
      <li Class="PatchOperationReplace">
        <xpath>/Defs/GauranlenTreeModeDef[defName="VDE_Stonedigger"]/description</xpath>
        <value>
          <description>An extremely easy-going treeminder caste that specializes in dragging up stone chunks. It absorbs minerals from the ground to harden its hide while leaving the oversized pieces aside.</description>
        </value>
        <success>Always</success>
      </li>
      <li Class="PatchOperationReplace">
        <xpath>/Defs/GauranlenTreeModeDef[defName="VDE_Spitter"]/description</xpath>
        <value>
          <description>A treeminder caste specialized in territorial defense that can launch corrosive projectiles. Though it can dish out tremendous damage, it remains vulnerable in melee due to its oversized maw.</description>
        </value>
        <success>Always</success>
      </li>
      <li Class="PatchOperationReplace">
        <xpath>/Defs/GauranlenTreeModeDef[defName="VDE_Gaubricmaker"]/description</xpath>
        <value>
          <description>A treeminder caste specialized in producing a shaggy, leather-like hide. Together with its Treefather, it can be sheared for a soft, insulative material on an ongoing basis, though it is slow and ineffective at work or combat.</description>
        </value>
        <success>Always</success>
      </li>
      <li Class="PatchOperationReplace">
        <xpath>/Defs/GauranlenTreeModeDef[defName="VDE_Nectarmaker"]/description</xpath>
        <value>
          <description>A curious treeminder caste specialized in producing invigorating sap-fruit. Together with its Treefather, it can generate this stimulant crop on an ongoing basis, but it is completely defenseless and requires careful protection.</description>
        </value>
        <success>Always</success>
      </li>
