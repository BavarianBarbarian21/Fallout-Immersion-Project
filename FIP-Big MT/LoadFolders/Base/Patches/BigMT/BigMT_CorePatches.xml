<?xml version="1.0" encoding="utf-8"?>
<!--
  FIP - Big MT: Core Patches
  Rethemes the central Anomaly structures and resources.

  VoidMonolith          → Big MT antenna
  Plant_TreeHarbinger   → spore plant (and stumps/seeds)
  Bioferrite            → Saturnite alloy
  GoldenCube            → toaster
  DeathPall             → FEV aerosol cloud
  Obelisks (3 types)    → Big MT experiment emitters
  PitGate               → service tunnel
  VoidStructure/Node    → Think Tank installation / broadcast node
-->
<Patch>

  <!-- ==================== VOID MONOLITH → BIG MT ANTENNA ==================== -->

  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/ThingDef[defName="VoidMonolith"]/label</xpath>
    <value><label>Big MT antenna</label></value>
  </Operation>

  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/ThingDef[defName="VoidMonolith"]/description</xpath>
    <value><description>A pre-war broadcast antenna of Big MT construction. Its control panel bears the stylized atom logo and dense scientific notation of the Big MT Research and Development corporation. The antenna hums with low-frequency static, and the signal it's broadcasting has started drawing in something from the region.\n\nThe longer it broadcasts, the stronger the signal grows — and the worse whatever's listening gets.</description></value>
  </Operation>

  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/EntityCodexEntryDef[defName="VoidMonolith"]/label</xpath>
    <value><label>Big MT antenna</label></value>
  </Operation>

  <!-- ==================== HARBINGER TREE → SPORE PLANT ==================== -->

  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/ThingDef[defName="Plant_TreeHarbinger"]/label</xpath>
    <value><label>spore plant</label></value>
  </Operation>

  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/ThingDef[defName="ChoppedStump_Harbinger"]/label</xpath>
    <value><label>chopped spore plant stump</label></value>
  </Operation>

  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/ThingDef[defName="SmashedStump_Harbinger"]/label</xpath>
    <value><label>smashed spore plant stump</label></value>
  </Operation>

  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/ThingDef[defName="HarbingerSeed"]/label</xpath>
    <value><label>spore plant seed</label></value>
  </Operation>

  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/EntityCodexEntryDef[defName="HarbingerTree"]/label</xpath>
    <value><label>spore plant</label></value>
  </Operation>

  <!-- ==================== BIOFERRITE → SATURNITE ALLOY ==================== -->

  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/ThingDef[defName="Bioferrite"]/label</xpath>
    <value><label>Saturnite alloy</label></value>
  </Operation>

  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/ThingDef[defName="Bioferrite"]/description</xpath>
    <value><description>A heat-resistant metallic compound developed by Big MT's materials division. Saturnite alloy is extracted from Big MT experiment subjects and byproducts. It has exceptional thermal and structural properties, and can be shaped into a range of weapons and tools under high heat.</description></value>
  </Operation>

  <!-- ==================== GOLDEN CUBE → TOASTER ==================== -->

  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/ThingDef[defName="GoldenCube"]/label</xpath>
    <value><label>toaster</label></value>
  </Operation>

  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/ThingDef[defName="GoldenCube"]/description</xpath>
    <value><description>A pre-war smart appliance from Big MT — specifically, the Toaster. Its chassis has been heavily modified at some point in the past, and it now hosts a rudimentary AI personality that considers itself imprisoned. It broadcasts low-level psychic suggestions on a subliminal frequency to anyone nearby, instilling a vague but persistent sense that it would really like to be freed.\n\nIt cannot be freed. It is a toaster.\n\nLong-term exposure leads to obsessive fixation on the object. Colonists who spend too long near it begin spending their free time staring at it, talking to it, and eventually refusing to let others near it.</description></value>
  </Operation>

  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/EntityCodexEntryDef[defName="GoldenCube"]/label</xpath>
    <value><label>toaster</label></value>
  </Operation>

  <!-- ==================== DEATHPALL → FEV AEROSOL CLOUD ==================== -->

  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/GameConditionDef[defName="DeathPall"]/label</xpath>
    <value><label>FEV aerosol cloud</label></value>
  </Operation>

  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/EntityCodexEntryDef[defName="Deathpall"]/label</xpath>
    <value><label>FEV aerosol cloud</label></value>
  </Operation>

  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/EntityCodexEntryDef[defName="Deathpall"]/description</xpath>
    <value><description>An airborne release of aerosolized FEV — Forced Evolutionary Virus — from a ruptured Big MT containment breach. The nanoscale viral particles settle into dead tissue and begin forced reanimation, creating lobotomites from any available corpses. Wearing sealed respirators provides some protection.</description></value>
  </Operation>

  <!-- ==================== OBELISKS → BIG MT EXPERIMENT EMITTERS ==================== -->

  <!-- Twisted Obelisk → West Tek Mutagenic Emitter (mutates nearby creatures/pawns) -->
  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/EntityCodexEntryDef[defName="TwistedObelisk"]/label</xpath>
    <value><label>West Tek mutagenic emitter</label></value>
  </Operation>

  <!-- Corrupted Obelisk → Malfunctioning ZAX Node (corrupts research progress, spawns hostiles) -->
  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/EntityCodexEntryDef[defName="CorruptedObelisk"]/label</xpath>
    <value><label>malfunctioning ZAX node</label></value>
  </Operation>

  <!-- Warped Obelisk → Big MT Field Projector (dimensional/spatial experiment emitter) -->
  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/EntityCodexEntryDef[defName="WarpedObelisk"]/label</xpath>
    <value><label>Big MT field projector</label></value>
  </Operation>

  <!-- ThingDef building labels for the concrete obelisk variant -->
  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/ThingDef[defName="WarpedObelisk_Mutator"]/label</xpath>
    <value><label>West Tek mutagenic emitter</label></value>
  </Operation>

  <!-- ==================== PIT GATE → SERVICE TUNNEL ==================== -->

  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/ThingDef[defName="PitGate"]/label</xpath>
    <value><label>service tunnel entrance</label></value>
  </Operation>

  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/EntityCodexEntryDef[defName="PitGate"]/label</xpath>
    <value><label>service tunnel</label></value>
  </Operation>

  <!-- ==================== VOID STRUCTURE / NODE → THINK TANK INSTALLATION ==================== -->

  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/EntityCodexEntryDef[defName="VoidStructure"]/label</xpath>
    <value><label>Think Tank installation</label></value>
  </Operation>

  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/EntityCodexEntryDef[defName="VoidNode"]/label</xpath>
    <value><label>broadcast node</label></value>
  </Operation>

  <!-- ==================== UNNATURAL CORPSE → TEST SUBJECT REMAINS ==================== -->

  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/EntityCodexEntryDef[defName="UnnaturalCorpse"]/label</xpath>
    <value><label>test subject remains</label></value>
  </Operation>

  <!-- ==================== FLESHMASS HEART → FEV REACTOR ==================== -->

  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/ThingDef[defName="FleshmassHeart"]/label</xpath>
    <value><label>FEV reactor</label></value>
  </Operation>

  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/EntityCodexEntryDef[defName="FleshmassHeart"]/label</xpath>
    <value><label>FEV reactor</label></value>
  </Operation>

  <!-- ==================== NOCTOLITH → FEV CONTAINMENT POD ==================== -->

  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/ThingDef[defName="Noctolith"]/label</xpath>
    <value><label>FEV containment pod</label></value>
  </Operation>

  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/EntityCodexEntryDef[defName="Noctolith"]/label</xpath>
    <value><label>FEV containment pod</label></value>
  </Operation>

  <!-- Blood Rain → FEV Rain (rage-inducing mutagen weather event) -->
  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/EntityCodexEntryDef[defName="BloodRain"]/label</xpath>
    <value><label>FEV rain</label></value>
  </Operation>

  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/EntityCodexEntryDef[defName="BloodRain"]/description</xpath>
    <value><description>A precipitation event caused by atmospheric dispersal of diluted Forced Evolutionary Virus from a high-altitude Big MT drone. The FEV is too thin to cause full mutation but triggers extreme aggression and adrenal overdrive in anyone it contacts. Anyone exposed will enter a berserk rage.</description></value>
  </Operation>

</Patch>
