<?xml version="1.0" encoding="utf-8"?>
<Defs>
    <!-- New world religions -->
    <MemeDef Name="Greenway_Religion_NewWorldChurch_Base" ParentName="Greenway_Religion_Base"
        Abstract="true">
        <worshipRoomLabel>tempel</worshipRoomLabel>
        <groupDef>Greenway_NewWorldChurch</groupDef>
        <iconPath>FIP-Greenway/Memes/NewWorldChurch</iconPath>
        <thingStyleCategories>
            <li>
                <category>Morbid</category>
                <priority>4</priority>
            </li>
        </thingStyleCategories>
        <symbolPackOverride>true</symbolPackOverride>
        <symbolPacks>
            <li>
                <ideoName>Children</ideoName>
                <adjective>Children</adjective>
                <member>Children</member>
                <prefix>true</prefix>
            </li>
        </symbolPacks>
    </MemeDef>

    <!--Children of Atom-->
    <MemeDef ParentName="Greenway_Religion_NewWorldChurch_Base">
        <defName>Greenway_Religion_ChildrenOfAtom</defName>
        <label>Children of Atom</label>
        <description>A new cult that treats radiation and atomic remnants as sacred, with ritualised exposure and offerings.</description>
        <deityNameMakerOverride>HHTools_Greenway_Religion_NameMaker_ChildrenOfAtom</deityNameMakerOverride>
        <deityTypeMakerOverride>HHTools_Greenway_Religion_TypeMaker_ChildrenOfAtom</deityTypeMakerOverride>
    </MemeDef>

    <!--Children of the Cathedral-->
    <MemeDef ParentName="Greenway_Religion_NewWorldChurch_Base">
        <defName>Greenway_Religion_ChildrenOfTheCathedral</defName>
        <label>Children of the Cathedral</label>
        <description>A cathedral-centered faith with strong civic influence and ceremonial public worship.</description>
        <deityNameMakerOverride>HHTools_Greenway_Religion_NameMaker_ChildrenOfTheCathedral</deityNameMakerOverride>
        <deityTypeMakerOverride>HHTools_Greenway_Religion_TypeMaker_ChildrenOfTheCathedral</deityTypeMakerOverride>
        <worshipRoomLabel>cathedral</worshipRoomLabel>
    </MemeDef>

    <!--Krvibi-->
    <MemeDef ParentName="Greenway_Religion_NewWorldChurch_Base">
        <defName>Greenway_Religion_ChildrenOfKrvibi</defName>
        <label>Children of Krvibi</label>
        <description>A Lovecraftian cult venerating Ug-Qualtoth and the forerunners; rituals here are strange and alien to most.</description>
        <deityNameMakerOverride>HHTools_Greenway_Religion_NameMaker_ChildrenOfKrvibi</deityNameMakerOverride>
        <deityTypeMakerOverride>HHTools_Greenway_Religion_TypeMaker_ChildrenOfKrvibi</deityTypeMakerOverride>
    </MemeDef>

    <!--Hubology-->
    <MemeDef ParentName="Greenway_Religion_NewWorldChurch_Base">
        <defName>Greenway_Religion_Hubology</defName>
        <label>Hubology</label>
        <description>A technospiritual faith devoted to the alignment of cosmic energies and the pursuit of mental purification through the Hub.</description>
        <deityNameMakerOverride>HHTools_Greenway_Religion_NameMaker_Hubology</deityNameMakerOverride>
        <deityTypeMakerOverride>HHTools_Greenway_Religion_TypeMaker_Hubology</deityTypeMakerOverride>
        <worshipRoomLabel>sanctum</worshipRoomLabel>
    </MemeDef>

</Defs>