<?xml version="1.0" encoding="utf-8"?>

<Defs>

  <ThingDef Name="RobCo_Protectron_BaseGun" ParentName="BaseGun" Abstract="True">
    <label>protectron hand blaster</label>
    <description>A simple civilian blaster using a low-beam laser cartridge built in protectron hand.\n\nSpecially designed for RobCo protectron model and could be only mounted to its chassis.</description>
    <uiIconPath>Things/Weapons/RobCo_ProtectronLaserUI</uiIconPath>
    <tickerType>Normal</tickerType>
    <smeltable>false</smeltable>
    <techLevel>Spacer</techLevel>
    <tradeability>None</tradeability>
    <destroyOnDrop>true</destroyOnDrop>
    <relicChance>0</relicChance>
    <weaponClasses>
      <li>Ranged</li>
    </weaponClasses>
    <statBases>
      <MarketValue>500</MarketValue>
      <Mass>2</Mass>
      <AccuracyTouch>0.70</AccuracyTouch>
      <AccuracyShort>0.65</AccuracyShort>
      <AccuracyMedium>0.50</AccuracyMedium>
      <AccuracyLong>0.30</AccuracyLong>
      <RangedWeapon_Cooldown>2.0</RangedWeapon_Cooldown>
    </statBases>
    <tools>
      <li>
        <label>hand</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>8.7</power>
        <cooldownTime>2.6</cooldownTime>
      </li>
    </tools>
  </ThingDef>

  <!-- Custom colored hands for different models -->

  <ThingDef ParentName="RobCo_Protectron_BaseGun">
    <defName>RobCo_Gun_Protectron_Hand</defName>
    <graphicData>
      <texPath>Things/Weapons/RobCo_ProtectronLaser</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>0.7</drawSize>
    </graphicData>
    <weaponTags>
      <li>RobCo_Gun_Protectron_Hand</li>
    </weaponTags>
    <verbs>
      <li>
        <verbClass>Verb_Shoot</verbClass>
        <hasStandardCommand>true</hasStandardCommand>
        <defaultProjectile>RobCo_Bullet_LaserRay</defaultProjectile>
        <range>24.9</range>
        <warmupTime>0.4</warmupTime>
        <soundCast>RobCo_Shot_LaserHeavy</soundCast>
        <soundCastTail>GunTail_Medium</soundCastTail>
        <muzzleFlashScale>9</muzzleFlashScale>
      </li>
    </verbs>
  </ThingDef>

