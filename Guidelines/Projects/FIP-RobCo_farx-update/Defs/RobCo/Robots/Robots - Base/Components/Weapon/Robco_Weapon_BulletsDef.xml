<?xml version="1.0" encoding="utf-8"?>

<Defs>

  <!-- Assaultron Laser -->
  <ThingDef ParentName="BaseBullet">
    <defName>RobCo_Bullet_LaserAssaultron</defName>
    <label>RobCo Assaultron head laser</label>
    <thingClass>Projectile_HellsphereCannon</thingClass>
    <graphicData>
      <texPath>Things/Projectile/HellsphereCannon</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>MoteGlow</shaderType>
      <drawSize>(1.2, 2.4)</drawSize>
    </graphicData>
    <projectile>
      <damageDef>RobCo_LaserAssaultronDamage</damageDef>
      <speed>75</speed>
      <explosionRadius>2.9</explosionRadius>
      <screenShakeFactor>1.0</screenShakeFactor>
      <filth>Filth_BlastMark</filth>
      <filthCount>1</filthCount>
      <explosionSpawnsSingleFilth>true</explosionSpawnsSingleFilth>
    </projectile>
  </ThingDef>

  <DamageDef Name="RobCo_LaserAssaultronDamage">
    <defName>RobCo_LaserAssaultronDamage</defName>
    <label>vaporize</label>
    <workerClass>DamageWorker_Vaporize</workerClass>
    <externalViolence>true</externalViolence>
    <deathMessage>{0} has been vaporized by extreme heat.</deathMessage>
    <hediff>Burn</hediff>
    <harmAllLayersUntilOutside>true</harmAllLayersUntilOutside>
    <defaultDamage>200</defaultDamage>
    <defaultStoppingPower>1.5</defaultStoppingPower>
    <defaultArmorPenetration>1</defaultArmorPenetration>
    <buildingDamageFactorImpassable>4</buildingDamageFactorImpassable>
    <buildingDamageFactorPassable>2</buildingDamageFactorPassable>
    <plantDamageFactor>2</plantDamageFactor>
    <explosionHeatEnergyPerCell>20</explosionHeatEnergyPerCell>
    <explosionCellFleck>Fleck_Vaporize</explosionCellFleck>
    <armorCategory>Heat</armorCategory>
    <minDamageToFragment>15</minDamageToFragment>
    <makesAnimalsFlee>true</makesAnimalsFlee>
    <explosionColorCenter>(1, 1, 1)</explosionColorCenter>
    <explosionColorEdge>(0.6, 0.5, 0.4)</explosionColorEdge>
    <soundExplosion>Explosion_Vaporize</soundExplosion>
    <expolosionPropagationSpeed>0.3</expolosionPropagationSpeed>
    <hasForcefulImpact>true</hasForcefulImpact>
    <corpseDamageFactor>0.1</corpseDamageFactor>
  </DamageDef>

  <!-- Sheepsquatch Laser -->
  <ThingDef ParentName="BaseBullet">
    <defName>RobCo_Bullet_LaserSheepsquatch</defName>
    <label>RobCo Assaultron head laser</label>
    <thingClass>Projectile_HellsphereCannon</thingClass>
    <graphicData>
      <texPath>Things/Projectile/HellsphereCannon</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>MoteGlow</shaderType>
      <drawSize>(1.5, 3)</drawSize>
    </graphicData>
    <projectile>
      <damageDef>Vaporize</damageDef>
      <speed>75</speed>
      <explosionRadius>4.9</explosionRadius>
      <screenShakeFactor>1.5</screenShakeFactor>
      <filth>Filth_BlastMark</filth>
      <filthCount>1</filthCount>
      <explosionSpawnsSingleFilth>true</explosionSpawnsSingleFilth>
    </projectile>
  </ThingDef>

  <!-- Laser Ray Mote -->
  <ThingDef ParentName="MoteBase">
    <defName>RobCo_Mote_LaserRay</defName>
    <thingClass>MoteDualAttached</thingClass>
    <altitudeLayer>MoteOverhead</altitudeLayer>
    <mote>
      <fadeInTime>0.1</fadeInTime>
      <fadeOutTime>0.1</fadeOutTime>
      <solidTime>0.1</solidTime>
      <rotateTowardsTarget>True</rotateTowardsTarget>
      <scaleToConnectTargets>True</scaleToConnectTargets>
    </mote>
    <drawOffscreen>true</drawOffscreen>
    <graphicData>
      <!-- Reuse base game graphic for laser beam -->
      <texPath>Things/Mote/GraserBeam</texPath>
      <graphicClass>Graphic_MoteWithAgeSecs</graphicClass>
      <shaderType>MoteBeam</shaderType>
      <shaderParameters>
        <_ExtraTexA>/Things/Mote/BeamSecondaryNoise_A</_ExtraTexA>
        <_ExtraTexB>/Things/Mote/BeamSecondaryNoise_B</_ExtraTexB>
        <_ScrollSpeedA>0</_ScrollSpeedA>
        <_ScrollSpeedB>0</_ScrollSpeedB>
        <_Intensity>2</_Intensity>
      </shaderParameters>
      <color>(227,23,13)</color>
    </graphicData>
  </ThingDef>

  <ThingDef ParentName="BaseBullet">
    <defName>RobCo_Bullet_LaserRay</defName>
    <label>laser ray</label>
    <thingClass>Beam</thingClass>
    <graphicData>
      <texPath>Things/Projectile/Bullet_Small</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <projectile>
      <damageDef>BeamBypassShields</damageDef>
      <damageAmountBase>8</damageAmountBase>
      <beamMoteDef>RobCo_Mote_LaserRay</beamMoteDef>
      <beamStartOffset>0.5</beamStartOffset>
      <armorPenetrationBase>0.35</armorPenetrationBase>
      <stoppingPower>1</stoppingPower>
      <speed>80</speed>
    </projectile>
    <comps>
      <li Class="CompProperties_Glower">
        <glowRadius>2.4</glowRadius>
        <glowColor>(227,23,13,0)</glowColor>
      </li>
    </comps>
  </ThingDef>

  <!-- Blue Laser Ray Mote -->
  <ThingDef ParentName="MoteBase">
    <defName>RobCo_Mote_StunnerRay</defName>
    <thingClass>MoteDualAttached</thingClass>
    <altitudeLayer>MoteOverhead</altitudeLayer>
    <mote>
      <fadeInTime>0.1</fadeInTime>
      <fadeOutTime>0.1</fadeOutTime>
      <solidTime>0.1</solidTime>
      <rotateTowardsTarget>True</rotateTowardsTarget>
      <scaleToConnectTargets>True</scaleToConnectTargets>
    </mote>
    <drawOffscreen>true</drawOffscreen>
    <graphicData>
      <texPath>Things/Mote/GraserBeam</texPath>
      <graphicClass>Graphic_MoteWithAgeSecs</graphicClass>
      <shaderType>MoteBeam</shaderType>
      <shaderParameters>
        <_ExtraTexA>/Things/Mote/BeamSecondaryNoise_A</_ExtraTexA>
        <_ExtraTexB>/Things/Mote/BeamSecondaryNoise_B</_ExtraTexB>
        <_ScrollSpeedA>0</_ScrollSpeedA>
        <_ScrollSpeedB>0</_ScrollSpeedB>
        <_Intensity>2</_Intensity>
      </shaderParameters>
      <color>(11,91,229)</color>
    </graphicData>
  </ThingDef>

  <ThingDef ParentName="BaseBullet">
    <defName>RobCo_Bullet_StunnerRay</defName>
    <label>stunner ray</label>
    <thingClass>Beam</thingClass>
    <graphicData>
      <texPath>Things/Projectile/Bullet_Small</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <projectile>
      <damageDef>Stun</damageDef>
      <damageAmountBase>8</damageAmountBase>
      <beamMoteDef>RobCo_Mote_StunnerRay</beamMoteDef>
      <beamStartOffset>0.5</beamStartOffset>
      <stoppingPower>1</stoppingPower>
      <speed>80</speed>
    </projectile>
    <comps>
      <li Class="CompProperties_Glower">
        <glowRadius>2.4</glowRadius>
        <glowColor>(11,91,229,0)</glowColor>
      </li>
    </comps>
  </ThingDef>

  <!-- Plasma -->

  <ThingDef ParentName="BaseBullet">
    <defName>RobCo_Bullet_PlasmaLight</defName>
    <label>plasma</label>
    <graphicData>
      <texPath>Things/Projectile/RobCo_Plasma</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <projectile>
      <damageDef>AcidBurn</damageDef>
      <damageAmountBase>30</damageAmountBase>
      <armorPenetrationBase>0.8</armorPenetrationBase>
      <stoppingPower>1</stoppingPower>
      <shadowSize>0</shadowSize>
      <filth>Filth_SpentAcid</filth>
      <filthCount>1</filthCount>
      <speed>45</speed>
    </projectile>
    <comps>
      <li Class="CompProperties_Glower">
        <glowRadius>2.4</glowRadius>
        <glowColor>(70,255,110,0)</glowColor>
      </li>
    </comps>
  </ThingDef>

  <ThingDef ParentName="BaseBullet">
    <defName>RobCo_Bullet_5mm</defName>
    <label>5mm bullet</label>
    <graphicData>
      <texPath>Things/Projectile/Bullet_Small</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <projectile>
      <damageDef>Bullet</damageDef>
      <damageAmountBase>6</damageAmountBase>
      <speed>70</speed>
    </projectile>
  </ThingDef>

  <ThingDef ParentName="BaseBullet">
    <defName>RobCo_Bullet_20_shotgun</defName>
    <label>shotgun shell</label>
    <graphicData>
      <!-- base game based, could be changed here for balancing-->
      <texPath>Things/Projectile/Bullet_Shotgun</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <projectile>
      <damageDef>Bullet</damageDef>
      <damageAmountBase>18</damageAmountBase>
      <stoppingPower>3</stoppingPower>
      <armorPenetrationBase>0.14</armorPenetrationBase>
      <speed>55</speed>
    </projectile>
  </ThingDef>

  <ThingDef ParentName="BaseBullet">
    <!-- For sentry bot hand rocket launcher -->
    <defName>RobCo_Rocket_Light</defName>
    <label>light rocket</label>
    <graphicData>
      <texPath>Things/Projectile/RobCo_Rocket</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>TransparentPostLight</shaderType>
      <drawSize>0.7</drawSize>
    </graphicData>
    <thingClass>Projectile_Explosive</thingClass>
    <projectile>
      <damageDef>Bomb</damageDef>
      <damageAmountBase>20</damageAmountBase>
      <explosionRadius>2.3</explosionRadius>
      <speed>60</speed>
    </projectile>
  </ThingDef>

  <ThingDef ParentName="BaseBullet">
    <!-- For sentry bot ability rocket launcher -->
    <defName>RobCo_Rocket_Heavy</defName>
    <label>heavy rocket</label>
    <graphicData>
      <texPath>Things/Projectile/RobCo_Rocket</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>TransparentPostLight</shaderType>
    </graphicData>
    <thingClass>Projectile_Explosive</thingClass>
    <projectile>
      <damageDef>Bomb</damageDef>
      <!-- as mortar shell -->
      <flyOverhead>true</flyOverhead>
      <damageAmountBase>45</damageAmountBase>
      <explosionRadius>2.9</explosionRadius>
      <speed>50</speed>
    </projectile>
  </ThingDef>

  <ThingDef ParentName="BaseBullet">
    <defName>RobCo_Bomb_Mininuke</defName>
    <label>mini nuke missile</label>
    <graphicData>
      <texPath>Things/Projectile/RobCo_Mininuke</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>TransparentPostLight</shaderType>
    </graphicData>
    <!-- Based on doomsday launcher -->
    <thingClass>FIP_RobCo.Projectile_FatManPolluting</thingClass>
    <projectile>
      <damageDef>Bomb</damageDef>
      <flyOverhead>true</flyOverhead>
      <!-- Use default damage from explosion def -->
      <explosionRadius>7.8</explosionRadius>
      <speed>40</speed>
    </projectile>
  </ThingDef>

  <ThingDef ParentName="BaseBullet">
    <!-- FOR LIBERTY PRIME -->
    <defName>RobCo_Bomb_Nuke</defName>
    <label>nuke missile</label>
    <graphicData>
      <texPath>Things/Projectile/RobCo_NukeMissile</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>TransparentPostLight</shaderType>
    </graphicData>
    <!-- Based on doomsday launcher -->
    <thingClass>FIP_RobCo.Projectile_FatManPolluting</thingClass>
    <projectile>
      <damageDef>Bomb</damageDef>
      <flyOverhead>true</flyOverhead>
      <damageAmountBase>95</damageAmountBase>
      <explosionRadius>10</explosionRadius>
      <speed>40</speed>
    </projectile>
  </ThingDef>

  <ThingDef ParentName="BaseBullet">
    <defName>RobCo_Bullet_Nail</defName>
    <label>nail</label>
    <graphicData>
      <texPath>Things/Projectile/RobCo_Nail</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>TransparentPostLight</shaderType>
    </graphicData>
    <projectile>
      <damageDef>Bullet</damageDef>
      <damageAmountBase>5</damageAmountBase>
      <armorPenetrationBase>1</armorPenetrationBase>
      <stoppingPower>3</stoppingPower>
      <speed>50</speed>
    </projectile>
  </ThingDef>

  <!-- Sonic Bark -->
  <ThingDef ParentName="BaseBullet">
    <defName>RobCo_Bullet_SonicBark</defName>
    <label>sonic bark</label>
    <graphicData>
      <texPath>RobCo/Misc/Invisible</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <projectile>
      <damageDef>EMP</damageDef>
      <explosionRadius>3.5</explosionRadius>
      <speed>70</speed>
      <applyDamageToExplosionCellsNeighbors>false</applyDamageToExplosionCellsNeighbors>
    </projectile>
  </ThingDef>

  <!-- Syringe -->
  <ThingDef ParentName="BaseBullet">
    <defName>RobCo_Bullet_Syringe</defName>
    <label>syringe shell</label>
    <graphicData>
      <texPath>Things/Projectile/ToxicNeedleShot</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <projectile>
      <damageDef>BulletToxic</damageDef>
      <damageAmountBase>25</damageAmountBase>
      <armorPenetrationBase>0.35</armorPenetrationBase>
      <stoppingPower>1.5</stoppingPower>
      <speed>90</speed>
    </projectile>
  </ThingDef>


</Defs>