  <!-- For Sentry Bot Siegebreaker -->
  <AbilityDef>
    <defName>RobCo_BackMissileLauncher</defName>
    <label>back missile launcher</label>
    <description>Launches a barrage of missiles.</description>
    <iconPath>UI/Abilities/RocketsMissileLauncher</iconPath>
    <aiCanUse>true</aiCanUse>
    <ai_IsIncendiary>true</ai_IsIncendiary>
    <cooldownTicksRange>1500~1500</cooldownTicksRange>
    <displayGizmoWhileUndrafted>false</displayGizmoWhileUndrafted>
    <showPsycastEffects>false</showPsycastEffects>
    <verbProperties>
      <verbClass>Verb_CastAbility</verbClass>
      <requireLineOfSight>false</requireLineOfSight>
      <range>40</range>
      <minRange>10</minRange>
      <warmupTime>2</warmupTime>
      <soundCast>RobCo_Shot_Launcher</soundCast>
      <targetParams>
        <canTargetLocations>true</canTargetLocations>
        <canTargetPawns>false</canTargetPawns>
        <canTargetBuildings>true</canTargetBuildings>
      </targetParams>
    </verbProperties>
    <comps>
      <li Class="FIP_RobCo.CompProperties_AbilityLaunchProjectileMultiple">
        <projectileDef>RobCo_Rocket_Heavy</projectileDef>
        <forcedMissRadius>2.9</forcedMissRadius>
        <ticksBetweenBurstShots>20</ticksBetweenBurstShots>
        <burstShotCount>3</burstShotCount>
        <maxCharges>2</maxCharges>
        <soundReload>Standard_Reload</soundReload>
        <chargeNoun>missile</chargeNoun>
        <ammoDef>Chemfuel</ammoDef>
        <ammoCountPerCharge>20</ammoCountPerCharge>
      </li>
    </comps>
  </AbilityDef>

  <!-- For Deathbot -->
  <AbilityDef>
