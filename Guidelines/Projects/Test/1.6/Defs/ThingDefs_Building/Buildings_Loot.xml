	</ThingDef>
	<ThingDef ParentName="SEX_PortalBase_SalvagePoint_Unloadable">
		<defName>SEX_WeaponCrateVertical</defName>
		<label>military crate</label>
		<description>A military crate for storing equipment. Can be cracked open to reveal the loot inside.</description>
		<graphicData>
			<graphicClass>Graphic_Random</graphicClass>
			<texPath>Things/Buildings/Lootable/SEX_GunCrateVertical</texPath>
			<drawSize>(1,2)</drawSize>
		</graphicData>
		<size>(1,2)</size>
		<modExtensions>
			<li Class="SEX_Machinists.SEX_LootableBuildings">
				<sound>AncientCommsConsoleActivated</sound>
				<openedGraphicdata>
					<graphicClass>Graphic_Random</graphicClass>
					<texPath>Things/Buildings/Lootable/SEX_GunCrateVerticalOpen</texPath>
					<drawSize>(1,2)</drawSize>
				</openedGraphicdata>
				<loots>
					<li>SEX_Weapons</li>
				</loots>
			</li>
		</modExtensions>
	</ThingDef>
