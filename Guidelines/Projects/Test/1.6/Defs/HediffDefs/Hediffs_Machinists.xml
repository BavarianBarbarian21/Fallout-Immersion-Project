<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<HediffDef ParentName="RoleStatBuff">
		<defName>SEX_MarksmanCommand</defName>
		<label>marksman command</label>
		<description>This person is using a special ability to call out shots. Everyone within an effect radius gains shooting bonuses.</description>
		<hediffClass>HediffWithComps</hediffClass>
		<comps>
			<li Class="HediffCompProperties_Disappears">
				<showRemainingTime>True</showRemainingTime>
			</li>
			<li Class="HediffCompProperties_DisappearsOnDeath"/>
			<li Class="HediffCompProperties_GiveHediffsInRange">
				<range>14.9</range>
				<mote>Mote_CombatCommand</mote>
				<hideMoteWhenNotDrafted>true</hideMoteWhenNotDrafted>
				<onlyPawnsInSameFaction>true</onlyPawnsInSameFaction>
				<targetingParameters>
					<canTargetBuildings>false</canTargetBuildings>
					<canTargetAnimals>false</canTargetAnimals>
					<canTargetMechs>false</canTargetMechs>
				</targetingParameters>
				<hediff>MarksmanCommandBuff</hediff>
			</li>
		</comps>
		<isBad>false</isBad>
	</HediffDef>
	<ThingDef ParentName="MoteBase">
		<defName>SEX_Mote_MedicCommand</defName>
		<thingClass>MoteAttached</thingClass>
		<altitudeLayer>LightingOverlay</altitudeLayer>
		<drawOffscreen>true</drawOffscreen>
		<mote>
			<solidTime>9999999</solidTime>
			<needsMaintenance>true</needsMaintenance>
		</mote>
		<graphicData>
			<graphicClass>Graphic_Mote</graphicClass>
			<texPath>Things/Mote/CombatCommandMask</texPath>
			<shaderType>MoteGlow</shaderType>
			<color>(0, 82, 0)</color>
			<drawSize>5</drawSize>
		</graphicData>
	</ThingDef>
	<HediffDef ParentName="RoleStatBuff">
		<defName>SEX_CombatMedic</defName>
		<label>medic command</label>
		<description>This person is helping mitigate injuries of nearby soldiers.</description>
		<hediffClass>HediffWithComps</hediffClass>
		<comps>
			<li Class="HediffCompProperties_Disappears">
				<showRemainingTime>True</showRemainingTime>
			</li>
			<li Class="HediffCompProperties_DisappearsOnDeath"/>
			<li Class="HediffCompProperties_GiveHediffsInRange">
				<range>3.9</range>
				<mote>SEX_Mote_MedicCommand</mote>
				<hideMoteWhenNotDrafted>true</hideMoteWhenNotDrafted>
				<onlyPawnsInSameFaction>true</onlyPawnsInSameFaction>
				<targetingParameters>
					<canTargetBuildings>false</canTargetBuildings>
					<canTargetAnimals>false</canTargetAnimals>
					<canTargetMechs>false</canTargetMechs>
				</targetingParameters>
				<hediff>SEX_CombatMedicBuff</hediff>
			</li>
		</comps>
		<isBad>false</isBad>
	</HediffDef>
	<HediffDef ParentName="CombatRoleAuraBuffHediffBase">
		<defName>SEX_CombatMedicBuff</defName>
		<label>damage control</label>
		<description>A nearby combat medic is mitigating any injuries this person may receive.</description>
		<debugLabelExtra>other</debugLabelExtra>
		<stages>
			<li>
				<statFactors>
					<IncomingDamageFactor>0.8</IncomingDamageFactor>
				</statFactors>
			</li>
		</stages>
	</HediffDef>
</Defs>
