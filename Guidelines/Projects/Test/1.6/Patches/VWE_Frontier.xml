<?xml version="1.0" encoding="utf-8"?>
<Patch>
	<Operation Class="PatchOperationFindMod">
		<mods>
			<li>Vanilla Weapons Expanded - Frontier</li>
		</mods>
		<match Class="PatchOperationSequence">
			<operations>
				<li Class="PatchOperationAdd">
					<xpath>/Defs/ThingDef[defName="VWEFT_Gun_RepeatingShotgun"]/weaponTags</xpath>
					<value>
						<li>SEX_LightMercWeapons</li>
					</value>
				</li>
				<li Class="PatchOperationAdd">
					<xpath>/Defs/ThingDef[defName="VWEFT_Gun_RepeatingShotgun"]/weaponTags</xpath>
					<value>
						<li>SEX_MinutemanWeapons</li>
					</value>
				</li>
			</operations>
		</match>
	</Operation>
</Patch>