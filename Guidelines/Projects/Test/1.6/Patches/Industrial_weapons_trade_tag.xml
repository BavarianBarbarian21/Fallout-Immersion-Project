<?xml version="1.0" encoding="utf-8"?>
<Patch>
	<Operation Class="PatchOperationAdd">
		<success>Always</success>
		<xpath>Defs/ThingDef[apparel/tags/li="IndustrialMilitaryBasic" or apparel/tags/li="IndustrialMilitaryAdvanced" and (tradeTags)]/tradeTags</xpath>
		<value>
			<li>SEX_IndustrialApparelTradeTag</li>
		</value>
	</Operation>
	<Operation Class="PatchOperationAdd">
		<success>Always</success>
		<xpath>Defs/ThingDef[weaponTags/li="IndustrialGunAdvanced" and (tradeTags) or weaponTags/li="SimpleGun" and (tradeTags)]/tradeTags</xpath>
		<value>
			<li>SEX_IndustrialWeaponsTradeTag</li>
		</value>
	</Operation>
	<Operation Class="PatchOperationAdd">
		<success>Always</success>
		<xpath>Defs/ThingDef[weaponTags/li="IndustrialGunAdvanced" and not (tradeTags) or weaponTags/li="SimpleGun" and not (tradeTags)]</xpath>
		<value>
			<tradeTags>
				<li>SEX_IndustrialWeaponsTradeTag</li>
			</tradeTags>
		</value>
	</Operation>
	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="VAE_Apparel_Gambeson"]</xpath>
		<value>
			<tradeTags>
				<li>SEX_IndustrialApparelTradeTag</li>
			</tradeTags>
		</value>
	</Operation>
	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="VAE_Apparel_QuiltedVest"]</xpath>
		<value>
			<tradeTags>
				<li>SEX_IndustrialApparelTradeTag</li>
			</tradeTags>
		</value>
	</Operation>
	<Operation Class="PatchOperationFindMod">
		<mods>
			<li>Biotech</li>
		</mods>
		<match Class="PatchOperationSequence">
			<operations>
				<li Class="PatchOperationAdd">
					<xpath>Defs/ThingDef[defName="Apparel_Bandolier"]/tradeTags</xpath>
					<value>
						<li>SEX_IndustrialApparelTradeTag</li>
					</value>
				</li>
			</operations>
		</match>
	</Operation>
	<Operation Class="PatchOperationFindMod">
		<mods>
			<li>Combat Extended</li>
		</mods>
		<match Class="PatchOperationSequence">
			<operations>
				<li Class="PatchOperationAdd">
					<xpath>Defs/ThingDef[defName="CE_Apparel_SimpleNightVision"]/tradeTags</xpath>
					<value>
						<li>SEX_IndustrialApparelTradeTag</li>
					</value>
				</li>
				<li Class="PatchOperationAdd">
					<xpath>Defs/ThingDef[defName="CE_Apparel_BallisticShield"]/tradeTags</xpath>
					<value>
						<li>SEX_IndustrialApparelTradeTag</li>
					</value>
				</li>
			</operations>
		</match>
	</Operation>
</Patch>