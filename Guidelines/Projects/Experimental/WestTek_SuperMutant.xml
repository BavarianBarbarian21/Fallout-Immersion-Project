<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <!--First Generation Super Mutant Xenotypes-->
  <XenotypeDef>
    <defName>WestTek_Xenotype_SuperMutantFirst</defName>
    <label>first generation super mutant</label>
    <description>First generation super mutants are the earliest stable survivors of direct Forced Evolutionary Virus exposure. They are broader, harder to kill, and even further removed from baseline humanity than later generations, though their minds Grew just as much as they're body.</description>
    <descriptionShort>Earlier, harsher Forced Evolutionary Virus subjects, big and mean, but not mindless.</descriptionShort>
    <iconPath>UI/Icons/Xenotypes/Baseliner</iconPath>
    <inheritable>true</inheritable>
    <nameMaker>HHTools_PawnNameMaker_SuperMutant_Male</nameMaker>
    <nameMakerFemale>HHTools_PawnNameMaker_Mutant_Female</nameMakerFemale>
    <chanceToUseNameMaker>1</chanceToUseNameMaker>
    <genes>
      <li>AptitudeRemarkable_Mining</li>
      <li>AptitudeStrong_Melee</li>
      <li>Aptitudestrong_Intellectual</li>
      <li>AptitudeTerrible_Cooking</li>

      <li>Ageless</li>
      <li>PerfectImmunity</li>
      <li>MinTemp_LargeDecrease</li>
      <li>MaxTemp_SmallIncrease</li>
      <li>MoveSpeed_Slow</li>
      <li>ToxResist_Total</li>
      <li>ToxicEnvironmentResistance_Total</li>
      <li>Aggression_HyperAggressive</li>
      <li>MeleeDamage_Strong</li>
      <li>KillThirst</li>
      <li>Robust</li>
      <li>Pain_Reduced</li>
      <li>Sterile</li>
      <li>Libido_Low</li>
      <li>Beauty_VeryUgly</li>
      <li>Learning_High</li>
      <li>Unstoppable</li>
      <li>StrongStomach</li>
      <li>RobustDigestion</li>

      <li>Body_Hulk</li>
      <li>Hair_BaldOnly</li>
      <li>Beard_NoBeardOnly</li>
      <li>Skin_Green</li>

      <li>WestTek_Gene_SuperMutant</li>
    </genes>
  </XenotypeDef>
  
  <!--Second Generation Super Mutant Xenotypes-->
  <XenotypeDef>
    <defName>WestTek_Xenotype_SuperMutantSecond</defName>
    <label>second generation super mutant</label>
    <description>Super Mutants are the children of the wasteland’s cruel experiments. Towering, musclebound, and nearly immortal, they are the outcome of forced evolution and forgotten ambition. Though often seen as monsters, some retain fractured shards of who they were—flickers of humanity behind monstrous eyes.</description>
    <descriptionShort>Massive, radiation-forged brutes born of twisted science and endless war.</descriptionShort>
    <iconPath>UI/Icons/Xenotypes/Baseliner</iconPath>
    <inheritable>true</inheritable>
    <nameMaker>HHTools_PawnNameMaker_SuperMutant_Male</nameMaker>
    <nameMakerFemale>HHTools_PawnNameMaker_Mutant_Female</nameMakerFemale>
    <chanceToUseNameMaker>1</chanceToUseNameMaker>
    <genes>
      <li>AptitudeRemarkable_Mining</li>
      <li>AptitudeStrong_Melee</li>
      <li>AptitudePoor_Intellectual</li>
      <li>AptitudeTerrible_Cooking</li>

      <li>Ageless</li>
      <li>PerfectImmunity</li>
      <li>MinTemp_LargeDecrease</li>
      <li>MaxTemp_SmallIncrease</li>
      <li>MoveSpeed_Slow</li>
      <li>ToxResist_Total</li>
      <li>ToxicEnvironmentResistance_Total</li>
      <li>Aggression_HyperAggressive</li>
      <li>MeleeDamage_Strong</li>
      <li>KillThirst</li>
      <li>Robust</li>
      <li>Pain_Reduced</li>
      <li>Sterile</li>
      <li>Libido_Low</li>
      <li>Beauty_VeryUgly</li>
      <li>Learning_Slow</li>
      <li>Unstoppable</li>
      <li>StrongStomach</li>
      <li>RobustDigestion</li>

      <li>Body_Hulk</li>
      <li>Hair_BaldOnly</li>
      <li>Beard_NoBeardOnly</li>
      <li>Skin_Green</li>

      <li>WestTek_Gene_SuperMutant</li>
    </genes>
  </XenotypeDef>
</Defs>