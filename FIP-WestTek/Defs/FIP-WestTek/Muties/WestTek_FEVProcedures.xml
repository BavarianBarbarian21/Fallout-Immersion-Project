<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <RecipeDef ParentName="SurgeryFlesh">
    <defName>WestTek_AdministerUnrefinedFEVDosage</defName>
    <label>administer unrefined FEV dosage</label>
    <description>Inject an unstable Forced Evolutionary Virus dose into a colony prisoner. Outcomes are evenly split between centaur conversion, super mutant conversion, and catastrophic tissue collapse.</description>
    <workerClass>FIP.WestTek.Recipe_AdministerUnrefinedFEVDosage</workerClass>
    <jobString>Administering unrefined FEV dosage to TargetA.</jobString>
    <workAmount>1600</workAmount>
    <hideBodyPartNames>true</hideBodyPartNames>
    <targetsBodyPart>false</targetsBodyPart>
    <isViolation>true</isViolation>
    <deathOnFailedSurgeryChance>0.12</deathOnFailedSurgeryChance>
    <skillRequirements>
      <Medicine>5</Medicine>
    </skillRequirements>
    <researchPrerequisite>
      <li>WestTek_FEV1</li>
    </researchPrerequisite>
    <uiIconThing>WestTek_UnrefinedFEVDosage</uiIconThing>
    <ingredients>
      <li>
        <filter>
          <thingDefs>
            <li>WestTek_UnrefinedFEVDosage</li>
          </thingDefs>
        </filter>
        <count>1</count>
      </li>
      <li>
        <filter>
          <categories>
            <li>Medicine</li>
          </categories>
        </filter>
        <count>2</count>
      </li>
    </ingredients>
    <fixedIngredientFilter>
      <thingDefs>
        <li>WestTek_UnrefinedFEVDosage</li>
      </thingDefs>
      <categories>
        <li>Medicine</li>
      </categories>
    </fixedIngredientFilter>
  </RecipeDef>

