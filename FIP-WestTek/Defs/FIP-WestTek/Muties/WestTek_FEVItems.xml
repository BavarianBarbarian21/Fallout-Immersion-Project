<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <ThingDef ParentName="ResourceBase">
    <defName>WestTek_FEVProbe</defName>
    <label>FEV probe</label>
    <description>A crude pre-refinement sample of Forced Evolutionary Virus growth medium. It is unstable, dangerous, and only useful in aggregate.</description>
    <graphicData>
      <texPath>FIP-WestTek/Muties/Misc/WestTek_FEVProbe</texPath>
      <graphicClass>Graphic_StackCount</graphicClass>
    </graphicData>
    <stackLimit>75</stackLimit>
    <statBases>
      <MarketValue>18</MarketValue>
      <Mass>0.03</Mass>
    </statBases>
  </ThingDef>

  <ThingDef ParentName="ResourceBase">
    <defName>WestTek_FEVSample</defName>
    <label>FEV sample</label>
