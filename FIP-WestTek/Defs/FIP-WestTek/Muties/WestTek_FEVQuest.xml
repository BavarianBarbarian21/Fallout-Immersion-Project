<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <IncidentDef>
    <defName>WestTek_GiveQuest_AncientWestTekLaboratory</defName>
    <category>GiveQuest</category>
    <label>ancient West Tek laboratory</label>
    <targetTags>
      <li>Map_PlayerHome</li>
    </targetTags>
    <letterLabel>ancient West Tek laboratory</letterLabel>
    <questScriptDef>WestTek_OpportunitySite_AncientWestTekLaboratory</questScriptDef>
    <workerClass>IncidentWorker_GiveQuest</workerClass>
    <baseChance>0.1</baseChance>
    <requireColonistsPresent>true</requireColonistsPresent>
    <earliestDay>12</earliestDay>
    <minRefireDays>35</minRefireDays>
  </IncidentDef>

  <QuestScriptDef>
    <defName>WestTek_OpportunitySite_AncientWestTekLaboratory</defName>
    <rootSelectionWeight>0</rootSelectionWeight>
    <rootMinPoints>350</rootMinPoints>
    <autoAccept>true</autoAccept>
    <defaultChallengeRating>1</defaultChallengeRating>
    <isRootSpecial>true</isRootSpecial>
    <questNameRules>
      <rulesStrings>
        <li>questName(p=3)->[complexAdj] West Tek laboratory</li>
        <li>questName->ancient West Tek laboratory</li>
        <li>complexAdj->sealed</li>
        <li>complexAdj->ancient</li>
        <li>complexAdj->hidden</li>
        <li>complexAdj->buried</li>
        <li>complexAdj->quarantined</li>
      </rulesStrings>
    </questNameRules>
    <questDescriptionRules>
      <rulesStrings>
        <li>questDescription->You've [discoveryDesc] of an ancient West Tek laboratory nearby. The site appears to contain sealed FEV research material, including probes and unstable dosages left behind in cryogenic storage.

If you can break into the laboratory and recover the cache, your colonists can begin analyzing the material and establish the first controlled FEV process.

Be warned - facilities of this type can contain dormant mechanoid defenses, and your intrusion may attract unwanted attention.</li>
        <li>discoveryDesc(discovered==false)->learned</li>
        <li>discoveryDesc(discovered==true)->determined the location</li>
      </rulesStrings>
    </questDescriptionRules>
    <root Class="FIP.WestTek.QuestNode_Root_Loot_AncientWestTekLaboratory" />
  </QuestScriptDef>

  <SitePartDef>
    <defName>WestTek_AncientWestTekLaboratory</defName>
    <label>ancient West Tek laboratory</label>
    <description>An ancient West Tek laboratory containing sealed FEV research material. The interior may still be guarded by dormant mechanoid defenses.</description>
    <workerClass>SitePartWorker_AncientComplex</workerClass>
    <siteTexture>World/WorldObjects/Sites/GenericSite</siteTexture>
    <expandingIconTexture>World/WorldObjects/Expanding/Sites/AncientMechanitorComplex</expandingIconTexture>
    <approachOrderString>Investigate {0}</approachOrderString>
    <approachingReportString>Investigating {0}.</approachingReportString>
    <considerEnteringAsAttack>false</considerEnteringAsAttack>
    <arrivedLetterDef>NeutralEvent</arrivedLetterDef>
    <wantsThreatPoints>true</wantsThreatPoints>
    <gravShipsCanLandOn>true</gravShipsCanLandOn>
    <tags>
      <li>WestTek_AncientWestTekLaboratory</li>
    </tags>
  </SitePartDef>

  <GenStepDef>
    <defName>WestTek_AncientWestTekLaboratory</defName>
    <linkWithSite>WestTek_AncientWestTekLaboratory</linkWithSite>
    <order>470</order>
    <genStep Class="FIP.WestTek.GenStep_AncientWestTekLaboratory" />
  </GenStepDef>

  <RuleDef>
    <defName>WestTek_AncientWestTekLaboratory</defName>
    <symbol>ancientWestTekLaboratory</symbol>
    <resolvers>
      <li Class="FIP.WestTek.SymbolResolver_AncientWestTekLaboratory">
        <minRectSize>(18, 18)</minRectSize>
      </li>
    </resolvers>
  </RuleDef>

  <ComplexLayoutDef>
    <defName>WestTek_AncientWestTekLaboratory_Loot</defName>
    <workerClass>FIP.WestTek.LayoutWorkerComplex_AncientWestTekLaboratory</workerClass>
    <roomRewardCrateFactor>0</roomRewardCrateFactor>
    <minRoomWidth>7</minRoomWidth>
    <minRoomHeight>7</minRoomHeight>
    <clearDoorFaction>false</clearDoorFaction>
    <corridorDef>ComplexCorridor</corridorDef>
    <canDisconnectRooms>false</canDisconnectRooms>
    <areaPrunePercent>0.1</areaPrunePercent>
    <roomDefs>
      <AncientRechargeRoom>
        <weight>1</weight>
      </AncientRechargeRoom>
      <AncientMechGestatorRoom>
        <weight>1</weight>
      </AncientMechGestatorRoom>
      <AncientMechGeneratorRoom>
        <weight>1</weight>
      </AncientMechGeneratorRoom>
      <AncientBandNodeRoom>
        <weight>2</weight>
        <countRange>0~2</countRange>
      </AncientBandNodeRoom>
    </roomDefs>
    <threats>
      <SleepingMechanoids />
      <MechDrop />
      <FuelNode MayRequire="Ludeon.RimWorld.Ideology">
        <maxPerRoom>1</maxPerRoom>
        <selectionWeight>3</selectionWeight>
      </FuelNode>
      <RaidTerminal MayRequire="Ludeon.RimWorld.Ideology">
        <maxPerComplex>1</maxPerComplex>
        <chancePerComplex>0.5</chancePerComplex>
      </RaidTerminal>
    </threats>
  </ComplexLayoutDef>
</Defs>