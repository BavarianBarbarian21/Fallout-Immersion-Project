<Defs>
  <!--Flatworms-->
  <RecipeDef>
    <defName>WestTek_MakeFloater</defName>
    <label>create floater</label>
    <description>Condition an early FEV culture inside a flatworm-derived host, yielding a tamed floater specimen.</description>
    <workerClass>FIP.WestTek.RecipeWorker_MakeFloater</workerClass>
    <jobString>Growing a floater specimen.</jobString>
    <workAmount>2200</workAmount>
    <effectWorking>Cook</effectWorking>
    <soundWorking>Recipe_CookMeal</soundWorking>
    <researchPrerequisite>WestTek_FlatwormMutation</researchPrerequisite>
    <workSpeedStat>DrugSynthesisSpeed</workSpeedStat>
    <workSkill>Intellectual</workSkill>
    <recipeUsers>
      <li>DrugLab</li>
    </recipeUsers>
    <ingredients>
      <li>
        <filter>
          <thingDefs>
            <li>WestTek_FEVProbe</li>
          </thingDefs>
        </filter>
        <count>1</count>
      </li>
    </ingredients>
    <fixedIngredientFilter>
      <thingDefs>
        <li>WestTek_FEVProbe</li>
      </thingDefs>
    </fixedIngredientFilter>
    <products>
      <WestTek_FEVProbe>1</WestTek_FEVProbe>
    </products>
  </RecipeDef>

<!--Tier 1 Procedure-->
  

  <!--Tier 2 Procedure-->
  

  <!--Tier 3 Procedure-->
  

    <!--Tier 1 Effect-->
  <HediffDef>
    <defName>WestTek_FEVMutationPending_1</defName>
    <label>unstable FEV exposure</label>
    <description>An unrefined FEV dosage is tearing through this subject's body in violent, uneven waves. Their metabolism surges, tissues misfire, and the mind slips toward paranoia and collapse while the mutation struggles to take hold.</description>
    <isBad>true</isBad>
    <stages>
      <li>
        <mentalBreakMtbDays>12</mentalBreakMtbDays>
      </li>
    </stages>
  </HediffDef>

  <!--Tier 2 Effect-->
  <HediffDef>
    <defName>WestTek_FEVMutationPending_2</defName>
    <label>refined FEV exposure</label>
    <description>A refined FEV strain is restructuring this subject with far more control, but the process is still brutal. Violent mood swings, intrusive aggression, and bouts of instability are common until the body either stabilizes or fails.</description>
    <isBad>true</isBad>
    <stages>
      <li>
        <mentalBreakMtbDays>8</mentalBreakMtbDays>
      </li>
    </stages>
  </HediffDef>

  <!--Tier 3 Effect-->
  <HediffDef>
    <defName>WestTek_FEVMutationPending_3</defName>
    <label>isolated FEV exposure</label>
    <description>An isolated FEV culture is remaking this subject at the deepest biological level. The transformation is faster and cleaner than lesser strains, but the nervous system remains under immense pressure until the final mutation locks into place.</description>
    <isBad>true</isBad>
    <stages>
      <li>
        <mentalBreakMtbDays>4</mentalBreakMtbDays>
      </li>
    </stages>
  </HediffDef>

  <ThingDef>
  <defName>WestTek_UnrefinedFaunaMutagen</defName>
  <label>unrefined fauna mutagen</label>
  <description>An unstable FEV-derived fauna mutagen. Can be used on a living raccoon to force a S'Lanter transformation.</description>
  <thingClass>ThingWithComps</thingClass>
  <category>Item</category>
  <resourceReadoutPriority>Middle</resourceReadoutPriority>
  <stackLimit>10</stackLimit>
  <useHitPoints>false</useHitPoints>
  <selectable>true</selectable>
  <alwaysHaulable>true</alwaysHaulable>
  <tickerType>Never</tickerType>
  <graphicData>
    <texPath>FIP-WestTek/Misc/Placeholder</texPath>
    <graphicClass>Graphic_Single</graphicClass>
  </graphicData>

  <comps>
    <li Class="CompProperties_Targetable">
      <compClass>CompTargetable_SinglePawn</compClass>
    </li>
    <li Class="FIP.WestTek.CompProperties_TargetEffectUnrefinedFaunaMutagen" />
  </comps>

    
    
  <costList><Uranium>75</Uranium></costList><drawGUIOverlay>true</drawGUIOverlay><statBases><Mass>0.1</Mass></statBases><recipeMaker>
    <researchPrerequisite>WestTek_FaunaMutation</researchPrerequisite>
    <recipeUsers>
      <li>DrugLab</li>
    </recipeUsers>
    <workAmount>1200</workAmount>
  </recipeMaker>
</ThingDef>

