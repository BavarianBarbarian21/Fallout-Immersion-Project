  <ThingDef>
    <defName>WestTek_PlantSymbiote</defName>
    <label>plant symbiote</label>
    <description>A living FEV flora symbiote prepared for surgical grafting. West Tek plant prostheses consume one symbiote per operation.</description>
    <thingClass>ThingWithComps</thingClass>
    <category>Item</category>
    <resourceReadoutPriority>Middle</resourceReadoutPriority>
    <stackLimit>25</stackLimit>
    <useHitPoints>false</useHitPoints>
    <selectable>true</selectable>
    <alwaysHaulable>true</alwaysHaulable>
    <tickerType>Never</tickerType>
    <graphicData>
      <texPath>FIP-WestTek/Misc/Placeholder</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <recipeMaker>
      <researchPrerequisite>WestTek_FloraMutation</researchPrerequisite>
      <recipeUsers>
        <li>DrugLab</li>
      </recipeUsers>
      <workAmount>1200</workAmount>
      <ingredients>
        <li>
          <filter>
            <thingDefs>
              <li>Uranium</li>
            </thingDefs>
          </filter>
          <count>100</count>
        </li>
      </ingredients>
      <fixedIngredientFilter>
        <thingDefs>
          <li>Uranium</li>
        </thingDefs>
      </fixedIngredientFilter>
    </recipeMaker>
  </ThingDef>

