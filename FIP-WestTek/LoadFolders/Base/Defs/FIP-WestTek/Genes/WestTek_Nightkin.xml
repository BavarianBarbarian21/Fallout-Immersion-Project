<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <TraitDef>
    <defName>WestTek_NightkinSchizophrenia</defName>
    <description>Violent hallucinations and dissociation associated with advanced Nightkin instability.</description>
    <commonality>0</commonality>
    <degreeDatas>
      <li>
        <label>nightkin schizophrenia</label>
        <description>This pawn is prone to volatile dissociation, extended wandering, and aggressive mental collapse.</description>
        <statOffsets>
          <MentalBreakThreshold>-0.08</MentalBreakThreshold>
          <SocialImpact>-0.1</SocialImpact>
        </statOffsets>
      </li>
    </degreeDatas>
  </TraitDef>

  <AbilityDef>
    <defName>WestTek_NightkinInvisibility</defName>
    <label>nightkin invisibility</label>
    <description>Trigger a Nightkin stealth field and briefly vanish from sight.</description>
    <iconPath>FIP-WestTek/Misc/WestTek_NightkinXenogerm</iconPath>
    <cooldownTicksRange>60000~60000</cooldownTicksRange>
    <writeCombatLog>True</writeCombatLog>
    <hotKey>Misc12</hotKey>
    <targetRequired>false</targetRequired>
    <casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence>
    <statBases>
      <Ability_Duration>15</Ability_Duration>
    </statBases>
    <verbProperties>
      <verbClass>Verb_CastAbility</verbClass>
      <drawAimPie>false</drawAimPie>
      <requireLineOfSight>false</requireLineOfSight>
      <nonInterruptingSelfCast>true</nonInterruptingSelfCast>
      <warmupTime>1</warmupTime>
      <range>19.9</range>
      <targetable>false</targetable>
      <targetParams>
        <canTargetSelf>True</canTargetSelf>
      </targetParams>
    </verbProperties>
    <comps>
      <li Class="CompProperties_AbilityGiveHediff">
        <compClass>CompAbilityEffect_GiveHediff</compClass>
        <hediffDef>PsychicInvisibility</hediffDef>
      </li>
      <li Class="CompProperties_AbilityFleckOnTarget">
        <fleckDef>PsycastPsychicEffect</fleckDef>
      </li>
    </comps>
  </AbilityDef>

  <GeneDef ParentName="WestTek_Gene_Base">
    <defName>WestTek_Gene_Nightkin</defName>
    <label>nightkin stealth field</label>
    <description>Forced Evolutionary Virus and stealth-field instability have fused into a Nightkin phenotype. Carriers turn blue, can trigger a self-camouflaging invisibility field, and suffer the dissociative schizophrenia common to advanced Nightkin degeneration.</description>
    <iconPath>FIP-WestTek/Misc/WestTek_NightkinXenogerm</iconPath>
    <displayCategory>Archite</displayCategory>
    <displayOrderInCategory>210</displayOrderInCategory>
    <skinColorOverride>(55, 111, 170)</skinColorOverride>
    <abilities>
      <li>WestTek_NightkinInvisibility</li>
    </abilities>
    <descriptionHyperlinks>
      <AbilityDef>WestTek_NightkinInvisibility</AbilityDef>
    </descriptionHyperlinks>
    <forcedTraits>
      <li>
        <def>WestTek_NightkinSchizophrenia</def>
      </li>
    </forcedTraits>
    <statOffsets>
      <MoveSpeed>0.1</MoveSpeed>
      <MeleeHitChance>0.05</MeleeHitChance>
    </statOffsets>
    <biostatMet>2</biostatMet>
  </GeneDef>

</Defs>
