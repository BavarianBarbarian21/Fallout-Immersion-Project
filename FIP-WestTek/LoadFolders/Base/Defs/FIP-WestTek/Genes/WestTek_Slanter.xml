<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <!--Ears-->
<GeneDef ParentName="GeneEarsBase">
  <defName>WestTek_CoonEars</defName>
  <label>raccoon ears</label>
  <description>Carriers of this gene have rounded raccoon-like ears, a hallmark of the S'Lanter and S'Nuffy lineages.</description>

  <iconPath>UI/Icons/Genes/Gene_CoonEars</iconPath>

  <renderNodeProperties>
    <li>
      <nodeClass>PawnRenderNode_AttachmentHead</nodeClass>
      <workerClass>PawnRenderNodeWorker_FlipWhenCrawling</workerClass>

      <texPath>Things/Pawn/Humanlike/HeadAttachments/CoonEars/CoonEars</texPath>

      <colorType>Skin</colorType>

      <parentTagDef>Head</parentTagDef>

      <useSkinShader>true</useSkinShader>
      <useRottenColor>true</useRottenColor>

      <rotDrawMode>Fresh, Rotting</rotDrawMode>

      <drawData>
        <defaultData>
          <layer>70</layer>
        </defaultData>
      </drawData>
    </li>
  </renderNodeProperties>

  <symbolPack>
    <prefixSymbols>
      <li><symbol>raccoon</symbol></li>
      <li><symbol>coon</symbol></li>
      <li><symbol>procyon</symbol></li>
      <li><symbol>ringtail</symbol></li>
      <li><symbol>mask</symbol></li>
    </prefixSymbols>

    <suffixSymbols>
      <li><symbol>raccoon</symbol></li>
      <li><symbol>coon</symbol></li>
      <li><symbol>ringtail</symbol></li>
      <li><symbol>ear</symbol></li>
      <li><symbol>procyon</symbol></li>
    </suffixSymbols>
  </symbolPack>
</GeneDef>

  <!-- S'Nuffy combined skin + hair coloration genes -->

