<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <!--Ears-->
<GeneDef ParentName="GeneEarsBase">
  <defName>WestTek_SaplingGrowth</defName>
  <label>sapling growth</label>
  <description>Carriers of this gene develop small living saplings that sprout from their bodies. These symbiotic growths are characteristic of the Numen lineage, sustained by the host's mutated physiology.</description>

  <iconPath>UI/Icons/Genes/Gene_SaplingGrowth</iconPath>

  <renderNodeProperties>
    <li>
      <nodeClass>PawnRenderNode_AttachmentHead</nodeClass>
      <workerClass>PawnRenderNodeWorker_FlipWhenCrawling</workerClass>

      <texPath>Things/Pawn/Humanlike/HeadAttachments/Saplings/Saplings</texPath>

      <colorType>Skin</colorType>

      <parentTagDef>Head</parentTagDef>

      <useSkinShader>true</useSkinShader>
      <useRottenColor>true</useRottenColor>

      <rotDrawMode>Fresh, Rotting</rotDrawMode>

      <drawData>
        <defaultData>
          <layer>70</layer>
        </defaultData>
      </drawData>
    </li>
  </renderNodeProperties>

  <symbolPack>
    <prefixSymbols>
      <li><symbol>plant</symbol></li>
      <li><symbol>flora</symbol></li>
      <li><symbol>sapling</symbol></li>
      <li><symbol>leaf</symbol></li>
      <li><symbol>vine</symbol></li>
    </prefixSymbols>

    <suffixSymbols>
      <li><symbol>plant</symbol></li>
      <li><symbol>sapling</symbol></li>
      <li><symbol>sprout</symbol></li>
      <li><symbol>flora</symbol></li>
      <li><symbol>leaf</symbol></li>
    </suffixSymbols>
  </symbolPack>
</GeneDef>

<GeneDef>
  <defName>WestTek_FEVSymbioticSenses</defName>
  <label>flowering senses</label>
  <description>The subject's sensory organs bloom into a responsive plant-human symbiosis.</description>
  <iconPath>UI/Icons/Genes/WestTek_FloweringSenses</iconPath>
  <displayOrderInCategory>610</displayOrderInCategory>
  <biostatCpx>2</biostatCpx>
  <biostatMet>-1</biostatMet>
  <skillGains>
    <Shooting>2</Shooting>
    <Medical>1</Medical>
  </skillGains>
  <!-- Ability später:
  <abilities>
    <li>WestTek_Ability_Flowering</li>
  </abilities>
  -->
</GeneDef>

<GeneDef>
  <defName>WestTek_FEVSymbioticMotorics</defName>
  <label>growing strong</label>
  <description>The subject's limbs and connective tissue are reinforced by living FEV flora.</description>
  <iconPath>UI/Icons/Genes/WestTek_GrowingStrong</iconPath>
  <displayOrderInCategory>611</displayOrderInCategory>
  <biostatCpx>2</biostatCpx>
  <biostatMet>-1</biostatMet>
  <statOffsets>
    <MoveSpeed>0.15</MoveSpeed>
    <MeleeDPS>0.25</MeleeDPS>
  </statOffsets>
  <!-- Ability später:
  <abilities>
    <li>WestTek_Ability_GrowingStrong</li>
  </abilities>
  -->
</GeneDef>

<GeneDef>
  <defName>WestTek_FEVSymbioticOrgans</defName>
  <label>rooted organs</label>
  <description>The subject's internal organs are stabilized by invasive but beneficial root systems.</description>
  <iconPath>UI/Icons/Genes/WestTek_RootedOrgans</iconPath>
  <displayOrderInCategory>612</displayOrderInCategory>
  <biostatCpx>2</biostatCpx>
  <biostatMet>-1</biostatMet>
  <statFactors>
    <ImmunityGainSpeed>1.15</ImmunityGainSpeed>
    <ToxicResistance>1.25</ToxicResistance>
  </statFactors>
  <!-- Ability später:
  <abilities>
    <li>WestTek_Ability_Rooted</li>
  </abilities>
  -->
</GeneDef>

<GeneDef ParentName="GeneSkinColorOverride">
  <defName>WestTek_Gene_SolarPowered</defName>
  <label>solar powered</label>
  <labelShortAdj>solar</labelShortAdj>
  <description>The subject's skin contains FEV-adapted chlorophyll tissue. They slowly replenish nutrition while standing in direct daylight.</description>
  <geneClass>FIP.WestTek.Gene_WestTekSolarPowered</geneClass>
  <iconPath>UI/Icons/Genes/WestTek_SolarPowered</iconPath>
  <skinColorOverride>(92, 135, 74)</skinColorOverride>
  <hairColorOverride>(55, 86, 45)</hairColorOverride>
  <displayOrderInCategory>620</displayOrderInCategory>
  <randomBrightnessFactor>0</randomBrightnessFactor>
  <biostatCpx>2</biostatCpx>
  <biostatMet>-2</biostatMet>
</GeneDef>

<GeneDef>
  <defName>WestTek_Gene_Myceline</defName>
  <label>myceline</label>
  <description>The subject's nervous system resonates with old root networks and Gauranlen-like organisms.</description>
  <iconPath>UI/Icons/Genes/WestTek_Myceline</iconPath>
  <displayOrderInCategory>621</displayOrderInCategory>
  <biostatCpx>2</biostatCpx>
  <biostatMet>-1</biostatMet>
  <skillGains>
    <Plants>2</Plants>
    <Animals>1</Animals>
  </skillGains>
</GeneDef>

<ThoughtDef>
  <defName>WestTek_MycelineNetwork</defName>
  <workerClass>FIP.WestTek.ThoughtWorker_WestTek_MycelineNetwork</workerClass>
  <stages>
    <li>
      <label>near mycelial network</label>
      <description>I can feel the old roots thinking beneath me.</description>
      <baseMoodEffect>6</baseMoodEffect>
    </li>
  </stages>
</ThoughtDef>

<GeneDef>
  <defName>WestTek_Gene_Starched</defName>
  <label>starched</label>
  <description>The subject feels metabolically stable under open sky and has an instinctive affinity for cultivation.</description>
  <iconPath>UI/Icons/Genes/WestTek_Starched</iconPath>
  <displayOrderInCategory>622</displayOrderInCategory>
  <biostatCpx>1</biostatCpx>
  <biostatMet>-1</biostatMet>
  <skillGains>
    <Plants>4</Plants>
  </skillGains>
</GeneDef>

<ThoughtDef>
  <defName>WestTek_StarchedOutside</defName>
  <workerClass>FIP.WestTek.ThoughtWorker_WestTek_StarchedOutside</workerClass>
  <stages>
    <li>
      <label>under open sky</label>
      <description>The open air keeps my starch reserves calm and balanced.</description>
      <baseMoodEffect>10</baseMoodEffect>
    </li>
  </stages>
</ThoughtDef>

<GeneDef>
  <defName>WestTek_Gene_Heterotroph</defName>
  <label>heterotroph</label>
  <description>The subject's fungal metabolism thrives away from direct sunlight but reacts poorly to bright exposure.</description>
  <iconPath>UI/Icons/Genes/WestTek_Heterotroph</iconPath>
  <displayOrderInCategory>623</displayOrderInCategory>
  <biostatCpx>1</biostatCpx>
  <biostatMet>1</biostatMet>
</GeneDef>

<ThoughtDef>
  <defName>WestTek_HeterotrophDark</defName>
  <workerClass>FIP.WestTek.ThoughtWorker_WestTek_HeterotrophDark</workerClass>
  <stages>
    <li>
      <label>away from sunlight</label>
      <description>The shaded air lets my fungal metabolism settle.</description>
      <baseMoodEffect>10</baseMoodEffect>
    </li>
  </stages>
</ThoughtDef>

<ThoughtDef>
  <defName>WestTek_HeterotrophSunlight</defName>
  <workerClass>FIP.WestTek.ThoughtWorker_WestTek_HeterotrophSunlight</workerClass>
  <stages>
    <li>
      <label>under harsh sunlight</label>
      <description>The light burns through my fungal tissues.</description>
      <baseMoodEffect>-5</baseMoodEffect>
    </li>
  </stages>
</ThoughtDef>

<GeneDef>
  <defName>WestTek_Gene_SporeCarrier</defName>
  <label>spore carrier</label>
  <description>The subject carries infectious FEV spores and can force compatible victims into the Spore Carrier strain.</description>
  <iconPath>UI/Icons/Genes/WestTek_SporeCarrier</iconPath>
  <displayOrderInCategory>624</displayOrderInCategory>
  <biostatCpx>4</biostatCpx>
  <biostatMet>-2</biostatMet>
  <abilities>
    <li>WestTek_Ability_SporeInfect</li>
  </abilities>
</GeneDef>

<AbilityDef>
  <defName>WestTek_Ability_SporeInfect</defName>
  <label>spore infect</label>
  <description>Infect a compatible human pawn with unstable FEV spores, transforming them into a Spore Carrier.</description>
  <iconPath>UI/Abilities/WestTek_SporeInfect</iconPath>
  <targetRequired>true</targetRequired>
  <cooldownTicksRange>180000</cooldownTicksRange>
  <verbProperties>
    <range>3.9</range>
    <warmupTime>1.5</warmupTime>
    <requireLineOfSight>true</requireLineOfSight>
    <targetParams>
      <canTargetPawns>true</canTargetPawns>
      <canTargetAnimals>false</canTargetAnimals>
      <canTargetMechs>false</canTargetMechs>
      <canTargetBuildings>false</canTargetBuildings>
      <canTargetItems>false</canTargetItems>
    </targetParams>
  </verbProperties>
  <comps>
    <li Class="FIP.WestTek.CompProperties_AbilitySporeInfect" />
  </comps>
</AbilityDef>

<GeneDef>
  <defName>WestTek_ExtremeSkillLoss</defName>
  <label>extreme skill loss</label>
  <description>Carriers of this gene forget skills twice as fast.</description>
  <iconPath>UI/Icons/Genes/WestTek_ExtremeSkillLoss</iconPath>
  <displayOrderInCategory>630</displayOrderInCategory>
  <biostatCpx>1</biostatCpx>
  <biostatMet>4</biostatMet>
  <exclusionTags>
    <li>WestTek_SkillLoss</li>
  </exclusionTags>
  <modExtensions>
    <li Class="FIP.WestTek.WestTekFloraGeneExtension">
      <skillLossMultiplier>2</skillLossMultiplier>
    </li>
  </modExtensions>
</GeneDef>

<GeneDef>
  <defName>WestTek_SevereSkillLoss</defName>
  <label>severe skill loss</label>
  <description>Carriers of this gene forget skills 50% faster.</description>
  <iconPath>UI/Icons/Genes/WestTek_SevereSkillLoss</iconPath>
  <displayOrderInCategory>631</displayOrderInCategory>
  <biostatCpx>1</biostatCpx>
  <biostatMet>2</biostatMet>
  <exclusionTags>
    <li>WestTek_SkillLoss</li>
  </exclusionTags>
  <modExtensions>
    <li Class="FIP.WestTek.WestTekFloraGeneExtension">
      <skillLossMultiplier>1.5</skillLossMultiplier>
    </li>
  </modExtensions>
</GeneDef>

<GeneDef>
  <defName>WestTek_MinorSkillLoss</defName>
  <label>minor skill loss</label>
  <description>Carriers of this gene forget skills half as fast.</description>
  <iconPath>UI/Icons/Genes/WestTek_MinorSkillLoss</iconPath>
  <displayOrderInCategory>632</displayOrderInCategory>
  <biostatCpx>1</biostatCpx>
  <biostatMet>-3</biostatMet>
  <exclusionTags>
    <li>WestTek_SkillLoss</li>
  </exclusionTags>
  <modExtensions>
    <li Class="FIP.WestTek.WestTekFloraGeneExtension">
      <skillLossMultiplier>0.5</skillLossMultiplier>
    </li>
  </modExtensions>
</GeneDef>

<GeneDef>
  <defName>WestTek_NoSkillLoss</defName>
  <label>no skill loss</label>
  <description>Carriers of this gene do not forget skills.</description>
  <iconPath>UI/Icons/Genes/WestTek_NoSkillLoss</iconPath>
  <displayOrderInCategory>633</displayOrderInCategory>
  <biostatCpx>1</biostatCpx>
  <biostatMet>-5</biostatMet>
  <exclusionTags>
    <li>WestTek_SkillLoss</li>
  </exclusionTags>
  <modExtensions>
    <li Class="FIP.WestTek.WestTekFloraGeneExtension">
      <skillLossMultiplier>0</skillLossMultiplier>
    </li>
  </modExtensions>
</GeneDef>

<GeneDef>
  <defName>WestTek_SkillDegradation</defName>
  <label>skill degradation</label>
  <description>Carriers of this gene slowly lose skill experience even below normal decay thresholds.</description>
  <iconPath>UI/Icons/Genes/WestTek_SkillDegradation</iconPath>
  <displayOrderInCategory>634</displayOrderInCategory>
  <biostatCpx>1</biostatCpx>
  <biostatMet>2</biostatMet>
  <exclusionTags>
    <li>WestTek_SkillLoss</li>
  </exclusionTags>
  <modExtensions>
    <li Class="FIP.WestTek.WestTekFloraGeneExtension">
      <skillDegradation>true</skillDegradation>
    </li>
  </modExtensions>
</GeneDef>

<GeneDef>
  <defName>WestTek_NoStudy</defName>
  <label>no study</label>
  <description>Carriers of this gene cannot learn new skills.</description>
  <iconPath>UI/Icons/Genes/WestTek_NoStudy</iconPath>
  <displayOrderInCategory>635</displayOrderInCategory>
  <biostatCpx>1</biostatCpx>
  <biostatMet>4</biostatMet>
  <exclusionTags>
    <li>Learning</li>
  </exclusionTags>
  <statFactors>
    <GlobalLearningFactor>0</GlobalLearningFactor>
  </statFactors>
</GeneDef>


</Defs>