<?xml version="1.0" encoding="utf-8"?>
<Defs>
    <!--Unity Robe-->
  <ThingDef ParentName="ApparelMakeableBase">
    <defName>WestTek_Apparel_UnityRobe</defName>
    <label>unity robe</label>
    <description>A ceremonial robe worn by members of the Unity and other FEV cultists.</description>
    <techLevel>Spacer</techLevel>
    <recipeMaker>
      <skillRequirements>
        <Crafting>5</Crafting>
      </skillRequirements>
    </recipeMaker>
    <graphicData>
      <texPath>FIP-WestTek/Armor/Robe/WestTek_UnityRobe</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <generateCommonality>0.1</generateCommonality>
    <statBases>
      <WorkToMake>10000</WorkToMake>
      <MaxHitPoints>150</MaxHitPoints>
      <Mass>2</Mass>
      <Flammability>1</Flammability>
      <ArmorRating_Sharp>0.15</ArmorRating_Sharp>
      <ArmorRating_Blunt>0.25</ArmorRating_Blunt>
      <ArmorRating_Heat>0.1</ArmorRating_Heat>
      <Insulation_Cold>30</Insulation_Cold>
      <EquipDelay>2</EquipDelay>
    </statBases>
    <equippedStatOffsets>
      <ResearchSpeedFactor>0.15</ResearchSpeedFactor>
    </equippedStatOffsets>
    <costList>
      <ComponentIndustrial>1</ComponentIndustrial>
      <Cloth>110</Cloth>
    </costList>
    <apparel>
      <bodyPartGroups>
        <li>Torso</li>
        <li>Shoulders</li>
        <li>Arms</li>
        <li>Waist</li>
        <li>Legs</li>
        <li>Neck</li>
      </bodyPartGroups>
      <wornGraphicPath>FIP-WestTek/Armor/Robe/WestTek_UnityRobe</wornGraphicPath>
      <layers>
        <li>Middle</li>
        <li>Shell</li>
      </layers>
      <tags>
        <li>WestTekUnity</li>
      </tags>
      <defaultOutfitTags>
        <li>Worker</li>
      </defaultOutfitTags>
    </apparel>
    <thingSetMakerTags>
      <li>RewardSpecial</li>
    </thingSetMakerTags>
    <thingCategories>
      <li>ApparelMisc</li>
    </thingCategories>
  </ThingDef>

  <ThingDef ParentName="ApparelMakeableBase">
    <defName>WestTek_Apparel_UnityHood</defName>
    <label>unity hood</label>
    <description>A hood worn by followers of the Unity.</description>
    <techLevel>Spacer</techLevel>
    <recipeMaker>
      <skillRequirements>
        <Crafting>5</Crafting>
      </skillRequirements>
    </recipeMaker>
    <graphicData>
      <texPath>FIP-WestTek/Armor/Robe/WestTek_UnityHood</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <generateCommonality>0.1</generateCommonality>
    <statBases>
      <WorkToMake>5000</WorkToMake>
      <MaxHitPoints>75</MaxHitPoints>
      <Mass>1</Mass>
      <Flammability>1</Flammability>
      <ArmorRating_Sharp>0.1</ArmorRating_Sharp>
      <ArmorRating_Blunt>0.15</ArmorRating_Blunt>
      <ArmorRating_Heat>0.1</ArmorRating_Heat>
      <Insulation_Cold>30</Insulation_Cold>
      <EquipDelay>1</EquipDelay>
    </statBases>
    <equippedStatOffsets>
      <PsychicSensitivity>-0.08</PsychicSensitivity>
    </equippedStatOffsets>
    <costList>
      <Cloth>35</Cloth>
    </costList>
    <apparel>
      <bodyPartGroups>
        <li>FullHead</li>
      </bodyPartGroups>
      <wornGraphicPath>FIP-WestTek/Armor/Robe/WestTek_UnityHood</wornGraphicPath>
      <layers>
        <li>Overhead</li>
      </layers>
      <tags>
        <li>WestTekUnity</li>
      </tags>
      <defaultOutfitTags>
        <li>Worker</li>
      </defaultOutfitTags>
    </apparel>
    <thingSetMakerTags>
      <li>RewardSpecial</li>
    </thingSetMakerTags>
    <thingCategories>
      <li>Headgear</li>
    </thingCategories>
  </ThingDef>
</Defs>