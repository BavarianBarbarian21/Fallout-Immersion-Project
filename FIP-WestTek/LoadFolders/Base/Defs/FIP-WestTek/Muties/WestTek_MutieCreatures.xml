<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <!--Centaur-->
  <ThingDef ParentName="AnimalThingBase">
    <defName>WestTek_Centaur</defName>
    <label>centaur</label>
    <description>Centaurs are hostile FEV predators built from failed human stock and finished into hunting beasts. West Tek's field strain keeps the low-slung, many-limbed silhouette but now uses the tougher Wasteland Compendium combat profile instead of the earlier lightweight animal tuning.</description>
    <graphicData>
      <texPath>FIP-WestTek/Muties/Centaur/WestTek_Centaur</texPath>
      <graphicClass>Graphic_Multi</graphicClass>
    </graphicData>
    <statBases>
      <MoveSpeed>2.8</MoveSpeed>
      <MarketValue>600</MarketValue>
      <ComfyTemperatureMin>-55</ComfyTemperatureMin>
      <ComfyTemperatureMax>55</ComfyTemperatureMax>
      <Wildness>0.8</Wildness>
      <ArmorRating_Blunt>1.14</ArmorRating_Blunt>
      <ArmorRating_Sharp>1.4</ArmorRating_Sharp>
      <ArmorRating_Heat>0</ArmorRating_Heat>
      <Flammability>1</Flammability>
      <ToxicEnvironmentResistance>1</ToxicEnvironmentResistance>
      <ToxicResistance>1</ToxicResistance>
    </statBases>
    <uiIconScale>1.2</uiIconScale>
    <race>
      <animalType>None</animalType>
      <body>WestTek_Centaur</body>
      <predator>true</predator>
      <maxPreyBodySize>1.2</maxPreyBodySize>
      <petness>0.35</petness>
      <baseBodySize>2.0</baseBodySize>
      <baseHungerRate>0.32</baseHungerRate>
      <baseHealthScale>2.5</baseHealthScale>
      <leatherDef>WestTek_Leather_FEVMutant</leatherDef>
      <foodType>OmnivoreAnimal, Corpse</foodType>
      <gestationPeriodDays>9</gestationPeriodDays>
      <nameOnTameChance>1</nameOnTameChance>
      <trainability>Intermediate</trainability>
      <specialTrainables>
        <li>AttackTarget</li>
      </specialTrainables>
      <manhunterOnTameFailChance>0.4</manhunterOnTameFailChance>
      <manhunterOnDamageChance>0.25</manhunterOnDamageChance>
      <lifeExpectancy>14</lifeExpectancy>
      <lifeStageAges>
        <li>
          <def>AnimalAdult</def>
          <minAge>0</minAge>
          <soundWounded>Pawn_Warg_Wounded</soundWounded>
          <soundDeath>Pawn_Warg_Death</soundDeath>
          <soundCall>Pawn_Warg_Call</soundCall>
          <soundAngry>Pawn_Warg_Angry</soundAngry>
        </li>
      </lifeStageAges>
        <soundMeleeHitPawn>WestTek_AbominationHit</soundMeleeHitPawn>
      <soundMeleeHitBuilding>Pawn_Melee_BigBash_HitBuilding</soundMeleeHitBuilding>
      <soundMeleeMiss>Pawn_Melee_BigBash_Miss</soundMeleeMiss>
    </race>
    <tools>
      <li>
        <label>tentacle</label>
        <capacities>
          <li>Scratch</li>
        </capacities>
        <power>12</power>
        <cooldownTime>2.0</cooldownTime>
        <linkedBodyPartsGroup>Arms</linkedBodyPartsGroup>
      </li>
      <li>
        <label>teeth</label>
        <capacities>
          <li>Bite</li>
        </capacities>
        <power>15</power>
        <cooldownTime>1.7</cooldownTime>
        <linkedBodyPartsGroup>Teeth</linkedBodyPartsGroup>
        <chanceFactor>0.7</chanceFactor>
      </li>
    </tools>
    <tradeTags>
      <li>AnimalUncommon</li>
    </tradeTags>
  </ThingDef>

  <PawnKindDef ParentName="AnimalKindBase">
    <defName>WestTek_Centaur</defName>
    <label>centaur</label>
    <race>WestTek_Centaur</race>
    <combatPower>140</combatPower>
    <wildGroupSize>1~3</wildGroupSize>
    <ecoSystemWeight>0.12</ecoSystemWeight>
    <lifeStages>
      <li>
        <bodyGraphicData>
          <texPath>FIP-WestTek/Muties/Centaur/WestTek_Centaur</texPath>
          <graphicClass>Graphic_Multi</graphicClass>
          <drawSize>1.9</drawSize>
          <shadowData>
            <volume>(0.5, 0.7, 0.5)</volume>
            <offset>(0,0,-0.18)</offset>
          </shadowData>
        </bodyGraphicData>
      </li>
    </lifeStages>
  </PawnKindDef>

 <SoundDef>
    <defName>WestTek_AbominationHit</defName>
    <context>MapOnly</context>
    <eventNames />
    <maxSimultaneous>2</maxSimultaneous>
    <subSounds>
      <li>
        <grains>
          <li Class="AudioGrain_Clip">
            <clipPath>WestTek_Abomination</clipPath>
          </li>
        </grains>
        <pitchRange>
          <min>0.9152174</min>
          <max>1.042391</max>
        </pitchRange>
      </li>
    </subSounds>
  </SoundDef>
  
  <!--Floater-->
  <ThingDef ParentName="AnimalThingBase">
    <defName>WestTek_Floater</defName>
    <label>floater</label>
    <description>Floaters are fast, flammable FEV horrors that drift on their own gas bladders and crowd prey in packs.</description>
    <graphicData>
      <texPath>FIP-WestTek/Muties/Floater/WestTek_Floater</texPath>
      <graphicClass>Graphic_Multi</graphicClass>
    </graphicData>
    <statBases>
      <MoveSpeed>3.8</MoveSpeed>
      <MarketValue>350</MarketValue>
      <ComfyTemperatureMin>-55</ComfyTemperatureMin>
      <ComfyTemperatureMax>55</ComfyTemperatureMax>
      <Wildness>0.8</Wildness>
      <ArmorRating_Blunt>0.14</ArmorRating_Blunt>
      <ArmorRating_Sharp>0.4</ArmorRating_Sharp>
      <ArmorRating_Heat>0</ArmorRating_Heat>
      <Flammability>2</Flammability>
      <ToxicEnvironmentResistance>1</ToxicEnvironmentResistance>
      <ToxicResistance>1</ToxicResistance>
    </statBases>
    <uiIconScale>1.1</uiIconScale>
    <race>
      <animalType>None</animalType>
      <body>WestTek_FloaterBody</body>
      <predator>true</predator>
      <maxPreyBodySize>0.8</maxPreyBodySize>
      <petness>0</petness>
      <baseBodySize>1.0</baseBodySize>
      <baseHungerRate>0.22</baseHungerRate>
      <baseHealthScale>2.5</baseHealthScale>
      <leatherDef>WestTek_Leather_FEVMutant</leatherDef>
      <foodType>OmnivoreAnimal, Corpse</foodType>
      <nameOnTameChance>1</nameOnTameChance>
      <trainability>None</trainability>
      <lifeExpectancy>400</lifeExpectancy>
      <lifeStageAges>
        <li>
          <def>AnimalAdult</def>
          <minAge>0.1</minAge>
        </li>
      </lifeStageAges>
      <soundCallIntervalRange>
        <min>1000</min>
        <max>2000</max>
      </soundCallIntervalRange>
      <soundMeleeHitPawn>WestTek_AbominationHit</soundMeleeHitPawn>
      <soundMeleeHitBuilding>Pawn_Melee_BigBash_HitBuilding</soundMeleeHitBuilding>
      <soundMeleeMiss>Pawn_Melee_BigBash_Miss</soundMeleeMiss>
    </race>
    <tools>
      <li>
        <label>fore mouth</label>
        <capacities>
          <li>Cut</li>
        </capacities>
        <power>5</power>
        <cooldownTime>1.7</cooldownTime>
        <linkedBodyPartsGroup>Mouth</linkedBodyPartsGroup>
      </li>
      <li>
        <label>ovipositor</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>15</power>
        <cooldownTime>1.7</cooldownTime>
        <linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
      </li>
      <li>
        <label>head</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>10</power>
        <cooldownTime>1.9</cooldownTime>
        <linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
        <ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
        <chanceFactor>0.2</chanceFactor>
      </li>
    </tools>
  </ThingDef>

  <PawnKindDef ParentName="AnimalKindBase">
    <defName>WestTek_Floater</defName>
