  <!--Behemoth-->
  <ThingDef ParentName="BasePawn">
    <defName>WestTek_SuperMutantBehemoth</defName>
    <label>super mutant behemoth</label>
    <description>An ancient FEV giant restored to West Tek's mutant catalogue.</description>
    <statBases>
      <PsychicSensitivity>50</PsychicSensitivity>
      <ComfyTemperatureMin>-10</ComfyTemperatureMin>
      <ComfyTemperatureMax>55</ComfyTemperatureMax>
      <Wildness>0.8</Wildness>
      <MoveSpeed>2.4</MoveSpeed>
      <ArmorRating_Blunt>0.4</ArmorRating_Blunt>
      <ArmorRating_Sharp>0.6</ArmorRating_Sharp>
    </statBases>
    <tools>
      <li>
        <label>left fist</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>29</power>
        <cooldownTime>1.7</cooldownTime>
        <linkedBodyPartsGroup>LeftHand</linkedBodyPartsGroup>
      </li>
      <li>
        <label>right fist</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>29</power>
        <cooldownTime>1.7</cooldownTime>
        <linkedBodyPartsGroup>RightHand</linkedBodyPartsGroup>
      </li>
      <li>
        <label>head</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>25</power>
        <cooldownTime>1.9</cooldownTime>
        <linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
        <ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
        <chanceFactor>0.2</chanceFactor>
      </li>
    </tools>
    <race>
      <needsRest>true</needsRest>
      <hasGenders>true</hasGenders>
      <foodType>OmnivoreHuman</foodType>
      <lifeExpectancy>400</lifeExpectancy>
      <trainability>Advanced</trainability>
      <leatherDef>WestTek_Leather_FEVMutant</leatherDef>
      <intelligence>ToolUser</intelligence>
      <thinkTreeMain>Humanlike</thinkTreeMain>
      <body>Human</body>
      <baseBodySize>5.2</baseBodySize>
      <baseHealthScale>12</baseHealthScale>
      <lifeStageAges>
        <li>
          <def>AnimalAdult</def>
          <minAge>0.1</minAge>
          <soundDeath>WestTek_SuperMutantDeath</soundDeath>
          <soundCall>WestTek_SuperMutantFollow</soundCall>
        </li>
      </lifeStageAges>
      <soundCallIntervalRange>
        <min>1000</min>
        <max>2000</max>
      </soundCallIntervalRange>
      <soundMeleeHitPawn>Pawn_Melee_BigBash_HitPawn</soundMeleeHitPawn>
      <soundMeleeHitBuilding>Pawn_Melee_BigBash_HitBuilding</soundMeleeHitBuilding>
      <soundMeleeMiss>Pawn_Melee_BigBash_Miss</soundMeleeMiss>
    </race>
  </ThingDef>

