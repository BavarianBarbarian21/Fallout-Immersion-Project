<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <!--Tier 1 Resource-->
  <ThingDef ParentName="ResourceBase">
    <defName>WestTek_FEVProbe</defName>
    <label>FEV probe</label>
    <description>A crude pre-refinement sample of Forced Evolutionary Virus growth medium. It is unstable and difficult to handle safely.

A colonist can analyze this probe to unlock FEV-1 research.</description>
    <graphicData>
      <texPath>FIP-WestTek/Misc/Placeholder</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <stackLimit>75</stackLimit>
    <statBases>
      <MarketValue>18</MarketValue>
      <Mass>0.03</Mass>
    </statBases>
    <comps>
      <li Class="CompProperties_CompAnalyzableUnlockResearch">
        <analysisID>410100001</analysisID>
        <requiresMechanitor>false</requiresMechanitor>
        <analysisDurationHours>0.6</analysisDurationHours>
        <destroyedOnAnalyzed>false</destroyedOnAnalyzed>
        <completedLetterLabel>FEV probe analyzed: {RESEARCH} unlocked</completedLetterLabel>
        <completedLetter>By analyzing the FEV probe, {PAWN_labelShort} has recovered the baseline insight needed for the research project(s) {RESEARCH}.

Your researchers can now begin formal work on first-generation FEV handling.</completedLetter>
        <completedLetterDef>PositiveEvent</completedLetterDef>
        <activateTexPath>UI/Icons/Study</activateTexPath>
        <activateLabelString>Analyze...</activateLabelString>
        <activateDescString>Analyze the FEV probe.</activateDescString>
        <jobString>Analyze FEV probe</jobString>
        <guiLabelString>Choose who should analyze this</guiLabelString>
        <inspectString>Can be analyzed by a colonist.</inspectString>
        <targetingParameters>
          <canTargetBuildings>false</canTargetBuildings>
          <canTargetAnimals>false</canTargetAnimals>
          <canTargetMechs>false</canTargetMechs>
          <onlyTargetControlledPawns>true</onlyTargetControlledPawns>
        </targetingParameters>
      </li>
    </comps>
  </ThingDef>

  <!--Tier 2 Resource-->
  <ThingDef ParentName="ResourceBase">
    <defName>WestTek_FEVSample</defName>
    <label>FEV sample</label>
    <description>A concentrated viral sample suitable for controlled testing. More stable than raw probe material.

A colonist can analyze this sample to unlock FEV-2 research.</description>
    <graphicData>
      <texPath>FIP-WestTek/Misc/Placeholder</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <stackLimit>25</stackLimit>
    <statBases>
      <MarketValue>120</MarketValue>
      <Mass>0.08</Mass>
    </statBases>
    <costList>
      <WestTek_FEVProbe>10</WestTek_FEVProbe>
    </costList>
    <tickerType>Normal</tickerType>
    <comps>
      <li Class="CompProperties_Rottable">
            <daysToRotStart>1</daysToRotStart>
            <rotDestroys>true</rotDestroys>
      </li>
      <li Class="CompProperties_CompAnalyzableUnlockResearch">
        <analysisID>410100002</analysisID>
        <requiresMechanitor>false</requiresMechanitor>
        <analysisDurationHours>0.8</analysisDurationHours>
        <destroyedOnAnalyzed>false</destroyedOnAnalyzed>
        <completedLetterLabel>FEV sample analyzed: {RESEARCH} unlocked</completedLetterLabel>
        <completedLetter>By analyzing the FEV sample, {PAWN_labelShort} has recovered the insight needed for the research project(s) {RESEARCH}.

Your researchers can now begin work on second-generation FEV refinement.</completedLetter>
        <completedLetterDef>PositiveEvent</completedLetterDef>
        <activateTexPath>UI/Icons/Study</activateTexPath>
        <activateLabelString>Analyze...</activateLabelString>
        <activateDescString>Analyze the FEV sample.</activateDescString>
        <jobString>Analyze FEV sample</jobString>
        <guiLabelString>Choose who should analyze this</guiLabelString>
        <inspectString>Can be analyzed by a colonist.</inspectString>
        <targetingParameters>
          <canTargetBuildings>false</canTargetBuildings>
          <canTargetAnimals>false</canTargetAnimals>
          <canTargetMechs>false</canTargetMechs>
          <onlyTargetControlledPawns>true</onlyTargetControlledPawns>
        </targetingParameters>
      </li>
    </comps>
    <recipeMaker>
      <researchPrerequisite>WestTek_FEV1</researchPrerequisite>
      <recipeUsers>
        <li>DrugLab</li>
      </recipeUsers>
      <workSpeedStat>DrugSynthesisSpeed</workSpeedStat>
      <workSkill>Intellectual</workSkill>
      <displayPriority>2200</displayPriority>
    </recipeMaker>
  </ThingDef>

  <!--Tier 3 Resource-->
  <ThingDef ParentName="ResourceBase">
    <defName>WestTek_FEVCulture</defName>
    <label>FEV culture</label>
    <description>A stabilized culture kept alive for higher-order Forced Evolutionary Virus work. Guaranteed transformation results when used in procedures.

A colonist can analyze this culture to unlock FEV-3 research.</description>
    <graphicData>
      <texPath>FIP-WestTek/Misc/Placeholder</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <stackLimit>10</stackLimit>
    <statBases>
      <MarketValue>260</MarketValue>
      <Mass>0.1</Mass>
    </statBases>
    <costList>
      <Uranium>2500</Uranium>
      <WestTek_FEVSample>1</WestTek_FEVSample>
    </costList>
    <tickerType>Normal</tickerType>
    <comps>
      <li Class="CompProperties_Rottable">
            <daysToRotStart>1</daysToRotStart>
            <rotDestroys>true</rotDestroys>
      </li>
      <li Class="CompProperties_CompAnalyzableUnlockResearch">
        <analysisID>410100003</analysisID>
        <requiresMechanitor>false</requiresMechanitor>
        <analysisDurationHours>1.2</analysisDurationHours>
        <destroyedOnAnalyzed>false</destroyedOnAnalyzed>
        <completedLetterLabel>FEV culture analyzed: {RESEARCH} unlocked</completedLetterLabel>
        <completedLetter>By analyzing the FEV culture, {PAWN_labelShort} has recovered the insight needed for the research project(s) {RESEARCH}.

Your researchers can now begin work on high-order FEV stabilization.</completedLetter>
        <completedLetterDef>PositiveEvent</completedLetterDef>
        <activateTexPath>UI/Icons/Study</activateTexPath>
        <activateLabelString>Analyze...</activateLabelString>
        <activateDescString>Analyze the FEV culture.</activateDescString>
        <jobString>Analyze FEV culture</jobString>
        <guiLabelString>Choose who should analyze this</guiLabelString>
        <inspectString>Can be analyzed by a colonist.</inspectString>
        <targetingParameters>
          <canTargetBuildings>false</canTargetBuildings>
          <canTargetAnimals>false</canTargetAnimals>
          <canTargetMechs>false</canTargetMechs>
          <onlyTargetControlledPawns>true</onlyTargetControlledPawns>
        </targetingParameters>
      </li>
    </comps>
    <recipeMaker>
      <researchPrerequisite>WestTek_FEV2</researchPrerequisite>
      <recipeUsers>
        <li>DrugLab</li>
      </recipeUsers>
      <workSpeedStat>DrugSynthesisSpeed</workSpeedStat>
      <workSkill>Intellectual</workSkill>
      <workAmount>12000</workAmount>
      <displayPriority>2210</displayPriority>
    </recipeMaker>
  </ThingDef>

