  <!--Tier 2 Item-->
  <ThingDef ParentName="ResourceBase">
    <defName>WestTek_RefinedFEVDosage</defName>
    <label>refined FEV dosage</label>
    <description>A cleaner Forced Evolutionary Virus dose suitable for more controlled procedures. Lethality is reduced compared to wild samples.</description>
    <graphicData>
