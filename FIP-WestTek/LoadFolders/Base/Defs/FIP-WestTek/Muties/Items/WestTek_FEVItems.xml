  <!--Tier 3 Item-->
  <ThingDef ParentName="ResourceBase">
    <defName>WestTek_IsolatedFEVDosage</defName>
    <label>isolated FEV dosage</label>
    <description>A highly stabilized Forced Evolutionary Virus dose reserved for colonist-directed procedures. Guaranteed transformation results when used in procedures.</description>
    <graphicData>
      <texPath>FIP-WestTek/Misc/Placeholder</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <stackLimit>25</stackLimit>
    <statBases>
      <MarketValue>420</MarketValue>
      <Mass>0.08</Mass>
    </statBases>
    <costList>
      <Uranium>300</Uranium>
    </costList>
    <recipeMaker>
      <researchPrerequisite>WestTek_FEV3</researchPrerequisite>
      <recipeUsers>
        <li>DrugLab</li>
      </recipeUsers>
      <workSpeedStat>DrugSynthesisSpeed</workSpeedStat>
      <workSkill>Intellectual</workSkill>
      <displayPriority>2240</displayPriority>
    </recipeMaker>
  </ThingDef>

  <ThingDef ParentName="ResourceBase">
    <defName>WestTek_NightkinMutagen</defName>
    <label>nightkin mutagen</label>
    <description>A specialized FEV mutagenic package that stabilizes a Nightkin stealth field in an existing WestTek super mutant. Only first- and second-generation WestTek super mutants can survive the implantation.</description>
    <graphicData>
      <texPath>FIP-WestTek/Misc/WestTek_NightkinXenogerm</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>0.8</drawSize>
    </graphicData>
    <thingCategories>
      <li>ItemsMisc</li>
    </thingCategories>
    <tradeability>Sellable</tradeability>
    <tradeTags>
      <li>GeneticItem</li>
      <li>Serum</li>
    </tradeTags>
    <stackLimit>10</stackLimit>
    <statBases>
      <MarketValue>520</MarketValue>
      <Mass>0.08</Mass>
      <MaxHitPoints>60</MaxHitPoints>
    </statBases>
    <ingestible>
      <preferability>NeverForNutrition</preferability>
      <maxNumToIngestAtOnce>1</maxNumToIngestAtOnce>
      <defaultNumToIngestAtOnce>1</defaultNumToIngestAtOnce>
      <foodType>Processed</foodType>
      <baseIngestTicks>100</baseIngestTicks>
      <humanlikeOnly>true</humanlikeOnly>
      <chairSearchRadius>0</chairSearchRadius>
      <ingestSound>Ingest_Pill</ingestSound>
      <ingestHoldUsesTable>false</ingestHoldUsesTable>
      <ingestCommandString>Consume {0}</ingestCommandString>
      <ingestReportString>Consuming {0}.</ingestReportString>
      <outcomeDoers>
        <li Class="IngestionOutcomeDoer_UseThing" />
      </outcomeDoers>
    </ingestible>
    <comps>
      <li Class="FIP.WestTek.CompProperties_UseEffectNightkinMutagen" />
      <li Class="CompProperties_UseEffectPlaySound">
        <soundOnUsed>MechSerumUsed</soundOnUsed>
      </li>
    </comps>
    <costList>
      <WestTek_FEVSample>1</WestTek_FEVSample>
      <Uranium>250</Uranium>
    </costList>
    <recipeMaker>
      <workAmount>1600</workAmount>
      <researchPrerequisite>WestTek_FEV2</researchPrerequisite>
      <recipeUsers>
        <li>DrugLab</li>
      </recipeUsers>
      <workSpeedStat>DrugSynthesisSpeed</workSpeedStat>
      <workSkill>Intellectual</workSkill>
      <displayPriority>2245</displayPriority>
    </recipeMaker>
  </ThingDef>

  <ThingDef ParentName="ResourceBase">
    <defName>WestTek_BehemothMutagen</defName>
    <label>behemoth mutagen</label>
    <description>A brutal FEV-3 mutagenic package that collapses a super mutant subject into a gigantic, tame behemoth war-beast. Only first- and second-generation super mutants survive the process.</description>
    <graphicData>
      <texPath>FIP-WestTek/Misc/WestTek_NightkinXenogerm</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>0.8</drawSize>
    </graphicData>
    <thingCategories>
      <li>ItemsMisc</li>
    </thingCategories>
    <tradeability>Sellable</tradeability>
    <stackLimit>5</stackLimit>
    <statBases>
      <MarketValue>1200</MarketValue>
      <Mass>0.2</Mass>
      <Flammability>0.4</Flammability>
    </statBases>
    <ingestible>
      <preferability>NeverForNutrition</preferability>
      <maxNumToIngestAtOnce>1</maxNumToIngestAtOnce>
      <defaultNumToIngestAtOnce>1</defaultNumToIngestAtOnce>
      <foodType>Processed</foodType>
      <ingestCommandString>Inject mutagen</ingestCommandString>
      <ingestReportString>{0} injects a behemoth mutagen.</ingestReportString>
      <outcomeDoers>
        <li Class="IngestionOutcomeDoer_GiveHediff">
          <severity>0.01</severity>
          <hediffDef>Hangover</hediffDef>
        </li>
      </outcomeDoers>
    </ingestible>
    <costList>
      <WestTek_FEVCulture>1</WestTek_FEVCulture>
    </costList>
    <recipeMaker>
      <workAmount>2600</workAmount>
      <researchPrerequisite>WestTek_FEV3</researchPrerequisite>
      <recipeUsers>
        <li>DrugLab</li>
      </recipeUsers>
      <workSpeedStat>DrugSynthesisSpeed</workSpeedStat>
      <workSkill>Intellectual</workSkill>
      <displayPriority>2250</displayPriority>
    </recipeMaker>
    <comps>
      <li Class="FIP.WestTek.CompProperties_UseEffectBehemothMutagen" />
    </comps>
  </ThingDef>

</Defs>
