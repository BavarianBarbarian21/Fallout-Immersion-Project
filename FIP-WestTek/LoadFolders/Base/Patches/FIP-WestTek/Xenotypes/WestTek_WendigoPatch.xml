<?xml version='1.0' encoding='UTF-8'?>
<Patch>
  <!--+6-->
  <!-- Patch Sanguophages xenotype label to Wendigo -->
  <Operation Class="PatchOperationSequence">
    <success>Always</success>
    <operations>
      <li Class="PatchOperationRemove">
        <xpath>Defs/XenotypeDef[defName="Sanguophage"]/genes/li[text()="MoveSpeed_Quick"]</xpath>
      </li>
      <li Class="PatchOperationRemove">
        <xpath>Defs/XenotypeDef[defName="Sanguophage"]/genes/li[text()="UVSensitivity_Mild"]</xpath>
      </li>
      <li Class="PatchOperationRemove">
        <xpath>Defs/XenotypeDef[defName="Sanguophage"]/genes/li[text()="Aggression_Aggressive"]</xpath>
      </li>
    </operations>
  </Operation>
  <Operation Class="PatchOperationAdd">
    <xpath>Defs/XenotypeDef[defName="Sanguophage"]/genes</xpath>
    <value>
      <li>MoveSpeed_VeryQuick</li>
      <li>Mood_Pessimist</li>
      <li>UVSensitivity_Intense</li>
      <li>Aggression_HyperAggressive</li>
      <li>KillThirst</li>
      <li>WestTek_Gene_Wendigo</li>
    </value>
  </Operation>
</Patch>