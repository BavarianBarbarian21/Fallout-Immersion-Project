<?xml version="1.0" encoding="utf-8"?>
<Defs>
    <!-- Old world religions -->
    <MemeDef Name="Greenway_Religion_OldWorldChurch_Base" ParentName="Greenway_Religion_Base"
        Abstract="true">
        <worshipRoomLabel>church</worshipRoomLabel>
        <groupDef>Greenway_OldWorldChurch</groupDef>
        <iconPath>Greenway/Memes/OldWorldChurch</iconPath>
        <thingStyleCategories>
            <li>
                <category>Christian</category>
                <priority>4</priority>
            </li>
        </thingStyleCategories>
        <symbolPackOverride>true</symbolPackOverride>
        <symbolPacks>
            <li>
                <ideoName>Follower</ideoName>
                <adjective>Follower</adjective>
                <member>Follower</member>
                <prefix>true</prefix>
            </li>
        </symbolPacks>
        <generalRules>
            <rulesStrings>
                <li>memeMoralist ->missionary</li>
            </rulesStrings>
        </generalRules>
    </MemeDef>

    <!--Follower-->
    <MemeDef ParentName="Greenway_Religion_OldWorldChurch_Base">
        <defName>Greenway_Religion_FollowerOfTheApocalypse</defName>
        <label>Follower of the Apocalypse</label>
        <description>A secular movement born from the Old World's collapse; its followers have sworn to help those in need.</description>
        <deityNameMakerOverride>HHTools_Greenway_Religion_NameMaker_FollowerOfTheApocalypse</deityNameMakerOverride>
        <deityTypeMakerOverride>HHTools_Greenway_Religion_TypeMaker_FollowerOfTheApocalypse</deityTypeMakerOverride>
    </MemeDef>

    <!--Mormon-->
    <MemeDef ParentName="Greenway_Religion_OldWorldChurch_Base">
        <defName>Greenway_Religion_CanaaniteChurch</defName>
        <label>Canaanite Church</label>
        <description>A restorationist movement that mixes frontier theocracy and strict social order, inspired by old doctrinal texts.</description>
        <deityNameMakerOverride>HHTools_Greenway_Religion_NameMaker_CanaaniteChurch</deityNameMakerOverride>
        <deityTypeMakerOverride>HHTools_Greenway_Religion_TypeMaker_CanaaniteChurch</deityTypeMakerOverride>
    </MemeDef>

    <!--Protestant-->
    <MemeDef ParentName="Greenway_Religion_OldWorldChurch_Base">
        <defName>Greenway_Religion_AbbeyOfTheRoad</defName>
        <label>Abbey of the Road</label>
        <description>A protestant-style order built around scripture and the travelling pulpit; it prizes scripture, preaching and humble worship.</description>
        <deityNameMakerOverride>HHTools_Greenway_Religion_NameMaker_AbbeyOfTheRoad</deityNameMakerOverride>
        <deityTypeMakerOverride>HHTools_Greenway_Religion_TypeMaker_AbbeyOfTheRoad</deityTypeMakerOverride>
    </MemeDef>
    <!--Catholic-->
    <MemeDef ParentName="Greenway_Religion_OldWorldChurch_Base">
        <defName>Greenway_Religion_OrderOfOurLadyOfTheWaters</defName>
        <label>Waters of Life</label>
        <description>A Catholic-style order deeply devoted to Mary and the saints, keeping older sacramental practices alive.</description>
        <deityNameMakerOverride>HHTools_Greenway_Religion_NameMaker_OrderOfOurLadyOfTheWaters</deityNameMakerOverride>
        <deityTypeMakerOverride>HHTools_Greenway_Religion_TypeMaker_OrderOfOurLadyOfTheWaters</deityTypeMakerOverride>
    </MemeDef>
</Defs>