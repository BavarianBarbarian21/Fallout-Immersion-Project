<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="PatchOperationSequence">
    <success>Always</success>
    <operations>
      <li Class="PatchOperationReplace" MayRequire="VanillaExpanded.VBooksE">
        <xpath>/Defs/RulePackDef[defName="ArtDescription_Newspaper"]/rulePack/rulesStrings</xpath>
        <value>
          <rulesStrings>
            <li>desc->Publick Occurrences issue [Digit][Digit][Digit][Digit]</li>
            <li>digit->0</li>
            <li>digit->1</li>
            <li>digit->2</li>
            <li>digit->3</li>
            <li>digit->4</li>
            <li>digit->5</li>
            <li>digit->6</li>
            <li>digit->7</li>
            <li>digit->8</li>
            <li>digit->9</li>
            <li>title->[desc]</li>
          </rulesStrings>
        </value>
      </li>
      <li Class="PatchOperationReplace" MayRequire="VanillaExpanded.VBooksE">
        <xpath>/Defs/RulePackDef[defName="ArtDescription_NewspaperDesc"]/rulePack/rulesStrings</xpath>
        <value>
          <rulesStrings>
            <li>desc->This issue covers the latest caravan traffic, fights, and rumors from the last few days.</li>
          </rulesStrings>
        </value>
      </li>
    </operations>
  </Operation>
</Patch>