  <FCP_Quest_SettlementRaidDefense.root.nodes.14.node.nodes.5.elseNode.node.nodes.1.label>Najeźdźcy są tutaj!</FCP_Quest_SettlementRaidDefense.root.nodes.14.node.nodes.5.elseNode.node.nodes.1.label>
  <FCP_Quest_SettlementRaidDefense.root.nodes.14.node.nodes.5.elseNode.node.nodes.1.text>Najeźdźcy przybyli!</FCP_Quest_SettlementRaidDefense.root.nodes.14.node.nodes.5.elseNode.node.nodes.1.text>
  <FCP_Quest_SettlementRaidDefense.root.nodes.14.node.nodes.5.node.nodes.1.label>Najeźdźcy już tu są!</FCP_Quest_SettlementRaidDefense.root.nodes.14.node.nodes.5.node.nodes.1.label>
  <FCP_Quest_SettlementRaidDefense.root.nodes.14.node.nodes.5.node.nodes.1.text>Najeźdźcy zaatakowali już osadników, których miałeś chronić!</FCP_Quest_SettlementRaidDefense.root.nodes.14.node.nodes.5.node.nodes.1.text>
  <FCP_Quest_SettlementRaidDefense.root.nodes.14.node.nodes.6.node.nodes.0.node.nodes.0.customLetterLabel>Osadnicy przeżyli</FCP_Quest_SettlementRaidDefense.root.nodes.14.node.nodes.6.node.nodes.0.node.nodes.0.customLetterLabel>
  <FCP_Quest_SettlementRaidDefense.root.nodes.14.node.nodes.6.node.nodes.0.node.nodes.0.customLetterText>Osadnicy, których miałeś chronić, przeżyli atak, a ty ukończyłeś swoją misję.</FCP_Quest_SettlementRaidDefense.root.nodes.14.node.nodes.6.node.nodes.0.node.nodes.0.customLetterText>
