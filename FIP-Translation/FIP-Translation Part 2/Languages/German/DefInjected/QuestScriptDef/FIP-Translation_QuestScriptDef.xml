  <FCP_Quest_SettlementRaidDefense.root.nodes.14.node.nodes.5.elseNode.node.nodes.1.text>Die Raider sind angekommen!</FCP_Quest_SettlementRaidDefense.root.nodes.14.node.nodes.5.elseNode.node.nodes.1.text>
  <FCP_Quest_SettlementRaidDefense.root.nodes.14.node.nodes.5.node.nodes.1.label>Die Raider sind schon da!</FCP_Quest_SettlementRaidDefense.root.nodes.14.node.nodes.5.node.nodes.1.label>
  <FCP_Quest_SettlementRaidDefense.root.nodes.14.node.nodes.5.node.nodes.1.text>Die Räuber haben die Siedler, die Sie beschützen sollten, bereits angegriffen!</FCP_Quest_SettlementRaidDefense.root.nodes.14.node.nodes.5.node.nodes.1.text>
  <FCP_Quest_SettlementRaidDefense.root.nodes.14.node.nodes.6.node.nodes.0.node.nodes.0.customLetterLabel>Die Siedler überlebten</FCP_Quest_SettlementRaidDefense.root.nodes.14.node.nodes.6.node.nodes.0.node.nodes.0.customLetterLabel>
  <FCP_Quest_SettlementRaidDefense.root.nodes.14.node.nodes.6.node.nodes.0.node.nodes.0.customLetterText>Die Siedler, die Sie beschützen sollten, haben den Angriff überlebt, Sie haben Ihre Mission erfüllt.</FCP_Quest_SettlementRaidDefense.root.nodes.14.node.nodes.6.node.nodes.0.node.nodes.0.customLetterText>
