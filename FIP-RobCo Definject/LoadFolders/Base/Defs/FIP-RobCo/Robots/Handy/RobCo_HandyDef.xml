			<MarketValue>1800</MarketValue>
			<MoveSpeed>4.6</MoveSpeed>
			<ArmorRating_Blunt>0.20</ArmorRating_Blunt>
			<ArmorRating_Sharp>0.40</ArmorRating_Sharp>
			<MechEnergyLossPerHP>0.66</MechEnergyLossPerHP>
			<BandwidthCost>2</BandwidthCost>
			<ControlTakingTime>18</ControlTakingTime>
		</statBases>
		<race>
			<body>RobCo_Handy</body>
			<intelligence>ToolUser</intelligence>
			<thinkTreeMain>Mechanoid</thinkTreeMain>
			<baseBodySize>1.0</baseBodySize>
			<baseHealthScale>1.5</baseHealthScale>
			<mechWeightClass>Light</mechWeightClass>
			<lifeStageAges>
				<li>
					<def>MechanoidFullyFormed</def>
					<minAge>0</minAge>
					<soundWounded>RobCo_Handy_Wounded</soundWounded>
					<soundDeath>RobCo_Handy_Death</soundDeath>
					<soundCall>RobCo_Handy_Call</soundCall>
					<soundAngry>RobCo_Handy_Angry</soundAngry>
				</li>
