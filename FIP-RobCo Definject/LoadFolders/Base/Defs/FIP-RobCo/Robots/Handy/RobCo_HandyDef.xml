	<!-- Mister Handy -->
	<ThingDef ParentName="RobCo_HandyBase">
		<defName>RobCo_MisterHandy</defName>
		<label>Mister Handy</label>
		<description>A hovering domestic servant robot produced by General Atomics International in partnership with RobCo Industries. It is equipped with three articulated arms that accept tool attachments including a buzzsaw, laser cutter, and flamethrower, along with three optical stalks. Its neural network allows near-sentient conversation, and a well-maintained unit is capable of autonomous operation for centuries.</description>
		<statBases>
			<FoodPoisonChance>0.001</FoodPoisonChance>
		</statBases>
		<race>
			<mechEnabledWorkTypes>
				<li>Cooking</li>
				<li>Cleaning</li>
			</mechEnabledWorkTypes>
			<mechWorkTypePriorities>
				<Cleaning>2</Cleaning>
			</mechWorkTypePriorities>
		</race>
	</ThingDef>
