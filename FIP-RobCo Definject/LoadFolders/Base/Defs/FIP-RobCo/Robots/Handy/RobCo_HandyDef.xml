	<!-- Head of Hydra -->
	<ThingDef ParentName="RobCo_HandyBase">
		<defName>RobCo_EyeOfHydra</defName>
		<label>Eye of Hydra</label>
		<description>A compact drone unit spawned and directed by the Hydra command platform. It carries a focused energy blaster and operates under slaved coordination from its parent unit. Individual Eye of Hydra units are lightly armored but attack in numbers from multiple angles simultaneously. Destroying the parent Hydra reverts them to basic autonomous attack protocols.</description>
		<race>
			<body>RobCo_Handy</body>
			<intelligence>ToolUser</intelligence>
			<thinkTreeMain>Mechanoid</thinkTreeMain>
			<baseBodySize>1.0</baseBodySize>
			<baseHealthScale>1.5</baseHealthScale>
			<mechWeightClass>Light</mechWeightClass>
		</race>
	</ThingDef>
