	<!-- Mister Farmhand -->
	<ThingDef ParentName="RobCo_HandyBase">
		<defName>RobCo_MisterFarmhand</defName>
		<label>Mister Farmhand</label>
		<description>A Mister Handy unit reconfigured for agricultural work. It is equipped with tool arms suited to planting, harvesting, and field maintenance, along with crop monitoring sensors. Sold to pre-war farming operations, the Mister Farmhand retains a laser arm for worksite defense.</description>
		<race>
			<mechEnabledWorkTypes>
				<li>Growing</li>
				<li>Handling</li>
				<li>PlantCutting</li>
			</mechEnabledWorkTypes>
			<mechWorkTypePriorities>
				<Growing>2</Growing>
			</mechWorkTypePriorities>
		</race>
	</ThingDef>
	<PawnKindDef ParentName="RobCo_SmallRobotKind">
		<defName>RobCo_MisterFarmhand</defName>
		<label>Mister Farmhand</label>
		<race>RobCo_MisterFarmhand</race>
		<combatPower>10</combatPower>
