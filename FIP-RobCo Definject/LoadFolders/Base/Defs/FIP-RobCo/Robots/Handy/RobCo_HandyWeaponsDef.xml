<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<ThingDef Name="RobCo_HandyCivilianBlasterBase" ParentName="RobCo_BaseGun" Abstract="True">
		<label>RobCo Civilian Blaster</label>
		<description>A pre-War RobCo sidearm intended for civilian security and general self-defense. It uses a low-beam laser cartridge and is less powerful than RobCo's military models.</description>
		<statBases>
			<MarketValue>500</MarketValue>
			<Mass>2</Mass>
			<AccuracyTouch>0.70</AccuracyTouch>
			<AccuracyShort>0.65</AccuracyShort>
			<AccuracyMedium>0.50</AccuracyMedium>
			<AccuracyLong>0.30</AccuracyLong>
			<RangedWeapon_Cooldown>2.0</RangedWeapon_Cooldown>
		</statBases>
		<verbs>
			<li>
				<verbClass>Verb_Shoot</verbClass>
				<range>20</range>
				<warmupTime>0.4</warmupTime>
				<defaultProjectile>RobCo_Bullet_LaserLow</defaultProjectile>
				<burstShotCount>1</burstShotCount>
			</li>
		</verbs>
	</ThingDef>

	<ThingDef Name="RobCo_GutsyArrayBase" ParentName="RobCo_BaseGun" Abstract="True">
		<label>Gutsy array</label>
		<description>A combined weapon system fitted to Mister Gutsy-class robots. It includes an automatic gun for ranged fire, a light flamer, and a reinforced close-quarters ripper.</description>
		<statBases>
			<MarketValue>1500</MarketValue>
			<Mass>3.5</Mass>
			<AccuracyTouch>0.80</AccuracyTouch>
			<AccuracyShort>0.75</AccuracyShort>
			<AccuracyMedium>0.60</AccuracyMedium>
			<AccuracyLong>0.40</AccuracyLong>
			<RangedWeapon_Cooldown>1.2</RangedWeapon_Cooldown>
		</statBases>
		<verbs>
			<li>
				<verbClass>Verb_Shoot</verbClass>
				<hasStandardCommand>true</hasStandardCommand>
				<defaultProjectile>RobCo_Bullet_BallisticAuto</defaultProjectile>
				<warmupTime>0.8</warmupTime>
				<range>22</range>
				<burstShotCount>4</burstShotCount>
				<ticksBetweenBurstShots>6</ticksBetweenBurstShots>
				<soundCast>Shot_MachinePistol</soundCast>
				<soundCastTail>GunTail_Heavy</soundCastTail>
				<muzzleFlashScale>1.8</muzzleFlashScale>
			</li>
		</verbs>
		<comps Inherit="False">
			<li Class="CompProperties_EquippableAbilityReloadable">
				<abilityDef>RobCo_LightFlamer</abilityDef>
				<maxCharges>1</maxCharges>
				<soundReload>Standard_Reload</soundReload>
				<chargeNoun>flamer charge</chargeNoun>
				<ammoDef>Chemfuel</ammoDef>
				<ammoCountPerCharge>10</ammoCountPerCharge>
				<baseReloadTicks>60</baseReloadTicks>
			</li>
		</comps>
	</ThingDef>

	<ThingDef Name="RobCo_EyeOfHydraSniperBase" ParentName="RobCo_BaseGun" Abstract="True">
		<label>RobCo Sniper Blaster</label>
		<description>A long-range precision blaster configured for deliberate, accurate fire. It uses high-beam laser cartridges and is intended for robotic marksman and patrol roles.</description>
		<statBases>
			<MarketValue>1600</MarketValue>
			<Mass>4</Mass>
			<AccuracyTouch>0.98</AccuracyTouch>
			<AccuracyShort>0.95</AccuracyShort>
			<AccuracyMedium>0.90</AccuracyMedium>
			<AccuracyLong>0.90</AccuracyLong>
			<RangedWeapon_Cooldown>4.5</RangedWeapon_Cooldown>
		</statBases>
		<verbs>
			<li>
				<verbClass>Verb_Shoot</verbClass>
				<range>35</range>
				<warmupTime>1.8</warmupTime>
				<defaultProjectile>RobCo_Bullet_LaserHigh</defaultProjectile>
				<burstShotCount>1</burstShotCount>
			</li>
		</verbs>
	</ThingDef>

