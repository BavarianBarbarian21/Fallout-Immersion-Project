<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <!-- Nature shrines / animus stone -> cryptid equivalents -->
  <!--Mothman Totem-->
  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/ThingDef[defName="Plant_TreeAnima"]/graphicData/texPath</xpath>
    <value>
      <texPath>FIP-Hubris/Totem/Hubris_MothmanTree</texPath>
    </value>
  </Operation>
  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/ThingDef[defName="Plant_TreeAnima"]/graphicData/graphicClass</xpath>
    <value>
      <graphicClass>Graphic_Single</graphicClass>
    </value>
  </Operation>
  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/ThingDef[defName="Plant_TreeAnima"]/plant/immatureGraphicPath</xpath>
    <value>
      <immatureGraphicPath>FIP-Hubris/Totem/Hubris_MothmanTree</immatureGraphicPath>
    </value>
  </Operation>
  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/ThingDef[defName="Plant_TreeAnima"]/plant/snowOverlayGraphicPath</xpath>
    <value>
      <snowOverlayGraphicPath>FIP-Hubris/Totem/Hubris_MothmanTree</snowOverlayGraphicPath>
    </value>
  </Operation>
  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/ThingDef[defName="Plant_TreeAnima"]/plant/immatureSnowOverlayGraphicPath</xpath>
    <value>
      <immatureSnowOverlayGraphicPath>FIP-Hubris/Totem/Hubris_MothmanTree</immatureSnowOverlayGraphicPath>
    </value>
  </Operation>
  <!--Mothman Eggs-->
  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/ThingDef[defName="Plant_GrassAnima"]/graphicData/texPath</xpath>
    <value>
      <texPath>FIP-Hubris/Egg</texPath>
    </value>
  </Operation>
</Patch>