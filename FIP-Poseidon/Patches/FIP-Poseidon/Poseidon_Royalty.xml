<?xml version="1.0" encoding="utf-8"?>
<Patch>
	<Operation Class="PatchOperationSequence" MayRequire="Ludeon.RimWorld.Royalty">
		<success>Always</success>
		<operations>
			<li Class="PatchOperationReplace">
				<xpath>/Defs/ThingDef[defName="UnstablePowerCell"]/label</xpath>
				<value>
					<label>unstable fusion battery</label>
				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>/Defs/ThingDef[defName="UnstablePowerCell"]/description</xpath>
				<value>
					<description>An unstable fusion battery built around a permanently active power core. It will run forever until something damages the housing badly enough to turn the whole unit into a catastrophic detonation.</description>
				</value>
			</li>
		</operations>
	</Operation>
</Patch>