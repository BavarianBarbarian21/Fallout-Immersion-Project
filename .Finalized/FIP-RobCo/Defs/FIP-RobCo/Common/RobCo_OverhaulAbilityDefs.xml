<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<AbilityDef>
		<defName>RobCo_LightFlamer</defName>
		<label>light flamer</label>
		<description>Expends a chemfuel charge to spray a close-range incendiary burst.</description>
		<iconPath>UI/Abilities/FireSpew</iconPath>
		<aiCanUse>true</aiCanUse>
		<ai_IsIncendiary>true</ai_IsIncendiary>
		<cooldownTicksRange>240~240</cooldownTicksRange>
		<warmupStartSound>FireSpew_Warmup</warmupStartSound>
		<displayGizmoWhileUndrafted>false</displayGizmoWhileUndrafted>
		<disableGizmoWhileUndrafted>true</disableGizmoWhileUndrafted>
		<verbProperties>
			<verbClass>Verb_CastAbility</verbClass>
			<requireLineOfSight>true</requireLineOfSight>
			<range>9.9</range>
			<warmupTime>0.5</warmupTime>
			<soundCast>FireSpew_Resolve</soundCast>
			<targetParams>
				<canTargetLocations>true</canTargetLocations>
			</targetParams>
		</verbProperties>
		<comps>
			<li Class="CompProperties_AbilityFireSpew">
				<range>9.9</range>
				<lineWidthEnd>3</lineWidthEnd>
				<filthDef>Filth_Ash</filthDef>
				<damAmount>12</damAmount>
				<canHitFilledCells>true</canHitFilledCells>
			</li>
			<li Class="CompProperties_AbilityBurner" MayRequire="Ludeon.RimWorld.Anomaly">
				<numStreams>15</numStreams>
				<range>11</range>
				<coneSizeDegrees>7.2</coneSizeDegrees>
				<moteDef>Mote_IncineratorBurst</moteDef>
				<barrelOffsetDistance>6</barrelOffsetDistance>
				<sizeReductionDistanceThreshold>8</sizeReductionDistanceThreshold>
				<lifespanNoise>40</lifespanNoise>
				<rangeNoise>.4</rangeNoise>
				<effecterDef>BurnerUsed</effecterDef>
			</li>
			<li Class="FIP_RobCo.CompProperties_AbilityLaunchProjectileMultiple">
				<maxCharges>1</maxCharges>
				<ammoDef>Chemfuel</ammoDef>
				<ammoCountPerCharge>10</ammoCountPerCharge>
				<soundReload>Standard_Reload</soundReload>
				<chargeNoun>flamer charge</chargeNoun>
			</li>
		</comps>
	</AbilityDef>

	<AbilityDef>
		<defName>RobCo_HeavyFlamer</defName>
		<label>heavy flamer</label>
		<description>Expends stored chemfuel to project a longer, hotter incendiary burst.</description>
		<iconPath>UI/Abilities/FireSpew</iconPath>
		<aiCanUse>true</aiCanUse>
		<ai_IsIncendiary>true</ai_IsIncendiary>
		<cooldownTicksRange>480~480</cooldownTicksRange>
		<warmupStartSound>FireSpew_Warmup</warmupStartSound>
		<displayGizmoWhileUndrafted>false</displayGizmoWhileUndrafted>
		<disableGizmoWhileUndrafted>true</disableGizmoWhileUndrafted>
		<verbProperties>
			<verbClass>Verb_CastAbility</verbClass>
			<requireLineOfSight>true</requireLineOfSight>
			<range>18</range>
			<warmupTime>0.5</warmupTime>
			<soundCast>FireSpew_Resolve</soundCast>
			<targetParams>
				<canTargetLocations>true</canTargetLocations>
			</targetParams>
		</verbProperties>
		<comps>
			<li Class="CompProperties_AbilityFireSpew">
				<range>18</range>
				<lineWidthEnd>3</lineWidthEnd>
				<filthDef>Filth_Ash</filthDef>
				<damAmount>12</damAmount>
				<canHitFilledCells>true</canHitFilledCells>
			</li>
			<li Class="CompProperties_AbilityBurner" MayRequire="Ludeon.RimWorld.Anomaly">
				<numStreams>15</numStreams>
				<range>20</range>
				<coneSizeDegrees>7.2</coneSizeDegrees>
				<moteDef>Mote_IncineratorBurst</moteDef>
				<barrelOffsetDistance>6</barrelOffsetDistance>
				<sizeReductionDistanceThreshold>8</sizeReductionDistanceThreshold>
				<lifespanNoise>40</lifespanNoise>
				<rangeNoise>.4</rangeNoise>
				<effecterDef>BurnerUsed</effecterDef>
			</li>
			<li Class="FIP_RobCo.CompProperties_AbilityLaunchProjectileMultiple">
				<maxCharges>3</maxCharges>
				<ammoDef>Chemfuel</ammoDef>
				<ammoCountPerCharge>20</ammoCountPerCharge>
				<soundReload>Standard_Reload</soundReload>
				<chargeNoun>heavy flamer charge</chargeNoun>
			</li>
		</comps>
	</AbilityDef>

	<AbilityDef>
		<defName>RobCo_SecuritronRocketSalvo</defName>
		<label>rocket salvo</label>
		<description>Launches a three-rocket saturation strike.</description>
		<iconPath>UI/Abilities/RocketsMissileLauncher</iconPath>
		<aiCanUse>true</aiCanUse>
		<cooldownTicksRange>600~600</cooldownTicksRange>
		<displayGizmoWhileUndrafted>false</displayGizmoWhileUndrafted>
		<showPsycastEffects>false</showPsycastEffects>
		<verbProperties>
			<verbClass>Verb_CastAbility</verbClass>
			<requireLineOfSight>false</requireLineOfSight>
			<range>34</range>
			<minRange>8</minRange>
			<warmupTime>1.5</warmupTime>
			<soundCast>Shot_IncendiaryLauncher</soundCast>
			<targetParams>
				<canTargetLocations>true</canTargetLocations>
				<canTargetBuildings>true</canTargetBuildings>
			</targetParams>
		</verbProperties>
		<comps>
			<li Class="FIP_RobCo.CompProperties_AbilityLaunchProjectileMultiple">
				<projectileDef>RobCo_Bullet_SecuritronRocket</projectileDef>
				<forcedMissRadius>1.8</forcedMissRadius>
				<ticksBetweenBurstShots>10</ticksBetweenBurstShots>
				<burstShotCount>3</burstShotCount>
			</li>
		</comps>
	</AbilityDef>

	<AbilityDef>
		<defName>RobCo_LibertyPrimeNukeThrow</defName>
		<label>mini-nuke throw</label>
		<description>Hurls a mini-nuke in a high arc.</description>
		<iconPath>UI/Abilities/NukeMissileLauncher</iconPath>
		<aiCanUse>true</aiCanUse>
		<cooldownTicksRange>1800~1800</cooldownTicksRange>
		<displayGizmoWhileUndrafted>false</displayGizmoWhileUndrafted>
		<showPsycastEffects>false</showPsycastEffects>
		<verbProperties>
			<verbClass>Verb_CastAbility</verbClass>
			<requireLineOfSight>false</requireLineOfSight>
			<range>40</range>
			<minRange>10</minRange>
			<warmupTime>2.4</warmupTime>
			<soundCast>Shot_IncendiaryLauncher</soundCast>
			<targetParams>
				<canTargetLocations>true</canTargetLocations>
				<canTargetBuildings>true</canTargetBuildings>
			</targetParams>
		</verbProperties>
		<comps>
			<li Class="FIP_RobCo.CompProperties_AbilityLaunchProjectileMultiple">
				<projectileDef>RobCo_Bullet_LibertyPrimeMiniNuke</projectileDef>
				<forcedMissRadius>2.5</forcedMissRadius>
				<burstShotCount>1</burstShotCount>
			</li>
		</comps>
	</AbilityDef>

	<HediffDef>
		<defName>RobCo_WarMachineLiberatorUplink</defName>
		<label>war machine uplink</label>
		<description>Receives a combat uplink from a nearby War Machine.</description>
		<hediffClass>HediffWithComps</hediffClass>
		<isBad>false</isBad>
		<stages>
			<li>
				<label>war machine uplink</label>
				<statOffsets>
					<MeleeDamageFactor>1</MeleeDamageFactor>
					<RangedCooldownFactor>-0.5</RangedCooldownFactor>
					<IncomingDamageFactor>-0.5</IncomingDamageFactor>
				</statOffsets>
			</li>
		</stages>
	</HediffDef>
</Defs>