<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<!-- Shared projectile bases -->
	<ThingDef Name="RobCo_BaseBullet" ParentName="BaseBullet" Abstract="True">
		<graphicData>
			<texPath>RobCo/Misc/Laser</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<shaderType>TransparentPostLight</shaderType>
		</graphicData>
	</ThingDef>

	<!-- Shared projectiles -->
	<ThingDef ParentName="RobCo_BaseBullet">
		<defName>RobCo_Bullet_LaserLow</defName>
		<label>low-beam laser</label>
		<projectile>
			<damageDef>Bullet</damageDef>
			<damageAmountBase>8</damageAmountBase>
			<armorPenetrationBase>0.4</armorPenetrationBase>
			<speed>75</speed>
			<stoppingPower>0.5</stoppingPower>
		</projectile>
	</ThingDef>
	<ThingDef ParentName="RobCo_BaseBullet">
		<defName>RobCo_Bullet_LaserHigh</defName>
		<label>high-beam laser</label>
		<projectile>
			<damageDef>Bullet</damageDef>
			<damageAmountBase>12</damageAmountBase>
			<armorPenetrationBase>0.4</armorPenetrationBase>
			<speed>85</speed>
			<stoppingPower>0.8</stoppingPower>
		</projectile>
	</ThingDef>
	<ThingDef ParentName="RobCo_BaseBullet">
		<defName>RobCo_Bullet_LaserAuto</defName>
		<label>auto laser</label>
		<projectile>
			<damageDef>Bullet</damageDef>
			<damageAmountBase>6</damageAmountBase>
			<armorPenetrationBase>0.2</armorPenetrationBase>
			<speed>80</speed>
			<stoppingPower>2.5</stoppingPower>
		</projectile>
	</ThingDef>
	<ThingDef ParentName="BaseBullet">
		<defName>RobCo_Bullet_SentryRocket</defName>
		<label>sentry rocket</label>
		<graphicData>
			<texPath>Things/Projectile/Rocket_Big</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<shaderType>TransparentPostLight</shaderType>
		</graphicData>
		<thingClass>Projectile_Explosive</thingClass>
		<projectile>
			<damageDef>Thump</damageDef>
			<explosionRadius>3.9</explosionRadius>
			<speed>50</speed>
		</projectile>
	</ThingDef>
	<ThingDef ParentName="BaseBullet">
		<defName>RobCo_Bullet_LaserAssaultron</defName>
		<label>RobCo Assaultron head laser</label>
		<thingClass>Projectile_HellsphereCannon</thingClass>
		<graphicData>
			<texPath>Things/Projectile/HellsphereCannon</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<shaderType>MoteGlow</shaderType>
			<drawSize>(1.2, 2.4)</drawSize>
		</graphicData>
		<projectile>
			<damageDef>RobCo_LaserAssaultronDamage</damageDef>
			<speed>75</speed>
			<explosionRadius>2.9</explosionRadius>
			<screenShakeFactor>1.0</screenShakeFactor>
			<filth>Filth_BlastMark</filth>
			<filthCount>1</filthCount>
			<explosionSpawnsSingleFilth>true</explosionSpawnsSingleFilth>
		</projectile>
	</ThingDef>
	<DamageDef Name="RobCo_LaserAssaultronDamage">
		<defName>RobCo_LaserAssaultronDamage</defName>
		<label>vaporize</label>
		<workerClass>DamageWorker_Vaporize</workerClass>
		<externalViolence>true</externalViolence>
		<deathMessage>{0} has been vaporized by extreme heat.</deathMessage>
		<hediff>Burn</hediff>
		<harmAllLayersUntilOutside>true</harmAllLayersUntilOutside>
		<defaultDamage>200</defaultDamage>
		<defaultStoppingPower>1.5</defaultStoppingPower>
		<defaultArmorPenetration>1</defaultArmorPenetration>
		<buildingDamageFactorImpassable>4</buildingDamageFactorImpassable>
		<buildingDamageFactorPassable>2</buildingDamageFactorPassable>
		<plantDamageFactor>2</plantDamageFactor>
		<explosionHeatEnergyPerCell>20</explosionHeatEnergyPerCell>
		<explosionCellFleck>Fleck_Vaporize</explosionCellFleck>
		<armorCategory>Heat</armorCategory>
		<minDamageToFragment>15</minDamageToFragment>
		<makesAnimalsFlee>true</makesAnimalsFlee>
		<explosionColorCenter>(1, 1, 1)</explosionColorCenter>
		<explosionColorEdge>(0.6, 0.5, 0.4)</explosionColorEdge>
		<soundExplosion>Explosion_Vaporize</soundExplosion>
		<expolosionPropagationSpeed>0.3</expolosionPropagationSpeed>
		<hasForcefulImpact>true</hasForcefulImpact>
		<corpseDamageFactor>0.1</corpseDamageFactor>
	</DamageDef>
	<ThingDef ParentName="BaseBullet">
		<defName>RobCo_Bullet_LaserSheepsquatch</defName>
		<label>RobCo Assaultron head laser</label>
		<thingClass>Projectile_HellsphereCannon</thingClass>
		<graphicData>
			<texPath>Things/Projectile/HellsphereCannon</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<shaderType>MoteGlow</shaderType>
			<drawSize>(1.5, 3)</drawSize>
		</graphicData>
		<projectile>
			<damageDef>Vaporize</damageDef>
			<speed>75</speed>
			<explosionRadius>4.9</explosionRadius>
			<screenShakeFactor>1.5</screenShakeFactor>
			<filth>Filth_BlastMark</filth>
			<filthCount>1</filthCount>
			<explosionSpawnsSingleFilth>true</explosionSpawnsSingleFilth>
		</projectile>
	</ThingDef>
	<ThingDef ParentName="BaseBullet">
		<defName>RobCo_Bullet_SonicBark</defName>
		<label>sonic bark</label>
		<graphicData>
			<texPath>RobCo/Misc/Invisible</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<projectile>
			<damageDef>EMP</damageDef>
			<explosionRadius>3.5</explosionRadius>
			<speed>70</speed>
			<applyDamageToExplosionCellsNeighbors>false</applyDamageToExplosionCellsNeighbors>
		</projectile>
	</ThingDef>
	<ThingDef ParentName="BaseBullet">
		<defName>RobCo_Bullet_Syringe</defName>
		<label>RobCo syringe</label>
		<graphicData>
			<texPath>Things/Projectile/ToxicNeedleShot</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<projectile>
			<damageDef>BulletToxic</damageDef>
			<damageAmountBase>25</damageAmountBase>
			<armorPenetrationBase>0.35</armorPenetrationBase>
			<stoppingPower>1.5</stoppingPower>
			<speed>90</speed>
		</projectile>
	</ThingDef>
	<ThingDef ParentName="RobCo_BaseBullet">
		<defName>RobCo_Bullet_LiberatorLaser</defName>
		<label>liberator laser</label>
		<projectile>
			<damageDef>Bullet</damageDef>
			<damageAmountBase>16</damageAmountBase>
			<armorPenetrationBase>0.45</armorPenetrationBase>
			<speed>88</speed>
			<stoppingPower>0.9</stoppingPower>
		</projectile>
	</ThingDef>
	<ThingDef ParentName="RobCo_BaseBullet">
		<defName>RobCo_Bullet_ScurrybotLaser</defName>
		<label>scurrybot laser</label>
		<projectile>
			<damageDef>Bullet</damageDef>
			<damageAmountBase>8</damageAmountBase>
			<armorPenetrationBase>0.35</armorPenetrationBase>
			<speed>80</speed>
			<stoppingPower>0.5</stoppingPower>
		</projectile>
	</ThingDef>
	<ThingDef ParentName="RobCo_BaseBullet">
		<defName>RobCo_Bullet_LibertyPrimeMiniNuke</defName>
		<label>liberty prime mini-nuke</label>
		<projectile>
			<damageDef>Bomb</damageDef>
			<damageAmountBase>40</damageAmountBase>
			<explosionRadius>4.5</explosionRadius>
			<speed>50</speed>
			<stoppingPower>0</stoppingPower>
		</projectile>
	</ThingDef>
	<ThingDef ParentName="RobCo_BaseBullet">
		<defName>RobCo_Bullet_SecuritronLaser</defName>
		<label>securitron laser</label>
		<projectile>
			<damageDef>Bullet</damageDef>
			<damageAmountBase>12</damageAmountBase>
			<armorPenetrationBase>0.45</armorPenetrationBase>
			<speed>85</speed>
			<stoppingPower>0.8</stoppingPower>
		</projectile>
	</ThingDef>
	<ThingDef ParentName="RobCo_BaseBullet">
		<defName>RobCo_Bullet_Electroshock</defName>
		<label>electroshock bolt</label>
		<projectile>
			<damageDef>EMP</damageDef>
			<damageAmountBase>8</damageAmountBase>
			<speed>70</speed>
			<stoppingPower>0.5</stoppingPower>
		</projectile>
	</ThingDef>

	<!-- Shared weapon base -->
	<ThingDef Name="RobCo_BaseGun" ParentName="BaseGun" Abstract="True">
		<tradeability>None</tradeability>
		<destroyOnDrop>true</destroyOnDrop>
		<relicChance>0</relicChance>
		<graphicData>
			<texPath>RobCo/Misc/Invisible</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<equippedDistanceOffset>-0.14</equippedDistanceOffset>
		<weaponClasses>
			<li>Ranged</li>
		</weaponClasses>
		<techLevel>Spacer</techLevel>
	</ThingDef>

	<!-- Shared abilities -->
	<AbilityDef>
		<defName>RobCo_ExterminatorFlamer</defName>
		<label>exterminator flamer</label>
		<description>Expends a charge to spray an extended-range incendiary burst.</description>
		<iconPath>UI/Abilities/FireSpew</iconPath>
		<aiCanUse>true</aiCanUse>
		<ai_IsIncendiary>true</ai_IsIncendiary>
		<warmupStartSound>FireSpew_Warmup</warmupStartSound>
		<verbProperties>
			<verbClass>Verb_CastAbility</verbClass>
			<requireLineOfSight>true</requireLineOfSight>
			<range>18</range>
			<warmupTime>0.5</warmupTime>
			<soundCast>FireSpew_Resolve</soundCast>
			<targetParams>
				<canTargetLocations>true</canTargetLocations>
			</targetParams>
			<flammabilityAttachFireChanceCurve>
				<points>
					<li>(0.2, 0)</li>
					<li>(1, 1)</li>
				</points>
			</flammabilityAttachFireChanceCurve>
		</verbProperties>
		<comps>
			<li Class="CompProperties_AbilityFireSpew">
				<range>18</range>
				<lineWidthEnd>3</lineWidthEnd>
				<filthDef>Filth_Ash</filthDef>
				<damAmount>12</damAmount>
				<canHitFilledCells>true</canHitFilledCells>
			</li>
			<li Class="CompProperties_AbilityBurner" MayRequire="Ludeon.RimWorld.Anomaly">
				<numStreams>15</numStreams>
				<range>20</range>
				<coneSizeDegrees>7.2</coneSizeDegrees>
				<moteDef>Mote_IncineratorBurst</moteDef>
				<barrelOffsetDistance>6</barrelOffsetDistance>
				<sizeReductionDistanceThreshold>8</sizeReductionDistanceThreshold>
				<lifespanNoise>40</lifespanNoise>
				<rangeNoise>.4</rangeNoise>
				<effecterDef>BurnerUsed</effecterDef>
			</li>
		</comps>
	</AbilityDef>
	<AbilityDef>
		<defName>RobCo_NapalmFlamer</defName>
		<label>napalm flamer</label>
		<description>Expends a napalm charge to spray an incendiary burst.</description>
		<iconPath>UI/Abilities/FireSpew</iconPath>
		<aiCanUse>true</aiCanUse>
		<ai_IsIncendiary>true</ai_IsIncendiary>
		<warmupStartSound>FireSpew_Warmup</warmupStartSound>
		<verbProperties>
			<verbClass>Verb_CastAbility</verbClass>
			<requireLineOfSight>true</requireLineOfSight>
			<range>9.9</range>
			<warmupTime>0.5</warmupTime>
			<soundCast>FireSpew_Resolve</soundCast>
			<targetParams>
				<canTargetLocations>true</canTargetLocations>
			</targetParams>
			<flammabilityAttachFireChanceCurve>
				<points>
					<li>(0.2, 0)</li>
					<li>(1, 1)</li>
				</points>
			</flammabilityAttachFireChanceCurve>
		</verbProperties>
		<comps>
			<li Class="CompProperties_AbilityFireSpew">
				<range>9.9</range>
				<lineWidthEnd>3</lineWidthEnd>
				<filthDef>Filth_Ash</filthDef>
				<damAmount>12</damAmount>
				<canHitFilledCells>true</canHitFilledCells>
			</li>
			<li Class="CompProperties_AbilityBurner" MayRequire="Ludeon.RimWorld.Anomaly">
				<numStreams>15</numStreams>
				<range>11</range>
				<coneSizeDegrees>7.2</coneSizeDegrees>
				<moteDef>Mote_IncineratorBurst</moteDef>
				<barrelOffsetDistance>6</barrelOffsetDistance>
				<sizeReductionDistanceThreshold>8</sizeReductionDistanceThreshold>
				<lifespanNoise>40</lifespanNoise>
				<rangeNoise>.4</rangeNoise>
				<effecterDef>BurnerUsed</effecterDef>
			</li>
		</comps>
	</AbilityDef>
</Defs>