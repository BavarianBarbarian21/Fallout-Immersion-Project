<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<!-- Securitron Body -->
	<BodyDef>
		<defName>RobCo_Securitron</defName>
		<label>securitron mkI</label>
		<corePart>
			<def>RobCo_Chassis</def>
			<height>Middle</height>
			<depth>Outside</depth>
			<groups>
				<li>Torso</li>
			</groups>
			<parts>
				<li>
					<def>RobCo_Processor</def>
					<coverage>0.06</coverage>
					<depth>Inside</depth>
				</li>
				<li>
					<def>Reactor</def>
					<coverage>0.06</coverage>
					<depth>Inside</depth>
				</li>
				<li>
					<def>FluidReprocessor</def>
					<coverage>0.04</coverage>
					<depth>Inside</depth>
				</li>
				<li>
					<def>MechanicalNeck</def>
					<coverage>0.10</coverage>
					<height>Top</height>
					<parts>
						<li>
							<def>MechanicalHead</def>
							<coverage>0.80</coverage>
							<parts>
								<li>
									<def>RobCo_Scanner</def>
									<coverage>0.13</coverage>
								</li>
								<li>
									<def>RobCo_Microphone</def>
									<coverage>0.10</coverage>
								</li>
							</parts>
						</li>
					</parts>
				</li>
				<li>
					<def>MechanicalLeg</def>
					<customLabel>central leg</customLabel>
					<coverage>0.40</coverage>
					<height>Bottom</height>
					<parts>
						<li>
							<def>MechanicalFoot</def>
							<customLabel>wheel</customLabel>
							<coverage>0.10</coverage>
						</li>
					</parts>
				</li>
			</parts>
		</corePart>
	</BodyDef>
	<BodyDef>
