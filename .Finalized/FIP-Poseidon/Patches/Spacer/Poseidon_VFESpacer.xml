<?xml version="1.0" encoding="utf-8"?>
<Patch>
	<Operation Class="PatchOperationSequence" MayRequire="VanillaExpanded.VFESpacer">
		<success>Always</success>
		<operations>
			<li Class="PatchOperationReplace">
				<xpath>/Defs/ThingDef[defName="Spacer_OutdoorLamp"]/description</xpath>
				<value>
					<description>An outdoor utility lamp with an integrated Poseidon solar collector. It charges by day and provides dependable lighting after dark.</description>
				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>/Defs/ThingDef[defName="VFES_AirPurifier"]/label</xpath>
				<value>
					<label>Wattz air scrubber</label>
				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>/Defs/ThingDef[defName="VFES_AirPurifier"]/description</xpath>
				<value>
					<description>A compact Wattz Electronics air scrubber that filters smoke, dust, and hazardous particulates while improving room cleanliness and indoor air quality.</description>
				</value>
			</li>
		</operations>
	</Operation>
</Patch>