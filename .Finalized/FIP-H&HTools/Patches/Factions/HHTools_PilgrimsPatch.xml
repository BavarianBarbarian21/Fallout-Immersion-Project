<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="PatchOperationSequence">
    <operations>
      <li Class="PatchOperationReplace" MayRequire="FIP.Greenway">
        <xpath>Defs/FactionDef[defName="Pilgrims"]/label</xpath>
        <value>
          <label>Wise Mothman Cultists</label>
        </value>
      </li>
      <li Class="PatchOperationReplace" MayRequire="FIP.Greenway">
        <xpath>Defs/FactionDef[defName="Pilgrims"]/description</xpath>
        <value>
          <description>Guardians of ancient wisdom, the Wise Mothman Cultists follow the elusive protector as a guide against the wasteland’s creeping horrors. Calm and watchful, they seek balance between man and myth, standing sentinel against the chaos that threatens to consume all.</description>
        </value>
      </li>
      <li Class="PatchOperationReplace" MayRequire="Ludeon.RimWorld.Royalty">
        <xpath>Defs/FactionDef[defName="Pilgrims"]/pawnSingular</xpath>
        <value>
          <pawnSingular>Watcher</pawnSingular>
        </value>
      </li>
      <li Class="PatchOperationReplace" MayRequire="Ludeon.RimWorld.Royalty">
        <xpath>Defs/FactionDef[defName="Pilgrims"]/pawnsPlural</xpath>
        <value>
          <pawnsPlural>Watchers</pawnsPlural>
        </value>
      </li>
    </operations>
  </Operation>

  <Operation Class="PatchOperationFindMod">
    <mods>
      <li>Ludeon.RimWorld.Ideology</li>
    </mods>
    <match Class="PatchOperationFindMod">
      <mods>
        <li>FIP.Greenway</li>
      </mods>
      <match Class="PatchOperationSequence">
        <operations>
          <li Class="PatchOperationReplace" MayRequire="FIP.WestTek">
            <xpath>Defs/FactionDef[defName="Pilgrims"]/xenotypeSet</xpath>
            <value>
              <xenotypeSet>
                <xenotypeChances>
                  <WestTek_Xenotype_Atlantic MayRequire="FIP.WestTek">0.4</WestTek_Xenotype_Atlantic>
                  <WestTek_Xenotype_NatL MayRequire="FIP.WestTek">0.3</WestTek_Xenotype_NatL>
                  <WestTek_Xenotype_Cascadia MayRequire="FIP.WestTek">0.2</WestTek_Xenotype_Cascadia>
                  <WestTek_Xenotype_PureHumans MayRequire="FIP.WestTek">0.1</WestTek_Xenotype_PureHumans>
                </xenotypeChances>
              </xenotypeSet>
            </value>
          </li>
        </operations>
      </match>
    </match>
  </Operation>
</Patch>