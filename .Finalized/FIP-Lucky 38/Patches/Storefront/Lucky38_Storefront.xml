<?xml version="1.0" encoding="utf-8"?>
<Patch>
	<!-- Storefront terminology -->
	<Operation Class="PatchOperationSequence" MayRequire="Adamas.Storefront">
		<success>Always</success>
		<operations>
			<li Class="PatchOperationReplace">
				<xpath>/LanguageData/StoreMessageIncomeToday</xpath>
				<value>
					<StoreMessageIncomeToday>Your promenade has earned {0} today.</StoreMessageIncomeToday>
				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>/LanguageData/TabRegisterStore</xpath>
				<value>
					<TabRegisterStore>Promenade</TabRegisterStore>
				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>/LanguageData/StoreDefaultName</xpath>
				<value>
					<StoreDefaultName>promenade {0}</StoreDefaultName>
				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>/LanguageData/StoreTooltipRename</xpath>
				<value>
					<StoreTooltipRename>Rename this promenade.</StoreTooltipRename>
				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>/LanguageData/TabRegisterOpenedTooltip</xpath>
				<value>
					<TabRegisterOpenedTooltip>When checked, patrons can browse while a sales shift is active.</TabRegisterOpenedTooltip>
				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>/LanguageData/TabRegisterActiveStaff</xpath>
				<value>
					<TabRegisterActiveStaff>Floor staff:</TabRegisterActiveStaff>
				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>/LanguageData/TabRegisterCustomers</xpath>
				<value>
					<TabRegisterCustomers>Patrons:</TabRegisterCustomers>
				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>/LanguageData/AlertNoRegister</xpath>
				<value>
					<AlertNoRegister>No register desk</AlertNoRegister>
				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>/LanguageData/AlertNoRegisterExplanation</xpath>
				<value>
					<AlertNoRegisterExplanation>To open your promenade, you need at least one register desk. This can be built from the production tab.</AlertNoRegisterExplanation>
				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>/LanguageData/AlertNoCashier</xpath>
				<value>
					<AlertNoCashier>No floor clerk</AlertNoCashier>
				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>/LanguageData/AlertNoCashierExplanation</xpath>
				<value>
					<AlertNoCashierExplanation>To operate your promenade, you need at least one staffed shift at a register desk and an assigned floor clerk.</AlertNoCashierExplanation>
				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>/LanguageData/Storefront_StandBy.reportString</xpath>
				<value>
					<Storefront_StandBy.reportString>waiting for promenade work.</Storefront_StandBy.reportString>
				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>/LanguageData/Storefront_Sell.reportString</xpath>
				<value>
					<Storefront_Sell.reportString>ringing up TargetB for TargetA.</Storefront_Sell.reportString>
				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>/LanguageData/Storefront_BrowseItems.reportString</xpath>
				<value>
					<Storefront_BrowseItems.reportString>browsing the promenade.</Storefront_BrowseItems.reportString>
				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>/LanguageData/Storefront_BuyItem.reportString</xpath>
				<value>
					<Storefront_BuyItem.reportString>buying TargetA from the promenade.</Storefront_BuyItem.reportString>
				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>/LanguageData/Storefront_Serviced.stages.0.label</xpath>
				<value>
					<Storefront_Serviced.stages.0.label>shoddy floor service</Storefront_Serviced.stages.0.label>
				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>/LanguageData/Storefront_Serviced.stages.2.label</xpath>
				<value>
					<Storefront_Serviced.stages.2.label>fair floor service</Storefront_Serviced.stages.2.label>
				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>/LanguageData/Storefront_Serviced.stages.4.label</xpath>
