				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>/LanguageData/Storefront_ServicedMood.stages.0.description</xpath>
				<value>
					<Storefront_ServicedMood.stages.0.description>The floor staff handled me poorly.</Storefront_ServicedMood.stages.0.description>
				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>/LanguageData/Storefront_ServicedMood.stages.4.label</xpath>
				<value>
					<Storefront_ServicedMood.stages.4.label>had first-class floor service</Storefront_ServicedMood.stages.4.label>
				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>/LanguageData/Storefront_ServicedMood.stages.4.description</xpath>
				<value>
					<Storefront_ServicedMood.stages.4.description>The floor staff treated me like a valued patron.</Storefront_ServicedMood.stages.4.description>
				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>/LanguageData/TabRegisterOpened</xpath>
				<value>
					<TabRegisterOpened>Open</TabRegisterOpened>
				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>/LanguageData/TabRegisterRadius</xpath>
				<value>
					<TabRegisterRadius>Floor radius</TabRegisterRadius>
				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>/LanguageData/TabRegisterStocked</xpath>
				<value>
					<TabRegisterStocked>Stock on hand:</TabRegisterStocked>
				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>/LanguageData/TabRegisterEarnedYesterday</xpath>
				<value>
					<TabRegisterEarnedYesterday>Took in yesterday:</TabRegisterEarnedYesterday>
				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>/LanguageData/TabRegisterEarnedToday</xpath>
				<value>
					<TabRegisterEarnedToday>Took in today:</TabRegisterEarnedToday>
				</value>
			</li>
		</operations>
	</Operation>
</Patch>