<?xml version="1.0" encoding="utf-8"?>
<Patch>
	<!-- Hospitality Spa flavor pass -->
	<Operation Class="PatchOperationSequence" MayRequire="Adamas.HospitalitySpa">
		<success>Always</success>
		<operations>
			<li Class="PatchOperationReplace">
				<xpath>/LanguageData/HospitalitySpa_VendingMachine</xpath>
				<value>
					<HospitalitySpa_VendingMachine>bathhouse intake</HospitalitySpa_VendingMachine>
				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>/LanguageData/HospitalitySpa_VendingMachineContains</xpath>
				<value>
					<HospitalitySpa_VendingMachineContains>Collected fees:</HospitalitySpa_VendingMachineContains>
				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>/LanguageData/HospitalitySpa_VendingMachineTotal</xpath>
				<value>
					<HospitalitySpa_VendingMachineTotal>Lifetime take:</HospitalitySpa_VendingMachineTotal>
				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>/LanguageData/HospitalitySpa_VendingMachineToggleDesc</xpath>
				<value>
					<HospitalitySpa_VendingMachineToggleDesc>Allow patrons to use this bathhouse amenity.</HospitalitySpa_VendingMachineToggleDesc>
				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>/LanguageData/HospitalitySpa_SetPricing</xpath>
				<value>
					<HospitalitySpa_SetPricing>Set bathhouse fee</HospitalitySpa_SetPricing>
				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>/LanguageData/HospitalitySpa_Free</xpath>
				<value>
					<HospitalitySpa_Free>complimentary soak</HospitalitySpa_Free>
				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>/LanguageData/HospitalitySpa_Medium</xpath>
				<value>
					<HospitalitySpa_Medium>house standard fee</HospitalitySpa_Medium>
				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>/LanguageData/HospitalitySpa_High</xpath>
				<value>
					<HospitalitySpa_High>premium bathhouse fee</HospitalitySpa_High>
				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>/Defs/JobDef[defName="HospitalitySpa_EmptyVendingMachine"]/reportString</xpath>
				<value>
					<reportString>collecting bathhouse fees.</reportString>
				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>/Defs/WorkGiverDef[defName="HospitalitySpa_WithdrawVendingMachineEarnings"]/label</xpath>
				<value>
					<label>collect bathhouse fees</label>
				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>/Defs/WorkGiverDef[defName="HospitalitySpa_WithdrawVendingMachineEarnings"]/verb</xpath>
				<value>
					<verb>collect bathhouse fees</verb>
				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>/Defs/WorkGiverDef[defName="HospitalitySpa_WithdrawVendingMachineEarnings"]/gerund</xpath>
				<value>
					<gerund>collecting bathhouse fees</gerund>
				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>/Defs/ThoughtDef[defName="ExpensiveSpa"]/stages/li/label</xpath>
				<value>
					<label>expensive bathhouse</label>
				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>/Defs/ThoughtDef[defName="ExpensiveSpa"]/stages/li/description</xpath>
				<value>
					<description>I had to pay rather a lot for access to the bathhouse.</description>
				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>/Defs/ThoughtDef[defName="CheapSpa"]/stages/li/label</xpath>
				<value>
					<label>good-value bathhouse</label>
				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>/Defs/ThoughtDef[defName="CheapSpa"]/stages/li/description</xpath>
				<value>
					<description>The bathhouse was well worth the fee.</description>
				</value>
			</li>
		</operations>
	</Operation>
</Patch>