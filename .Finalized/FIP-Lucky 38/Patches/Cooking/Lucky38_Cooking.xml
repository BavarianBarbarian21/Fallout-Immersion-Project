<?xml version="1.0" encoding="utf-8"?>
<Patch>
	<Operation Class="PatchOperationSequence" MayRequire="VanillaExpanded.VCookE">
		<success>Always</success>
		<operations>
			<li Class="PatchOperationSequence" MayRequire="Rick.FCP.Plants">
				<success>Always</success>
				<operations>
					<li Class="PatchOperationReplace">
						<xpath>/Defs/ThingDef[defName="VCE_Sugarcane"]/label</xpath>
						<value>
							<label>maize stalk</label>
						</value>
					</li>
					<li Class="PatchOperationReplace">
						<xpath>/Defs/ThingDef[defName="VCE_Sugarcane"]/description</xpath>
						<value>
							<description>A tall stand of maize bred for dense, syrup-rich kernels. It is milled down into the sweeteners used throughout pre-war kitchens and diner recipes.</description>
						</value>
					</li>
					<li Class="PatchOperationReplace">
						<xpath>/Defs/ThingDef[defName="VCE_Sugarcane"]/plant/harvestedThingDef</xpath>
						<value>
							<harvestedThingDef>FCP_Raw_Maize</harvestedThingDef>
						</value>
					</li>
					<li Class="PatchOperationReplace">
						<xpath>/Defs/ThingDef[defName="VCE_Sugarcane"]/plant/sowTags</xpath>
						<value>
							<sowTags />
						</value>
					</li>

					<li Class="PatchOperationReplace">
						<xpath>/Defs/ThingDef[defName="VCE_Allspice"]/label</xpath>
						<value>
							<label>broc flower patch</label>
						</value>
					</li>
					<li Class="PatchOperationReplace">
						<xpath>/Defs/ThingDef[defName="VCE_Allspice"]/description</xpath>
						<value>
							<description>A hardy patch of broc flowers. Their petals bring a peppery, herbal bite to wasteland stews, grills, and sauces.</description>
						</value>
					</li>
					<li Class="PatchOperationReplace">
						<xpath>/Defs/ThingDef[defName="VCE_Allspice"]/plant/harvestedThingDef</xpath>
						<value>
							<harvestedThingDef>FCP_Raw_Broc_Flower</harvestedThingDef>
						</value>
					</li>
					<li Class="PatchOperationReplace">
						<xpath>/Defs/ThingDef[defName="VCE_Allspice"]/plant/sowTags</xpath>
						<value>
							<sowTags />
						</value>
					</li>

					<li Class="PatchOperationReplace">
						<xpath>/Defs/ThingDef[defName="VCE_Wheat"]/label</xpath>
						<value>
							<label>razorgrain stalk</label>
						</value>
					</li>
					<li Class="PatchOperationReplace">
						<xpath>/Defs/ThingDef[defName="VCE_Wheat"]/description</xpath>
						<value>
							<description>A tough amber cereal bred from razorgrain. It yields the coarse flour used in wasteland breads, pastries, and campfire cooking.</description>
						</value>
					</li>
					<li Class="PatchOperationReplace">
						<xpath>/Defs/ThingDef[defName="VCE_Wheat"]/plant/harvestedThingDef</xpath>
						<value>
							<harvestedThingDef>FCP_Raw_Razorgrain</harvestedThingDef>
						</value>
					</li>
					<li Class="PatchOperationReplace">
						<xpath>/Defs/ThingDef[defName="VCE_Wheat"]/plant/sowTags</xpath>
						<value>
							<sowTags />
						</value>
					</li>

					<li Class="PatchOperationReplace">
						<xpath>/Defs/ThingDef[defName="VCE_Flour"]/label</xpath>
						<value>
							<label>razorgrain flour</label>
						</value>
					</li>
					<li Class="PatchOperationReplace">
						<xpath>/Defs/ThingDef[defName="VCE_Flour"]/description</xpath>
						<value>
							<description>Ground razorgrain flour used for breads, pies, and bakery work across the wasteland.</description>
						</value>
					</li>
					<li Class="PatchOperationReplace">
						<xpath>/Defs/ThingDef[defName="VCE_RawSpices"]/label</xpath>
						<value>
							<label>broc flower petals</label>
						</value>
					</li>
					<li Class="PatchOperationReplace">
						<xpath>/Defs/ThingDef[defName="VCE_RawSpices"]/description</xpath>
						<value>
							<description>Dried broc flower petals prepared for seasoning soups, meats, and sauces.</description>
						</value>
					</li>

					<li Class="PatchOperationReplace">
						<xpath>/Defs/RecipeDef[defName="VCE_AgaveNectar"]/ingredients/li/filter/thingDefs/li[text()="RawAgave"]</xpath>
						<value>
							<li>FCP_Raw_Nevada_Agave</li>
						</value>
					</li>
					<li Class="PatchOperationReplace">
						<xpath>/Defs/RecipeDef[defName="VCE_AgaveNectar"]/fixedIngredientFilter/thingDefs/li[text()="RawAgave"]</xpath>
						<value>
							<li>FCP_Raw_Nevada_Agave</li>
						</value>
					</li>
					<li Class="PatchOperationReplace">
						<xpath>/Defs/ThingDef[defName="VCE_AgaveNectar"]/description</xpath>
						<value>
							<description>A thin, semi-sweet nectar pressed from Nevada agave. It keeps the soothing sting of the desert plant while working as a versatile wasteland sweetener.</description>
						</value>
					</li>

					<li Class="PatchOperationReplace">
						<xpath>/Defs/ThingDef[defName="VCE_InsectJellyPreserves"]/label</xpath>
						<value>
							<label>ant preserves</label>
						</value>
					</li>
					<li Class="PatchOperationReplace">
						<xpath>/Defs/ThingDef[defName="VCE_InsectJellyPreserves"]/description</xpath>
						<value>
							<description>A sticky batch of preserves made from giant ant jelly. Sweet, strange, and somehow still good on toast.</description>
						</value>
					</li>
					<li Class="PatchOperationReplace">
						<xpath>/Defs/RecipeDef[defName="VCE_InsectJellyPreserves"]/label</xpath>
						<value>
							<label>make ant preserves</label>
						</value>
					</li>

					<li Class="PatchOperationReplace">
						<xpath>/Defs/ThingDef[defName="VCE_DigestibleResurrectorNanites"]/label</xpath>
						<value>
							<label>aqua cura</label>
						</value>
					</li>
					<li Class="PatchOperationReplace">
						<xpath>/Defs/ThingDef[defName="VCE_DigestibleResurrectorNanites"]/description</xpath>
						<value>
							<description>A rare pre-war restorative suspension packaged as a culinary additive. Folded into food, aqua cura can pull a body back from death by flooding it with emergency repair agents.</description>
						</value>
					</li>
					<li Class="PatchOperationReplace">
						<xpath>/Defs/HediffDef[defName="VCE_ConsumedDigestibleResurrectorNanites"]/label</xpath>
						<value>
							<label>consumed aqua cura (from meal)</label>
						</value>
					</li>
					<li Class="PatchOperationReplace">
						<xpath>/Defs/ThoughtDef[defName="VCE_ConsumedDigestibleResurrectorNanites"]/stages/li/label</xpath>
						<value>
							<label>aqua cura</label>
						</value>
					</li>

					<li Class="PatchOperationAdd">
						<xpath>/Defs</xpath>
						<value>
							<RecipeDef>
								<defName>Lucky38_CookCornSyrup</defName>
								<label>cook corn syrup</label>
								<description>Render down a large batch of maize into a thick pre-war sweetener. Once cooled and processed, the syrup crystallizes into usable cooking sugar.</description>
								<jobString>Cooking corn syrup.</jobString>
								<workSpeedStat>CookSpeed</workSpeedStat>
								<effectWorking>Cook</effectWorking>
								<soundWorking>Recipe_CookMeal</soundWorking>
								<workAmount>1500</workAmount>
								<recipeUsers>
									<li>VCE_CondimentPrepTable</li>
								</recipeUsers>
								<ingredients>
									<li>
										<filter>
											<thingDefs>
												<li>FCP_Raw_Maize</li>
											</thingDefs>
										</filter>
										<count>75</count>
									</li>
								</ingredients>
								<fixedIngredientFilter>
									<thingDefs>
										<li>FCP_Raw_Maize</li>
									</thingDefs>
								</fixedIngredientFilter>
								<products>
									<VCE_RawSugar>75</VCE_RawSugar>
								</products>
								<researchPrerequisite>VCE_CondimentsResearch</researchPrerequisite>
							</RecipeDef>
						</value>
					</li>
				</operations>
			</li>
			<li Class="PatchOperationFindMod">
				<mods>
					<li>Vanilla Plants Expanded</li>
				</mods>
				<match Class="PatchOperationSequence" MayRequire="Rick.FCP.Plants">
					<success>Always</success>
					<operations>
						<li Class="PatchOperationReplace">
							<xpath>/Defs/RecipeDef[defName="VCE_Ketchup"]/ingredients/li/filter/thingDefs/li[text()="VCE_RawTomatoes"]</xpath>
							<value>
								<li>FCP_Raw_Tato</li>
							</value>
						</li>
						<li Class="PatchOperationReplace">
							<xpath>/Defs/RecipeDef[defName="VCE_Ketchup"]/fixedIngredientFilter/thingDefs/li[text()="VCE_RawTomatoes"]</xpath>
							<value>
								<li>FCP_Raw_Tato</li>
							</value>
						</li>
						<li Class="PatchOperationReplace">
							<xpath>/Defs/RecipeDef[defName="VCE_Ketchup"]/description</xpath>
							<value>
								<description>Create ketchup from tatos. A thick sauce built from stewed wasteland tomatoes with the same sweet tang diners expect.</description>
							</value>
						</li>
						<li Class="PatchOperationReplace">
							<xpath>/Defs/RecipeDef[defName="VCE_HotSauce"]/ingredients/li/filter/thingDefs/li[text()="VCE_RawPepper"]</xpath>
							<value>
								<li>FCP_Raw_Jalapeno</li>
							</value>
						</li>
						<li Class="PatchOperationReplace">
							<xpath>/Defs/RecipeDef[defName="VCE_HotSauce"]/fixedIngredientFilter/thingDefs/li[text()="VCE_RawPepper"]</xpath>
							<value>
								<li>FCP_Raw_Jalapeno</li>
							</value>
						</li>
						<li Class="PatchOperationReplace">
							<xpath>/Defs/RecipeDef[defName="VCE_HotSauce"]/description</xpath>
							<value>
								<description>Create hot sauce from jalapenos. It still bites hard enough to make the eyes water while fitting better into wasteland cooking.</description>
							</value>
						</li>
					</operations>
				</match>
			</li>
		</operations>
	</Operation>
</Patch>