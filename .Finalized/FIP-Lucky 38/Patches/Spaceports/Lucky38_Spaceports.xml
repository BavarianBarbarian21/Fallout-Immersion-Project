<?xml version="1.0" encoding="utf-8"?>
<Patch>
	<!-- Spaceports hospitality-facing terminology -->
	<Operation Class="PatchOperationSequence" MayRequire="zal.spaceports">
		<success>Always</success>
		<operations>
			<li Class="PatchOperationReplace">
				<xpath>/Defs/ThingDef[defName="Spaceports_ShuttleLandingPad"]/label</xpath>
				<value>
					<label>charter shuttle pad</label>
				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>/Defs/ThingDef[defName="Spaceports_ShuttleLandingPad"]/description</xpath>
				<value>
					<description>An automated landing pad for charter shuttlecraft. Its beacon brings in patrons, visiting parties, and traders from across the region and beyond.</description>
				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>/LanguageData/Spaceports_JustGuests</xpath>
				<value>
					<Spaceports_JustGuests>Patrons only</Spaceports_JustGuests>
				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>/LanguageData/Spaceports_SingleVisitorLanding</xpath>
				<value>
					<Spaceports_SingleVisitorLanding>A charter shuttle from {1} is landing with a visiting patron. {PAWN_titleIndef} named {PAWN_nameFull} is onboard.</Spaceports_SingleVisitorLanding>
				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>/LanguageData/Spaceports_GroupVisitorsLanding</xpath>
				<value>
					<Spaceports_GroupVisitorsLanding>A charter shuttle from {0} is landing with visiting patrons.</Spaceports_GroupVisitorsLanding>
				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>/LanguageData/Spaceports_VisitorsLeaving</xpath>
				<value>
					<Spaceports_VisitorsLeaving>Visiting patrons from {0} are departing.</Spaceports_VisitorsLeaving>
				</value>
			</li>
		</operations>
	</Operation>
</Patch>