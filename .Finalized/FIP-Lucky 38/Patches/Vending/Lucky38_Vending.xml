<?xml version="1.0" encoding="utf-8"?>
<Patch>
	<!-- Vending machine terminology -->
	<Operation Class="PatchOperationSequence" MayRequire="Adamas.VendingMachines">
		<success>Always</success>
		<operations>
			<li Class="PatchOperationReplace">
				<xpath>/Defs/ThingDef[defName="VendingMachine"]/label</xpath>
				<value>
					<label>refreshment kiosk</label>
				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>/Defs/ThingDef[defName="VendingMachine"]/description</xpath>
				<value>
					<description>A pre-War kiosk stocked for patrons, casino traffic, and idle lounge crowds.</description>
				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>/Defs/ThingDef[defName="MedievalVendingMachine"]/label</xpath>
				<value>
					<label>service kiosk</label>
				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>/Defs/ThingDef[defName="MedievalVendingMachine"]/description</xpath>
				<value>
					<description>A low-tech kiosk for patrons that needs no electricity.</description>
				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>/LanguageData/VendingMachines_VendingMachine</xpath>
				<value>
					<VendingMachines_VendingMachine>refreshment kiosk</VendingMachines_VendingMachine>
				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>/LanguageData/VendingMachines_VendingMachineContains</xpath>
				<value>
					<VendingMachines_VendingMachineContains>Stock:</VendingMachines_VendingMachineContains>
				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>/LanguageData/VendingMachines_VendingMachineTotal</xpath>
				<value>
					<VendingMachines_VendingMachineTotal>Lifetime take:</VendingMachines_VendingMachineTotal>
				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>/LanguageData/VendingMachines_VendingMachineToggleDesc</xpath>
				<value>
					<VendingMachines_VendingMachineToggleDesc>Allow patrons to use this amenity.</VendingMachines_VendingMachineToggleDesc>
				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>/LanguageData/VendingMachines_SetPricing</xpath>
				<value>
					<VendingMachines_SetPricing>Set markup</VendingMachines_SetPricing>
				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>/LanguageData/VendingMachines_Free</xpath>
				<value>
					<VendingMachines_Free>complimentary stock</VendingMachines_Free>
				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>/LanguageData/VendingMachines_Medium</xpath>
				<value>
					<VendingMachines_Medium>house standard pricing</VendingMachines_Medium>
				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>/LanguageData/VendingMachines_Low</xpath>
				<value>
					<VendingMachines_Low>patron discount</VendingMachines_Low>
				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>/LanguageData/VendingMachines_High</xpath>
				<value>
					<VendingMachines_High>premium markup</VendingMachines_High>
				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>/LanguageData/EmptyAfterHours</xpath>
				<value>
					<EmptyAfterHours>Empty every refreshment kiosk after X hours</EmptyAfterHours>
				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>/LanguageData/EmptyAfterHoursTooltip</xpath>
				<value>
					<EmptyAfterHoursTooltip>If a refreshment kiosk has not been cleared after this many hours, someone will need to come collect the take.</EmptyAfterHoursTooltip>
				</value>
			</li>
		</operations>
	</Operation>
</Patch>