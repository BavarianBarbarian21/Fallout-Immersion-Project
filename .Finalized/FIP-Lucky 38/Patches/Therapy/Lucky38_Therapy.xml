<?xml version="1.0" encoding="utf-8"?>
<Patch>
	<!-- Therapy flavor pass -->
	<Operation Class="PatchOperationSequence" MayRequire="Orion.Therapy">
		<success>Always</success>
		<operations>
			<li Class="PatchOperationReplace">
				<xpath>/Defs/ThingDef[defName="TherapyCouch"]/label</xpath>
				<value>
					<label>counselor couch</label>
				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>/Defs/ThingDef[defName="TherapyCouch"]/description</xpath>
				<value>
					<description>A comfortable couch used for private counseling, decompression, and premium patron care.</description>
				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>/Defs/WorkTypeDef[defName="Therapist"]/labelShort</xpath>
				<value>
					<labelShort>Counsel</labelShort>
				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>/Defs/WorkTypeDef[defName="Therapist"]/pawnLabel</xpath>
				<value>
					<pawnLabel>counselor</pawnLabel>
				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>/Defs/WorkTypeDef[defName="Therapist"]/gerundLabel</xpath>
				<value>
					<gerundLabel>counseling</gerundLabel>
				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>/Defs/WorkTypeDef[defName="Therapist"]/description</xpath>
				<value>
					<description>Help colonists and patrons work through stress, trauma, and dependency in a private counseling suite.</description>
				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>/Defs/JobDef[defName="ReceiveTherapy"]/reportString</xpath>
				<value>
					<reportString>waiting for counseling.</reportString>
				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>/Defs/JobDef[defName="PerformTherapy"]/reportString</xpath>
				<value>
					<reportString>counseling TargetB.</reportString>
				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>/Defs/ThoughtDef[defName="TherapyRelieved"]/stages/li/label</xpath>
				<value>
					<label>load lifted</label>
				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>/Defs/ThoughtDef[defName="TherapyRelieved"]/stages/li/description</xpath>
				<value>
					<description>I had the chance to speak openly and leave lighter than I arrived.</description>
				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>/Defs/RoomRoleDef[defName="TherapyOffice"]/label</xpath>
				<value>
					<label>counseling suite</label>
				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>/LanguageData/CommandThingSetPatientsLabel</xpath>
				<value>
					<CommandThingSetPatientsLabel>Set clients</CommandThingSetPatientsLabel>
				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>/LanguageData/CommandBedSetPatientsDesc</xpath>
				<value>
					<CommandBedSetPatientsDesc>Assign this couch to specific colonists. If no one is assigned, anyone may use it for counseling.</CommandBedSetPatientsDesc>
				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>/LanguageData/ReceiveTherapyReport</xpath>
				<value>
					<ReceiveTherapyReport>Being counseled.</ReceiveTherapyReport>
				</value>
			</li>
		</operations>
	</Operation>
</Patch>