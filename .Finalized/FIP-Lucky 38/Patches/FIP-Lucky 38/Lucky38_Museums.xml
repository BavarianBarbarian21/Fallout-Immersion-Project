<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="PatchOperationSequence" MayRequire="Nightmare.Museums">
    <success>Always</success>
    <operations>
      <li Class="PatchOperationReplace">
        <xpath>/Defs/*[defName="Museums_Sign"]/description</xpath>
        <value>
          <description>A placard used to provide context and presentation for an exhibit piece.</description>
        </value>
      </li>
      <li Class="PatchOperationReplace">
        <xpath>/Defs/*[defName="Museums_Sign"]/label</xpath>
        <value>
          <label>exhibit placard</label>
        </value>
      </li>
      <li Class="PatchOperationReplace">
        <xpath>/Defs/*[defName="Museums_TourGatheringSpot"]/description</xpath>
        <value>
          <description>Designates the spot where patrons gather and wait for a guided gallery tour to begin. A room must have a tour start spot to count as an exhibit gallery.</description>
        </value>
      </li>
      <li Class="PatchOperationReplace">
        <xpath>/Defs/*[defName="Museums_TourGatheringSpot"]/label</xpath>
        <value>
          <label>gallery tour gathering spot</label>
        </value>
      </li>
    </operations>
  </Operation>
</Patch>