<?xml version="1.0" encoding="utf-8"?>
<Patch>
	<Operation Class="PatchOperationSequence" MayRequire="VanillaExpanded.VBrewECandT">
		<success>Always</success>
		<operations>
			<li Class="PatchOperationFindMod">
				<mods>
					<li>Vanilla Cooking Expanded</li>
				</mods>
				<match Class="PatchOperationSequence" MayRequire="Rick.FCP.Plants">
					<success>Always</success>
					<operations>
						<li Class="PatchOperationReplace">
							<xpath>/Defs/RecipeDef[defName="VBE_MakeCoffeeFast"]/ingredients/li/filter/thingDefs/li[text()="VBE_RawCoffee"]</xpath>
							<value>
								<li>FCP_Raw_Honey_Mesquite</li>
							</value>
						</li>
						<li Class="PatchOperationReplace">
							<xpath>/Defs/RecipeDef[defName="VBE_MakeCoffeeFast"]/fixedIngredientFilter/thingDefs/li[text()="VBE_RawCoffee"]</xpath>
							<value>
								<li>FCP_Raw_Honey_Mesquite</li>
							</value>
						</li>
						<li Class="PatchOperationReplace">
							<xpath>/Defs/RecipeDef[defName="VBE_MakeCoffeeFast"]/defaultIngredientFilter/thingDefs/li[text()="VBE_RawCoffee"]</xpath>
							<value>
								<li>FCP_Raw_Honey_Mesquite</li>
							</value>
						</li>
						<li Class="PatchOperationReplace">
							<xpath>/Defs/RecipeDef[defName="VBE_MakeTeaFast"]/ingredients/li/filter/thingDefs/li[text()="VBE_RawTea"]</xpath>
							<value>
								<li>FCP_Raw_Mutated_Fern</li>
							</value>
						</li>
						<li Class="PatchOperationReplace">
							<xpath>/Defs/RecipeDef[defName="VBE_MakeTeaFast"]/fixedIngredientFilter/thingDefs/li[text()="VBE_RawTea"]</xpath>
							<value>
								<li>FCP_Raw_Mutated_Fern</li>
							</value>
						</li>
						<li Class="PatchOperationReplace">
							<xpath>/Defs/RecipeDef[defName="VBE_MakeTeaFast"]/defaultIngredientFilter/thingDefs/li[text()="VBE_RawTea"]</xpath>
							<value>
								<li>FCP_Raw_Mutated_Fern</li>
							</value>
						</li>
						<li Class="PatchOperationReplace">
							<xpath>/Defs/ThingDef[defName="VBE_MintPlant"]/label</xpath>
							<value>
								<label>carrot flower patch</label>
							</value>
						</li>
						<li Class="PatchOperationReplace">
							<xpath>/Defs/ThingDef[defName="VBE_MintPlant"]/description</xpath>
							<value>
								<description>A stand of carrot flowers used for bright herbal garnish in teas and coffee blends.</description>
							</value>
						</li>
						<li Class="PatchOperationReplace">
							<xpath>/Defs/ThingDef[defName="VBE_MintPlant"]/plant/harvestedThingDef</xpath>
							<value>
								<harvestedThingDef>FCP_Raw_Carrot_Flower</harvestedThingDef>
							</value>
						</li>
						<li Class="PatchOperationReplace">
							<xpath>/Defs/ThingDef[defName="VBE_MintPlant"]/plant/sowTags</xpath>
							<value>
								<sowTags />
							</value>
						</li>
						<li Class="PatchOperationReplace">
							<xpath>/Defs/ThingDef[defName="VBE_MintLeaves"]/label</xpath>
							<value>
								<label>carrot flowers</label>
							</value>
						</li>
						<li Class="PatchOperationReplace">
							<xpath>/Defs/ThingDef[defName="VBE_MintLeaves"]/description</xpath>
							<value>
								<description>Bright carrot flowers used to freshen brewed drinks and garnish wasteland dishes.</description>
							</value>
						</li>
						<li Class="PatchOperationReplace">
							<xpath>/Defs/RecipeDef[defName="VBE_BrewMintCoffee"]/ingredients/li/filter/thingDefs/li[text()="VBE_MintLeaves"]</xpath>
							<value>
								<li>FCP_Raw_Carrot_Flower</li>
							</value>
						</li>
						<li Class="PatchOperationReplace">
							<xpath>/Defs/RecipeDef[defName="VBE_BrewMintCoffee"]/fixedIngredientFilter/thingDefs/li[text()="VBE_MintLeaves"]</xpath>
							<value>
								<li>FCP_Raw_Carrot_Flower</li>
							</value>
						</li>
						<li Class="PatchOperationReplace">
							<xpath>/Defs/RecipeDef[defName="VBE_BrewMintCoffee"]/defaultIngredientFilter/thingDefs/li[text()="VBE_MintLeaves"]</xpath>
							<value>
								<li>FCP_Raw_Carrot_Flower</li>
							</value>
						</li>
						<li Class="PatchOperationReplace">
							<xpath>/Defs/RecipeDef[defName="VBE_MakeMintTea"]/ingredients/li/filter/thingDefs/li[text()="VBE_MintLeaves"]</xpath>
							<value>
								<li>FCP_Raw_Carrot_Flower</li>
							</value>
						</li>
						<li Class="PatchOperationReplace">
							<xpath>/Defs/RecipeDef[defName="VBE_MakeMintTea"]/fixedIngredientFilter/thingDefs/li[text()="VBE_MintLeaves"]</xpath>
							<value>
								<li>FCP_Raw_Carrot_Flower</li>
							</value>
						</li>
						<li Class="PatchOperationReplace">
							<xpath>/Defs/RecipeDef[defName="VBE_MakeMintTea"]/defaultIngredientFilter/thingDefs/li[text()="VBE_MintLeaves"]</xpath>
							<value>
								<li>FCP_Raw_Carrot_Flower</li>
							</value>
						</li>
					</operations>
				</match>
			</li>
			<li Class="PatchOperationFindMod">
				<mods>
					<li>Vanilla Plants Expanded</li>
				</mods>
				<match Class="PatchOperationSequence" MayRequire="Rick.FCP.Plants">
					<success>Always</success>
					<operations>
						<li Class="PatchOperationReplace">
							<xpath>/Defs/RecipeDef[defName="VBE_BrewLemonCoffee"]/ingredients/li/filter/thingDefs/li[text()="VCE_RawLemon"]</xpath>
							<value>
								<li>FCP_Raw_Mutfruit</li>
							</value>
						</li>
						<li Class="PatchOperationReplace">
							<xpath>/Defs/RecipeDef[defName="VBE_BrewLemonCoffee"]/fixedIngredientFilter/thingDefs/li[text()="VCE_RawLemon"]</xpath>
							<value>
								<li>FCP_Raw_Mutfruit</li>
							</value>
						</li>
						<li Class="PatchOperationReplace">
							<xpath>/Defs/RecipeDef[defName="VBE_BrewLemonCoffee"]/defaultIngredientFilter/thingDefs/li[text()="VCE_RawLemon"]</xpath>
							<value>
								<li>FCP_Raw_Mutfruit</li>
							</value>
						</li>
						<li Class="PatchOperationReplace">
							<xpath>/Defs/RecipeDef[defName="VBE_MakeLemonTea"]/ingredients/li/filter/thingDefs/li[text()="VCE_RawLemon"]</xpath>
							<value>
								<li>FCP_Raw_Mutfruit</li>
							</value>
						</li>
						<li Class="PatchOperationReplace">
							<xpath>/Defs/RecipeDef[defName="VBE_MakeLemonTea"]/fixedIngredientFilter/thingDefs/li[text()="VCE_RawLemon"]</xpath>
							<value>
								<li>FCP_Raw_Mutfruit</li>
							</value>
						</li>
						<li Class="PatchOperationReplace">
							<xpath>/Defs/RecipeDef[defName="VBE_MakeLemonTea"]/defaultIngredientFilter/thingDefs/li[text()="VCE_RawLemon"]</xpath>
							<value>
								<li>FCP_Raw_Mutfruit</li>
							</value>
						</li>
						<li Class="PatchOperationReplace">
							<xpath>/Defs/RecipeDef[defName="VBE_MixLemonade"]/ingredients/li/filter/thingDefs/li[text()="VCE_RawLemon"]</xpath>
							<value>
								<li>FCP_Raw_Mutfruit</li>
							</value>
						</li>
					</operations>
				</match>
			</li>
		</operations>
	</Operation>
</Patch>