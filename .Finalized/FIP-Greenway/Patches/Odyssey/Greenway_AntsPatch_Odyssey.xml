<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <!-- Odyssey-only insect replacements -->
  <Operation Class="PatchOperationSequence">
    <operations>
      <li Class="PatchOperationReplace" MayRequire="Ludeon.RimWorld.Odyssey">
        <xpath>Defs/ThingDef[defName="Larva"]/description</xpath>
        <value>
          <description>The juvenile stage of a giant ant. Ant larvae are cared for by worker ants and will eventually grow into powerful hive members.</description>
        </value>
      </li>
      <li Class="PatchOperationReplace" MayRequire="Ludeon.RimWorld.Odyssey">
        <xpath>Defs/ThingDef[defName="HiveQueen"]/label</xpath>
        <value>
          <label>giant ant queen</label>
        </value>
      </li>
      <li Class="PatchOperationReplace" MayRequire="Ludeon.RimWorld.Odyssey">
        <xpath>Defs/ThingDef[defName="HiveQueen"]/description</xpath>
        <value>
          <description>The queen of a giant ant hive. She is responsible for laying eggs and directing the colony's growth and defense.</description>
        </value>
      </li>
      <li Class="PatchOperationReplace" MayRequire="Ludeon.RimWorld.Odyssey">
        <xpath>Defs/PawnKindDef[defName="HiveQueen"]/label</xpath>
        <value>
          <label>giant ant queen</label>
        </value>
      </li>
      <li Class="PatchOperationReplace" MayRequire="Ludeon.RimWorld.Odyssey">
        <xpath>Defs/ThingDef[defName="Locust"]/label</xpath>
        <value>
          <label>giant ant drone</label>
        </value>
      </li>
      <li Class="PatchOperationReplace" MayRequire="Ludeon.RimWorld.Odyssey">
        <xpath>Defs/ThingDef[defName="Locust"]/description</xpath>
        <value>
          <description>A giant ant capable of flight. Ant drones only live to mate with the queen.</description>
        </value>
      </li>
      <li Class="PatchOperationReplace" MayRequire="Ludeon.RimWorld.Odyssey">
        <xpath>Defs/PawnKindDef[defName="Locust"]/label</xpath>
        <value>
          <label>giant ant drone</label>
        </value>
      </li>
      <li Class="PatchOperationReplace" MayRequire="Ludeon.RimWorld.Odyssey">
        <xpath>Defs/PawnKindDef[defName="Locust"]/lifeStages</xpath>
        <value>
          <lifeStages>
            <li>
              <bodyGraphicData>
                <texPath>Greenway/Ants/AntWinged/Black/AntWinged_Black</texPath>
                <drawSize>1.25</drawSize>
              </bodyGraphicData>
              <dessicatedBodyGraphicData>
                <texPath>Greenway/Ants/AntWinged/AntWinged_Dessicated</texPath>
                <drawSize>1.25</drawSize>
              </dessicatedBodyGraphicData>
            </li>
            <li>
              <bodyGraphicData>
                <texPath>Greenway/Ants/AntWinged/Black/AntWinged_Black</texPath>
                <drawSize>1.45</drawSize>
              </bodyGraphicData>
              <dessicatedBodyGraphicData>
                <texPath>Greenway/Ants/AntWinged/AntWinged_Dessicated</texPath>
                <drawSize>1.45</drawSize>
              </dessicatedBodyGraphicData>
            </li>
            <li>
              <bodyGraphicData>
                <texPath>Greenway/Ants/AntWinged/Black/AntWinged_Black</texPath>
                <drawSize>1.65</drawSize>
                <shadowData>
                  <volume>(0.2, 0.3, 0.2)</volume>
                  <offset>(0,0,0)</offset>
                </shadowData>
              </bodyGraphicData>
              <dessicatedBodyGraphicData>
                <texPath>Greenway/Ants/AntWinged/AntWinged_Dessicated</texPath>
                <drawSize>1.65</drawSize>
              </dessicatedBodyGraphicData>
            </li>
          </lifeStages>
        </value>
      </li>
      <li Class="PatchOperationReplace" MayRequire="Ludeon.RimWorld.Odyssey">
        <xpath>Defs/PawnKindDef[defName="HiveQueen"]/lifeStages</xpath>
        <value>
          <lifeStages>
            <li>
              <bodyGraphicData>
                <texPath>Greenway/Ants/AntQueen/Black/AntQueen_Black</texPath>
                <drawSize>4</drawSize>
              </bodyGraphicData>
              <dessicatedBodyGraphicData>
                <texPath>Greenway/Ants/AntQueen/AntQueen_Dessicated</texPath>
                <drawSize>4</drawSize>
              </dessicatedBodyGraphicData>
            </li>
          </lifeStages>
        </value>
      </li>
    </operations>
  </Operation>
</Patch>