<?xml version="1.0" encoding="utf-8" ?>
<Patch>
  <Operation Class="PatchOperationSequence">
    <operations>
      <li Class="PatchOperationReplace">
        <xpath>/Defs/MemeDef[defName="VME_Astrology"]/label</xpath>
        <value>
          <label>sky omens</label>
        </value>
        <success>Always</success>
        <MayRequire>VanillaExpanded.VMemesE</MayRequire>
      </li>
      <li Class="PatchOperationReplace">
        <xpath>/Defs/MemeDef[defName="VME_Astrology"]/description</xpath>
        <value>
          <description>We are guided by signs in the heavens, old-world charts, and the omens they cast over the wastes.</description>
        </value>
        <success>Always</success>
        <MayRequire>VanillaExpanded.VMemesE</MayRequire>
      </li>
      <li Class="PatchOperationReplace">
        <xpath>/Defs/MemeDef[defName="VME_GodEmperor"]/label</xpath>
        <value>
          <label>cult of personality</label>
        </value>
        <success>Always</success>
        <MayRequire>VanillaExpanded.VMemesE</MayRequire>
      </li>
      <li Class="PatchOperationReplace">
        <xpath>/Defs/MemeDef[defName="VME_GodEmperor"]/description</xpath>
        <value>
          <description>Our leader must be obeyed as the living embodiment of the cause.</description>
        </value>
        <success>Always</success>
        <MayRequire>VanillaExpanded.VMemesE</MayRequire>
      </li>
      <li Class="PatchOperationReplace">
        <xpath>/Defs/IdeoPresetDef[defName="VME_GodKing_Radicals"]/label</xpath>
        <value>
          <label>cult radicals</label>
        </value>
        <success>Always</success>
        <MayRequire>VanillaExpanded.VMemesE</MayRequire>
      </li>
      <li Class="PatchOperationReplace">
        <xpath>/Defs/IdeoPresetDef[defName="VME_GodKing_Radicals"]/description</xpath>
        <value>
          <description>The iron rule of our supreme leader should never come into question. If those who oppose us will not kneel, we will break them until they do.</description>
        </value>
        <success>Always</success>
        <MayRequire>VanillaExpanded.VMemesE</MayRequire>
      </li>
      <li Class="PatchOperationReplace">
        <xpath>/Defs/IdeoPresetDef[defName="VME_Cosmic_Cultists"]/label</xpath>
        <value>
          <label>omen cultists</label>
        </value>
        <success>Always</success>
        <MayRequire>VanillaExpanded.VMemesE</MayRequire>
      </li>
      <li Class="PatchOperationReplace">
        <xpath>/Defs/IdeoPresetDef[defName="VME_Cosmic_Cultists"]/description</xpath>
        <value>
          <description>The lights above and the ruined world below both speak in signs. We read the sky for warnings, promises, and the fate waiting out in the wastes.</description>
        </value>
        <success>Always</success>
        <MayRequire>VanillaExpanded.VMemesE</MayRequire>
      </li>
      <li Class="PatchOperationReplace">
