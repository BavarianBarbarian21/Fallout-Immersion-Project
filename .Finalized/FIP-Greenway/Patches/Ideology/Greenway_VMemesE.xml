        <xpath>/Defs/IdeoPresetDef[defName="VME_Nordic_Matriarchy"]/label</xpath>
        <value>
          <label>raider matriarchy</label>
        </value>
        <success>Always</success>
        <MayRequire>VanillaExpanded.VMemesE</MayRequire>
      </li>
      <li Class="PatchOperationReplace">
        <xpath>/Defs/IdeoPresetDef[defName="VME_Nordic_Matriarchy"]/description</xpath>
        <value>
          <description>Through winter storms and broken coastlines, our shield-mothers lead the people. Die with honor or answer to the women who keep the warbands together.</description>
        </value>
        <success>Always</success>
        <MayRequire>VanillaExpanded.VMemesE</MayRequire>
      </li>
    </operations>
