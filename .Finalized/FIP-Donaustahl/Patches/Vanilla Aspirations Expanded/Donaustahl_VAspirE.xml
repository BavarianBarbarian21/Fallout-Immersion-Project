      </li>
      <li Class="PatchOperationReplace" MayRequire="VanillaExpanded.VanillaAspirationsExpanded,Ludeon.RimWorld.Royalty">
        <xpath>/Defs/VAspirE.AspirationDef[defName="VAspirE_BecomeNoble"]/satisfiedWhenText</xpath>
        <value>
          <satisfiedWhenText>{0} earns a formal elite rank.</satisfiedWhenText>
        </value>
      </li>
      <li Class="PatchOperationReplace" MayRequire="VanillaExpanded.VanillaAspirationsExpanded,Ludeon.RimWorld.Royalty">
        <xpath>/Defs/VAspirE.AspirationDef[defName="VAspirE_AttendSpeech"]/label</xpath>
        <value>
          <label>attend a presidential speech</label>
        </value>
      </li>
      <li Class="PatchOperationReplace" MayRequire="VanillaExpanded.VanillaAspirationsExpanded,Ludeon.RimWorld.Royalty">
        <xpath>/Defs/VAspirE.AspirationDef[defName="VAspirE_AttendSpeech"]/description</xpath>
        <value>
          <description>{0} wants to be there when the president gives a rousing speech.</description>
        </value>
      </li>
    </operations>
  </Operation>
</Patch>