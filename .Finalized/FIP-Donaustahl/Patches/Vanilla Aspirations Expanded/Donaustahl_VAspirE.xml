    <success>Always</success>
    <operations>
      <li Class="PatchOperationReplace" MayRequire="VanillaExpanded.VanillaAspirationsExpanded,Ludeon.RimWorld.Royalty">
        <xpath>/Defs/VAspirE.AspirationDef[defName="VAspirE_BecomeNoble"]/label</xpath>
        <value>
          <label>join the Enclave</label>
        </value>
      </li>
      <li Class="PatchOperationReplace" MayRequire="VanillaExpanded.VanillaAspirationsExpanded,Ludeon.RimWorld.Royalty">
        <xpath>/Defs/VAspirE.AspirationDef[defName="VAspirE_BecomeNoble"]/description</xpath>
        <value>
          <description>{0} wants the privileges, pull, and ceremony that come with joining the Enclave.</description>
