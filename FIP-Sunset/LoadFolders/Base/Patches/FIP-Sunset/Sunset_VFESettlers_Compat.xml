<?xml version="1.0" encoding="utf-8"?>
<Patch>
	<Operation Class="PatchOperationSequence" MayRequire="OskarPotocki.VanillaFactionsExpanded.SettlersModule">
		<success>Always</success>
		<operations>
			<li Class="PatchOperationAdd"><xpath>/Defs/FactionDef[defName="SettlerCivil"]</xpath><value><settlementGenerationWeight>0</settlementGenerationWeight><requiredCountAtGameStart>0</requiredCountAtGameStart><canMakeRandomly>false</canMakeRandomly></value></li>
			<li Class="PatchOperationAdd"><xpath>/Defs/FactionDef[defName="SettlerRough"]</xpath><value><settlementGenerationWeight>0</settlementGenerationWeight><requiredCountAtGameStart>0</requiredCountAtGameStart><canMakeRandomly>false</canMakeRandomly></value></li>
			<li Class="PatchOperationAdd"><xpath>/Defs/FactionDef[defName="SettlerSavage"]</xpath><value><settlementGenerationWeight>0</settlementGenerationWeight><requiredCountAtGameStart>0</requiredCountAtGameStart><canMakeRandomly>false</canMakeRandomly></value></li>
			<li Class="PatchOperationReplace"><xpath>/Defs/FactionDef[defName="SettlerCivil"]/maxConfigurableAtWorldCreation</xpath><value><maxConfigurableAtWorldCreation>0</maxConfigurableAtWorldCreation></value></li>
			<li Class="PatchOperationReplace"><xpath>/Defs/FactionDef[defName="SettlerRough"]/maxConfigurableAtWorldCreation</xpath><value><maxConfigurableAtWorldCreation>0</maxConfigurableAtWorldCreation></value></li>
			<li Class="PatchOperationReplace"><xpath>/Defs/FactionDef[defName="SettlerSavage"]/maxConfigurableAtWorldCreation</xpath><value><maxConfigurableAtWorldCreation>0</maxConfigurableAtWorldCreation></value></li>
		</operations>
	</Operation>
	<Operation Class="PatchOperationSequence" MayRequire="OskarPotocki.VanillaFactionsExpanded.SettlersModule">
		<success>Always</success>
		<operations>
			<li Class="PatchOperationReplace" MayRequire="FIP.HHTools"><xpath>Defs/FactionDef[@Name="HHTools_Settler_Democratic"]/settlementTexturePath</xpath><value><settlementTexturePath>World/WorldObjects/Expanding/SettlersSettlement</settlementTexturePath></value></li>
			<li Class="PatchOperationReplace" MayRequire="FIP.HHTools"><xpath>Defs/FactionDef[@Name="HHTools_Settler_Despotic"]/settlementTexturePath</xpath><value><settlementTexturePath>World/WorldObjects/Expanding/SettlersSettlement</settlementTexturePath></value></li>
			<li Class="PatchOperationReplace" MayRequire="Rick.FCP.Animals,FIP.HHTools"><xpath>Defs/FactionDef[@Name="HHTools_Settler_Democratic"]/pawnGroupMakers/li[kindDef="Trader"]/carriers/Muffalo</xpath><value><FCP_Animal_Bighorner>6</FCP_Animal_Bighorner></value></li>
			<li Class="PatchOperationReplace" MayRequire="Rick.FCP.Animals,FIP.HHTools"><xpath>Defs/FactionDef[@Name="HHTools_Settler_Despotic"]/pawnGroupMakers/li[kindDef="Trader"]/carriers/Muffalo</xpath><value><FCP_Animal_Bighorner>6</FCP_Animal_Bighorner></value></li>
			<li Class="PatchOperationAdd" MayRequire="FIP.HHTools"><xpath>Defs/PawnKindDef[defName="HHTools_Settlement_Civilian"]/weaponTags</xpath><value><li>SimpleGun</li><li>GrenadeDestructive</li></value></li>
			<li Class="PatchOperationAdd" MayRequire="FIP.HHTools"><xpath>Defs/PawnKindDef[defName="HHTools_Settlement_Civilian"]/apparelTags</xpath><value><li>Outlander</li><li>NeolithicRangedBasic</li></value></li>
			<li Class="PatchOperationAdd" MayRequire="FIP.HHTools"><xpath>Defs/PawnKindDef[defName="HHTools_Settlement_Fighter"]/weaponTags</xpath><value><li>SimpleGun</li><li>Revolver</li></value></li>
			<li Class="PatchOperationAdd" MayRequire="FIP.HHTools"><xpath>Defs/PawnKindDef[defName="HHTools_Settlement_Fighter"]/apparelTags</xpath><value><li>Outlander</li></value></li>
			<li Class="PatchOperationAdd" MayRequire="FIP.HHTools"><xpath>Defs/PawnKindDef[defName="HHTools_Settlement_Trader"]/weaponTags</xpath><value><li>SimpleGun</li><li>Revolver</li></value></li>
			<li Class="PatchOperationAdd" MayRequire="FIP.HHTools"><xpath>Defs/PawnKindDef[defName="HHTools_Settlement_Trader"]/apparelTags</xpath><value><li>Outlander</li></value></li>
			<li Class="PatchOperationAdd" MayRequire="FIP.HHTools"><xpath>Defs/PawnKindDef[defName="HHTools_Settlement_Leader"]/weaponTags</xpath><value><li>SimpleGun</li><li>Revolver</li></value></li>
			<li Class="PatchOperationAdd" MayRequire="FIP.HHTools"><xpath>Defs/PawnKindDef[defName="HHTools_Settlement_Leader"]/apparelTags</xpath><value><li>Outlander</li></value></li>
			<li Class="PatchOperationAdd" MayRequire="FIP.HHTools"><xpath>Defs/PawnKindDef[starts-with(defName,"HHTools_") and contains(defName,"_Settlement_") and not(contains(defName,"_Child"))]/weaponTags</xpath><value><li>SimpleGun</li><li>Revolver</li><li>IndustrialGunAdvanced</li><li>GrenadeDestructive</li></value></li>
			<li Class="PatchOperationAdd" MayRequire="FIP.HHTools"><xpath>Defs/PawnKindDef[starts-with(defName,"HHTools_") and contains(defName,"_Settlement_")]/apparelTags</xpath><value><li>Outlander</li><li>IndustrialMilitaryBasic</li><li>IndustrialMilitaryAdvanced</li><li>BeltDefensePop</li></value></li>
			<li Class="PatchOperationReplace" MayRequire="Rick.FCP.Animals"><xpath>Defs/FactionDef[defName="SettlerCivil"]/pawnGroupMakers/li[kindDef="Trader"]/carriers/Muffalo</xpath><value><FCP_Animal_Bighorner>10</FCP_Animal_Bighorner></value></li>
			<li Class="PatchOperationReplace" MayRequire="Rick.FCP.Animals"><xpath>Defs/FactionDef[defName="SettlerRough"]/pawnGroupMakers/li[kindDef="Trader"]/carriers/Muffalo</xpath><value><FCP_Animal_Bighorner>10</FCP_Animal_Bighorner></value></li>
			<li Class="PatchOperationReplace"><xpath>Defs/QuestScriptDef[defName="VFES_Wanted"]/rootSelectionWeight</xpath><value><rootSelectionWeight>0</rootSelectionWeight></value></li>
			<li Class="PatchOperationReplace"><xpath>Defs/QuestScriptDef[defName="VFES_CaravanRaid"]/rootSelectionWeight</xpath><value><rootSelectionWeight>0</rootSelectionWeight></value></li>
			<li Class="PatchOperationAdd"><xpath>Defs/ScenarioDef[defName="VFES_Bandits"]/scenario</xpath><value><showInUI>false</showInUI></value></li>
			<li Class="PatchOperationRemove"><xpath>Defs/ThinkTreeDef[defName="Muffalo_PreMain" and thinkRoot/@Class="VFE_Settlers.ThinkNodes.ThinkNode_ConditionalChemshinedMuffalo"]</xpath></li>
		</operations>
	</Operation>
	<Operation Class="PatchOperationSequence" MayRequire="OskarPotocki.VanillaFactionsExpanded.SettlersModule">
		<success>Always</success>
		<operations>
			<li Class="PatchOperationReplace"><xpath>/Defs/*[defName="VFES_ChemfuelToChemshine"]/labelOverride</xpath><value><labelOverride>Ferment 50 chemfuel into 25 rot gut</labelOverride></value></li>
		</operations>
	</Operation>
</Patch>
