<?xml version="1.0" encoding="utf-8"?>
<Patch>

  <!-- RulePack: rename 'empire' token to 'whitespring' for namers -->
  <Operation Class="PatchOperationReplace">
    <xpath>Defs/RulePackDef[defName="NamerFactionEmpire"]/rulePack/rulesStrings</xpath>
    <value>
      <rulesStrings>
        <li>r_name(p=3)->The Whitespring</li>
        <li>r_name(p=2)->The Whitespring Bunker</li>
        <li>r_name(p=3)->The Enclave</li>
        <li>r_name(p=2)->The Appalachia Enclave
        <li>r_name(p=1)->The Whitespring Enclave</li>
        <li>r_name(p=1)->The Appalachia Bunker</li>
      </rulesStrings>
    </value>
  </Operation>

</Patch>
