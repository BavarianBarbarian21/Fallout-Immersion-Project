<?xml version="1.0" encoding="utf-8"?>
<Patch>

  <!-- Faction: Empire -> Whitespring Enclave -->
  <Operation Class="PatchOperationReplace">
    <xpath>Defs/FactionDef[defName="Empire"]/label</xpath>
    <value>
      <label>Whitespring Enclave</label>
    </value>
  </Operation>

  <Operation Class="PatchOperationReplace">
    <xpath>Defs/FactionDef[defName="Empire"]/description</xpath>
    <value>
      <description>A militant enclave of survivors claiming to represent the Appalachia scientific order. They pursue research into cryptids and hoard intelligence and technology for the Whitespring Enclave.

The Enclave enforces its authority with ranks and privileges rather than traditional royal titles, and will often barter their intel and resources for loyalty.</description>
    </value>
  </Operation>

  <Operation Class="PatchOperationReplace">
    <xpath>Defs/FactionDef[defName="Empire"]/pawnSingular</xpath>
    <value>
      <pawnSingular>Whitespring agent</pawnSingular>
    </value>
  </Operation>

  <Operation Class="PatchOperationReplace">
    <xpath>Defs/FactionDef[defName="Empire"]/pawnsPlural</xpath>
    <value>
      <pawnsPlural>Whitespring agents</pawnsPlural>
    </value>
  </Operation>

  <Operation Class="PatchOperationReplace">
    <xpath>Defs/FactionDef[defName="Empire"]/leaderTitle</xpath>
    <value>
      <leaderTitle>president</leaderTitle>
    </value>
  </Operation>

  <Operation Class="PatchOperationReplace">
    <xpath>Defs/FactionDef[defName="Empire"]/royalFavorLabel</xpath>
    <value>
      <royalFavorLabel>intel</royalFavorLabel>
    </value>
  </Operation>

  <!-- Ship / Shuttle -->
  <Operation Class="PatchOperationReplace">
    <xpath>Defs/ThingDef[defName="ShipLandingBeacon"]/label</xpath>
    <value>
      <label>Vertibird Landing Beacon</label>
    </value>
  </Operation>

  <Operation Class="PatchOperationReplace">
    <xpath>Defs/TransportShipDef[defName="Ship_Shuttle"]/label</xpath>
    <value>
      <label>Whitespring Vertibird</label>
    </value>
  </Operation>

  <!-- Nature shrines / animus stone -> cryptid equivalents -->
  <Operation Class="PatchOperationReplace">
    <xpath>Defs/ThingDef[defName="NatureShrine_Small"]/label</xpath>
    <value>
      <label>small cryptic shrine</label>
    </value>
  </Operation>
  <Operation Class="PatchOperationReplace">
    <xpath>Defs/ThingDef[defName="NatureShrine_Small"]/description</xpath>
    <value>
      <description>A small shrine used by cryptid researchers to focus meditation and study. These shrines strengthen cryptid-focused meditation for Whitespring operatives.</description>
    </value>
  </Operation>

  <Operation Class="PatchOperationReplace">
    <xpath>Defs/ThingDef[defName="NatureShrine_Large"]/label</xpath>
    <value>
      <label>large cryptic shrine</label>
    </value>
  </Operation>
  <Operation Class="PatchOperationReplace">
    <xpath>Defs/ThingDef[defName="NatureShrine_Large"]/description</xpath>
    <value>
      <description>A large shrine for honoring cryptid forces. Whitespring operatives use these to amplify cryptid focus during ritualized study.</description>
    </value>
  </Operation>

  <Operation Class="PatchOperationReplace">
    <xpath>Defs/ThingDef[defName="AnimusStone"]/label</xpath>
    <value>
      <label>cryptic stone</label>
    </value>
  </Operation>
  <Operation Class="PatchOperationReplace">
    <xpath>Defs/ThingDef[defName="AnimusStone"]/description</xpath>
    <value>
      <description>A resonant cryptic stone studied by Whitespring researchers. It increases cryptid meditation focus and is often used in enclave research facilities.</description>
    </value>
  </Operation>

</Patch>
