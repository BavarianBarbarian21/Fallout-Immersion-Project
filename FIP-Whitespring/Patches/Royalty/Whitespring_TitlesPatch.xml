<?xml version="1.0" encoding="utf-8"?>
<Patch>

  <!-- RulePack: rename 'empire' token to 'whitespring' for namers -->
  <Operation Class="PatchOperationReplace">
    <xpath>Defs/RulePackDef[defName="NamerFactionEmpire"]/rulePack/rulesStrings</xpath>
    <value>
      <rulesStrings>
        <li>r_name(p=2)->[whitespring] of [ofThing]</li>
        <li>r_name(p=2)->The [whitespring] of [ofThing]</li>
        <li>r_name->The Exodus [whitespring]</li>
        <li>r_name->The Refugee [whitespring]</li>
        <li>r_name->The Broken [whitespring]</li>
        <li>r_name->The Shattered [whitespring]</li>
        <li>r_name->The Fallen [whitespring]</li>
        <li>r_name->The [Color] [whitespring]</li>

        <li>whitespring(p=4)->Whitespring Enclave</li>
        <li>whitespring->Whitespring</li>
        <li>whitespring->Enclave</li>
        <li>whitespring->Dominion</li>
        <li>whitespring->Sovereignty</li>

        <li>ofThing(p=4)->[WordImperial]</li>
        <li>ofThing->the Sun</li>
        <li>ofThing->the Moon</li>
        <li>ofThing->the Universe</li>
        <li>ofThing->God</li>
        <li>ofThing->Perfection</li>
        <li>ofThing->Eternity</li>
        <li>ofThing->the Spirit</li>
      </rulesStrings>
    </value>
  </Operation>

</Patch>
