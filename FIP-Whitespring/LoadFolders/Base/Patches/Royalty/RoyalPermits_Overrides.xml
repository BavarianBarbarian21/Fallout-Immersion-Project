<?xml version="1.0" encoding="utf-8"?>
<Patch MayRequire="Ludeon.RimWorld.Royalty">

  <!-- Change Silver to Gold in SilverDrop permit -->
  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/RoyalTitlePermitDef[defName="SilverDrop"]/royalAid/itemsToDrop/Silver</xpath>
    <value>
      <Gold>500</Gold>
    </value>
  </Operation>

</Patch>
