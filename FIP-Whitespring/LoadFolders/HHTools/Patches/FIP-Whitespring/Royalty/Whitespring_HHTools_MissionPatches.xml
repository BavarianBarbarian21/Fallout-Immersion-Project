<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <!-- Mission patches for HHTools integration -->
  
  <!-- Mission_BanditCamp - Replace faction lists with Whitespring and HHTools factions -->
  <Operation Class="PatchOperationReplace" MayRequire="FundyMods.HHTools">
    <xpath>/Defs/QuestScriptDef[defName="Mission_BanditCamp"]/root/factionsToDrawLeaderFrom</xpath>
    <value>
      <factionsToDrawLeaderFrom>
        <li>Empire</li>
      </factionsToDrawLeaderFrom>
    </value>
  </Operation>

  <Operation Class="PatchOperationReplace" MayRequire="FundyMods.HHTools">
    <xpath>/Defs/QuestScriptDef[defName="Mission_BanditCamp"]/root/siteFactions</xpath>
    <value>
      <siteFactions>
        <li>HHTools_Arizona_Raider</li>
        <li>HHTools_California_Raider</li>
        <li>HHTools_Cascadia_Raider</li>
        <li>HHTools_Texico_Raider</li>
        <li>HHTools_Mutant_Army</li>
      </siteFactions>
    </value>
  </Operation>

</Patch>
