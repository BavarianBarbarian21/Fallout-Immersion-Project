  "Part3|DefInjected/VanillaPsycastsExpanded.PsycasterPathDef/VanillaExpanded_VPE_Puppeteer.xml|VPEP_Puppeteer.label": "Marionettenspieler",
  "Part3|DefInjected/VanillaPsycastsExpanded.PsycasterPathDef/VanillaExpanded_VPsycastsE.xml|VPE_Archon.description": "Der Archon-Pfad ist der Weg eines psychischen Anf\u00fchrers, der verschiedene Verst\u00e4rkungen f\u00fcr die gesamte Kolonie bietet, aber auch mit eiserner Faust regiert. Es ist auch ein Pfad, der es erlaubt, feindliche Psycaster zu drainieren und auf diese Weise Psycast-Stufen zu gewinnen.",
  "Part3|DefInjected/VanillaPsycastsExpanded.PsycasterPathDef/VanillaExpanded_VPsycastsE.xml|VPE_Archon.label": "Archon",
  "Part3|DefInjected/VanillaPsycastsExpanded.PsycasterPathDef/VanillaExpanded_VPsycastsE.xml|VPE_Archotechist.description": "Der Archotechnist-Pfad ist ein spezieller Pfad, der nur f\u00fcr imperiumsbasierte Psycaster freigeschaltet ist. Er erlaubt das Verbreiten von Wahnsinn, das Bet\u00e4uben von \u00dcbelt\u00e4tern mit psychischem Schock und das \u00dcbertragen von neuraler Hitze auf andere sowie den Einsatz neuraler Hitze im Kampf.",
  "Part3|DefInjected/VanillaPsycastsExpanded.PsycasterPathDef/VanillaExpanded_VPsycastsE.xml|VPE_Archotechist.label": "Archotechnist",
  "Part3|DefInjected/VanillaPsycastsExpanded.PsycasterPathDef/VanillaExpanded_VPsycastsE.xml|VPE_Chronopath.description": "Der Chronopath-Pfad konzentriert sich auf die Manipulation der Zeit: Dinge altern lassen, Pflanzenwachstum beschleunigen oder Kolonisten verj\u00fcngen.",
  "Part3|DefInjected/VanillaPsycastsExpanded.PsycasterPathDef/VanillaExpanded_VPsycastsE.xml|VPE_Chronopath.label": "Chronopath",
  "Part3|DefInjected/VanillaPsycastsExpanded.PsycasterPathDef/VanillaExpanded_VPsycastsE.xml|VPE_Conflagrator.description": "Der Konflagrator-Pfad konzentriert sich auf die Manipulation von Feuer, Hitze und Energie zur Vernichtung von Feinden.",
  "Part3|DefInjected/VanillaPsycastsExpanded.PsycasterPathDef/VanillaExpanded_VPsycastsE.xml|VPE_Conflagrator.label": "Konflagrator",
  "Part3|DefInjected/VanillaPsycastsExpanded.PsycasterPathDef/VanillaExpanded_VPsycastsE.xml|VPE_Empath.description": "Empathie-Psycasts konzentrieren sich darauf, die Stimmung anderer zu verbessern, auf die eine oder andere Weise.",
  "Part3|DefInjected/VanillaPsycastsExpanded.PsycasterPathDef/VanillaExpanded_VPsycastsE.xml|VPE_Empath.label": "Empath",
  "Part3|DefInjected/VanillaPsycastsExpanded.PsycasterPathDef/VanillaExpanded_VPsycastsE.xml|VPE_Frostshaper.description": "Frostformer ist ein Pfad \u00fcber die Manipulation der Elemente, insbesondere der K\u00e4lte, zu eurem Vorteil. Ihr k\u00f6nnt nicht nur die K\u00e4lte nutzen, um Feinde einzufrieren und zu verlangsamen, Frostformer erhalten auch Zugang zu vielen Nutzen-Psycasts, die entweder Schutzbauten aus Eisbl\u00f6cken errichten oder K\u00fchlkristalle erschaffen, die sowohl als tempor\u00e4rer K\u00fchlraum als auch als Falle dienen k\u00f6nnen.",
  "Part3|DefInjected/VanillaPsycastsExpanded.PsycasterPathDef/VanillaExpanded_VPsycastsE.xml|VPE_Frostshaper.label": "Frostformer",
  "Part3|DefInjected/VanillaPsycastsExpanded.PsycasterPathDef/VanillaExpanded_VPsycastsE.xml|VPE_Harmonist.description": "Harmonisten drehen sich um die Manipulation des Gleichgewichts des Universums. Ihre F\u00e4higkeiten sind nie ein klarer Vorteil oder Nachteil, und sie kommen immer mit einem Preis, auf die eine oder andere Weise.",
  "Part3|DefInjected/VanillaPsycastsExpanded.PsycasterPathDef/VanillaExpanded_VPsycastsE.xml|VPE_Harmonist.label": "Harmonist",
  "Part3|DefInjected/VanillaPsycastsExpanded.PsycasterPathDef/VanillaExpanded_VPsycastsE.xml|VPE_Necropath.description": "Nekropath ist ein Pfad, der sich auf die Verbreitung von Furcht und Tod konzentriert und gleichzeitig von Tod und Leichen profitiert. Ihr k\u00f6nnt gefallene Verb\u00fcndete wiederbeleben, ihnen das Sterben verbieten und Horden von Skeletten auferwecken, die f\u00fcr eure Sache k\u00e4mpfen.",
  "Part3|DefInjected/VanillaPsycastsExpanded.PsycasterPathDef/VanillaExpanded_VPsycastsE.xml|VPE_Necropath.label": "Nekropath",
  "Part3|DefInjected/VanillaPsycastsExpanded.PsycasterPathDef/VanillaExpanded_VPsycastsE.xml|VPE_Nightstalker.description": "Nachtj\u00e4ger sind Krieger der Dunkelheit, die viele kampfbezogene Vorteile erhalten, wenn sie im Schatten verborgen sind.",
  "Part3|DefInjected/VanillaPsycastsExpanded.PsycasterPathDef/VanillaExpanded_VPsycastsE.xml|VPE_Nightstalker.label": "Nachtj\u00e4ger",
  "Part3|DefInjected/VanillaPsycastsExpanded.PsycasterPathDef/VanillaExpanded_VPsycastsE.xml|VPE_Protector.description": "Der Besch\u00fctzer-Pfad konzentriert sich darauf, euren Kolonisten Beistand und Schutz zu bieten, sie vor dem Tod zu bewahren und euch zu erm\u00f6glichen, aus gef\u00e4hrlichen Situationen unversehrt zu entkommen.",
  "Part3|DefInjected/VanillaPsycastsExpanded.PsycasterPathDef/VanillaExpanded_VPsycastsE.xml|VPE_Protector.label": "Besch\u00fctzer",
  "Part3|DefInjected/VanillaPsycastsExpanded.PsycasterPathDef/VanillaExpanded_VPsycastsE.xml|VPE_Skipmaster.description": "Skipmeister-Psycasts konzentrieren sich auf die Nutzung von Skiptoren, um den Verlauf der Schlacht oder das Leben der Kolonie zu ver\u00e4ndern.",
  "Part3|DefInjected/VanillaPsycastsExpanded.PsycasterPathDef/VanillaExpanded_VPsycastsE.xml|VPE_Skipmaster.label": "Skipmeister",
  "Part3|DefInjected/VanillaPsycastsExpanded.PsycasterPathDef/VanillaExpanded_VPsycastsE.xml|VPE_Staticlord.description": "Statiklord ist ein Pfad, der sich auf das Beschie\u00dfen von Feinden mit Elektrizit\u00e4t, das Deaktivieren von Elektronik und die Kontrolle des Sturms selbst konzentriert.",
  "Part3|DefInjected/VanillaPsycastsExpanded.PsycasterPathDef/VanillaExpanded_VPsycastsE.xml|VPE_Staticlord.label": "Statiklord",
  "Part3|DefInjected/VanillaPsycastsExpanded.PsycasterPathDef/VanillaExpanded_VPsycastsE.xml|VPE_Technomancer.description": "Technomanten sind Meister der Technologie, des Wissens und der Forschung, die psychische Energie nutzen k\u00f6nnen, um bei der Konzepterforschung zu helfen, aber auch um kleinen Konstrukten Leben einzuhauchen, die ihnen helfen und sie verteidigen k\u00f6nnen.",
  "Part3|DefInjected/VanillaPsycastsExpanded.PsycasterPathDef/VanillaExpanded_VPsycastsE.xml|VPE_Technomancer.label": "Technomant",
  "Part3|DefInjected/VanillaPsycastsExpanded.PsycasterPathDef/VanillaExpanded_VPsycastsE.xml|VPE_Warlord.description": "Der Kriegsf\u00fcrst-Pfad konzentriert sich auf die Verbesserung der Kampff\u00e4higkeiten des Psycasters und nur des Psycasters \u2013 da alle Kriegsf\u00fcrst-Psycasts in gewissem Ma\u00dfe selbst gewirkt werden.",
  "Part3|DefInjected/VanillaPsycastsExpanded.PsycasterPathDef/VanillaExpanded_VPsycastsE.xml|VPE_Warlord.label": "Kriegsf\u00fcrst",
  "Part3|DefInjected/VanillaPsycastsExpanded.PsycasterPathDef/VanillaExpanded_VPsycastsE.xml|VPE_Wildspeaker.description": "Der Wildfl\u00fcsterer-Pfad ist ein spezieller Pfad, der nur f\u00fcr stammesbasierte Psycaster freigeschaltet ist. Es dreht sich alles um die Kontrolle der Natur und der Tiere zur Verteidigung und zum \u00dcberleben.",
  "Part3|DefInjected/VanillaPsycastsExpanded.PsycasterPathDef/VanillaExpanded_VPsycastsE.xml|VPE_Wildspeaker.label": "Wildfl\u00fcsterer"
}
