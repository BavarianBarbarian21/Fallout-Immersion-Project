<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <!-- Launcher: listens for research completion or manual trigger and starts the MechRuins one-off quest.
       - Listens for two signals:
         * ResearchFinished/FutureTec_SpecialTech  (placeholder research signal)
         * FutureTec_Trigger_MechRuins             (manual/dev trigger)
       - When received, runs the subscript `FutureTec_MechRuins_OneOff` then ends.
       Notes: Replace the research signal name if your research system uses a different naming convention.
  -->

  <QuestScriptDef>
    <defName>FutureTec_MechRuins_Launcher</defName>
    <autoAccept>true</autoAccept>
    <defaultHidden>true</defaultHidden>
    <isRootSpecial>true</isRootSpecial>
    <questNameRules>
      <rulesStrings>
        <li>questName->FutureTec: Mech Ruins Launcher</li>
      </rulesStrings>
    </questNameRules>

    <root Class="QuestNode_AllSignals">
      <inSignals>
        <!-- Common placeholder: research finished signal for the research def 'FutureTec_SpecialTech' -->
        <li>ResearchFinished/FutureTec_SpecialTech</li>
        <!-- Manual trigger you can call from other scripts or dev console -->
        <li>FutureTec_Trigger_MechRuins</li>
      </inSignals>
      <node Class="QuestNode_Sequence">
        <nodes>
          <!-- Run the one-off quest as a subscreened script -->
          <li Class="QuestNode_SubScript">
            <def>FutureTec_MechRuins_OneOff</def>
          </li>

          <!-- End the launcher quest after firing once -->
          <li Class="QuestNode_End" />
        </nodes>
      </node>
    </root>
  </QuestScriptDef>

</Defs>
