    <workerClass>FIP.Repconn3.BiomeWorker_Preserve</workerClass>
    <texture>World/Biomes/BorealForest</texture>
  </BiomeDef>

  <BiomeDef ParentName="FIP3_LandBiomeBase">
    <defName>FIP3_Spring</defName>
    <label>spring</label>
    <description>River-fed boreal springland that replaces about half of eligible preserve river tiles.</description>
    <workerClass>FIP.Repconn3.BiomeWorker_Spring</workerClass>
    <texture>World/Biomes/BorealForest</texture>
  </BiomeDef>

  <BiomeDef ParentName="FIP3_LandBiomeBase">
    <defName>FIP3_Lake</defName>
    <label>lake</label>
