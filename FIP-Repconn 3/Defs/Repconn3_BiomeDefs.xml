<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <BiomeDef Name="FIP3_LandBiomeBase" Abstract="True">
    <animalDensity>0</animalDensity>
    <plantDensity>0</plantDensity>
    <settlementSelectionWeight>0.5</settlementSelectionWeight>
    <campSelectionWeight>0.1</campSelectionWeight>
    <movementDifficulty>1</movementDifficulty>
    <lakeBeachTerrain>Sand</lakeBeachTerrain>
    <riverbankTerrain>Riverbank</riverbankTerrain>
    <riverbankSizeRange>6~8</riverbankSizeRange>
    <forageability>0</forageability>
    <wildPlantRegrowDays>60</wildPlantRegrowDays>
    <maxFishPopulation>0</maxFishPopulation>
    <baseWeatherCommonalities>
      <Clear>12</Clear>
      <Fog>1</Fog>
      <Rain>1</Rain>
      <SnowGentle>1</SnowGentle>
    </baseWeatherCommonalities>
    <terrainsByFertility>
      <li>
        <terrain>Soil</terrain>
        <min>-999</min>
        <max>0.87</max>
      </li>
      <li>
        <terrain>SoilRich</terrain>
        <min>0.87</min>
        <max>999</max>
      </li>
    </terrainsByFertility>
  </BiomeDef>

  <BiomeDef Name="FIP3_ManualBiomeBase" ParentName="FIP3_LandBiomeBase" Abstract="True">
    <workerClass>FIP.Repconn3.BiomeWorker_ManuallyPlaced</workerClass>
    <canAutoChoose>false</canAutoChoose>
  </BiomeDef>

  <BiomeDef ParentName="FIP3_LandBiomeBase">
    <defName>FIP3_SeaIce</defName>
    <label>sea ice</label>
    <description>Repconn 3 arctic sea ice using the vanilla sea ice worker.</description>
    <workerClass>BiomeWorker_SeaIce</workerClass>
    <isWaterBiome>true</isWaterBiome>
    <canBuildBase>false</canBuildBase>
    <allowRoads>false</allowRoads>
    <allowRivers>false</allowRivers>
    <hasVirtualPlants>false</hasVirtualPlants>
    <texture>World/Biomes/IceSheetOcean</texture>
    <impassable>true</impassable>
    <isBackgroundBiome>true</isBackgroundBiome>
    <lakeBeachTerrain>Ice</lakeBeachTerrain>
    <mudTerrain>Ice</mudTerrain>
    <coastalBeachTerrain>Ice</coastalBeachTerrain>
    <terrainPatchMakers>
      <li>
        <perlinFrequency>0.015</perlinFrequency>
        <isPond>true</isPond>
        <thresholds>
          <li>
            <terrain>WaterShallow</terrain>
            <min>0.76</min>
            <max>999</max>
          </li>
        </thresholds>
      </li>
    </terrainPatchMakers>
  </BiomeDef>

  <BiomeDef ParentName="FIP3_LandBiomeBase">
    <defName>FIP3_IceSheet</defName>
    <label>ice sheet</label>
    <description>Repconn 3 ice sheet using the vanilla ice sheet worker.</description>
    <workerClass>BiomeWorker_IceSheet</workerClass>
    <texture>World/Biomes/IceSheet</texture>
    <lakeBeachTerrain>Ice</lakeBeachTerrain>
    <mudTerrain>Ice</mudTerrain>
    <terrainsByFertility>
      <li>
        <terrain>Ice</terrain>
        <min>-999</min>
        <max>999</max>
      </li>
    </terrainsByFertility>
  </BiomeDef>

  <BiomeDef ParentName="FIP3_LandBiomeBase">
    <defName>FIP3_GlacialPlain</defName>
    <label>glacial plain</label>
    <description>Repconn 3 glacial plain using the vanilla glacial plain worker.</description>
    <workerClass>BiomeWorker_GlacialPlain</workerClass>
    <texture>World/Biomes/GlacialPlains</texture>
    <lakeBeachTerrain>Ice</lakeBeachTerrain>
    <mudTerrain>Ice</mudTerrain>
    <coastalBeachTerrain>Ice</coastalBeachTerrain>
    <terrainsByFertility>
      <li>
        <terrain>Ice</terrain>
        <min>-999</min>
        <max>999</max>
      </li>
    </terrainsByFertility>
  </BiomeDef>

  <BiomeDef ParentName="FIP3_LandBiomeBase">
    <defName>FIP3_Tundra</defName>
    <label>tundra</label>
    <description>Repconn 3 tundra using the vanilla tundra worker.</description>
    <workerClass>BiomeWorker_Tundra</workerClass>
    <texture>World/Biomes/Tundra</texture>
    <lakeBeachTerrain>Gravel</lakeBeachTerrain>
    <mudTerrain>Gravel</mudTerrain>
    <riverbankTerrain>Gravel</riverbankTerrain>
  </BiomeDef>

  <BiomeDef ParentName="FIP3_LandBiomeBase">
    <defName>FIP3_Preserve</defName>
    <label>preserve</label>
