  <BiomeDef ParentName="FIP3_ManualBiomeBase">
    <defName>FIP3_Crater</defName>
    <label>crater</label>
    <description>Central seed biome for the crater, ruin, and wasteland ring structure.</description>
    <texture>World/Biomes/Scarlands</texture>
    <pollutionOffset>0.04</pollutionOffset>
  </BiomeDef>

  <BiomeDef ParentName="FIP3_ManualBiomeBase">
    <defName>FIP3_Ruin</defName>
    <label>ruin</label>
    <description>Guaranteed first ring surrounding craters, with a small chance to expand outward.</description>
    <texture>World/Biomes/Scarlands</texture>
    <pollutionOffset>0.02</pollutionOffset>
  </BiomeDef>

  <BiomeDef ParentName="FIP3_ManualBiomeBase">
    <defName>FIP3_Wasteland</defName>
    <label>wasteland</label>
