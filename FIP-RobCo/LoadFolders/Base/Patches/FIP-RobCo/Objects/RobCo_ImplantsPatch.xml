<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <!-- Change Mechlink to Pipboy -->
  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/ThingDef[defName="Mechlink"]/graphicData/texPath</xpath>
    <value>
      <texPath>FIP-RobCo/Misc/RobCo_Pipboy</texPath>
    </value>
  </Operation>
  <!-- ControlSublinkImplant HediffDef -->
  <Operation Class="PatchOperationAdd">
    <xpath>/Defs/ThingDef[defName="ControlSublink"]</xpath>
    <value>
      <graphicData>
        <texPath>FIP-RobCo/Misc/RobCo_Holotape</texPath>
      </graphicData>
    </value>
  </Operation>
