	<!-- Assaultron Dominator -->
	<ThingDef ParentName="RobCo_AssaultronBase">
		<defName>RobCo_AssaultronDominator</defName>
		<label>Assaultron Dominator</label>
		<description>A specialized Assaultron hunter-killer variant built around an integrated stealth-field emitter and a dedicated close-assault blade package. It gives up the standard head laser in exchange for faster cloaked approaches and more dangerous melee engagements.</description>
		<statBases>
			<MarketValue>3600</MarketValue>
			<MoveSpeed>5.0</MoveSpeed>
			<BandwidthCost>4</BandwidthCost>
		</statBases>
		<race>
			<baseHealthScale>3.4</baseHealthScale>
		</race>
	</ThingDef>
