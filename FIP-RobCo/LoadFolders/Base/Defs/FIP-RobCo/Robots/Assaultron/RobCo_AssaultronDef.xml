	<!-- Sheepsquatch -->
	<ThingDef ParentName="RobCo_AssaultronBase">
		<defName>RobCo_AssaultronSheepsquatch</defName>
		<label>sheepsquatch</label>
		<description>A heavily modified Assaultron chassis built to resemble the legendary Sheepsquatch cryptid of Appalachian folklore. Larger than a standard Assaultron and fitted with an uprated head laser, it was likely constructed as an intimidation tool by whoever had access to a robotics workbench and a dark sense of humor.</description>
		<race>
			<body>RobCo_Assaultron</body>
			<intelligence>ToolUser</intelligence>
			<thinkTreeMain>Mechanoid</thinkTreeMain>
			<baseBodySize>1.0</baseBodySize>
			<baseHealthScale>4.5</baseHealthScale>
			<mechWeightClass>Medium</mechWeightClass>
		</race>
		<killedLeavings>
			<PowerfocusChip>1</PowerfocusChip>
		</killedLeavings>
		<comps>
			<li Class="CompProperties_TargetingBeam" />
		</comps>
	</ThingDef>
