<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<!-- Assaultron Base -->
	<ThingDef Name="RobCo_AssaultronBase" ParentName="BaseMechanoid" Abstract="True">
		<statBases>
			<MarketValue>3000</MarketValue>
			<MoveSpeed>4.6</MoveSpeed>
			<ArmorRating_Blunt>0.40</ArmorRating_Blunt>
			<ArmorRating_Sharp>0.80</ArmorRating_Sharp>
			<BandwidthCost>3</BandwidthCost>
			<ControlTakingTime>18</ControlTakingTime>
		</statBases>
		<race>
			<body>RobCo_Assaultron</body>
			<intelligence>ToolUser</intelligence>
			<thinkTreeMain>Mechanoid</thinkTreeMain>
			<baseBodySize>1.0</baseBodySize>
			<baseHealthScale>3.0</baseHealthScale>
			<mechWeightClass>Medium</mechWeightClass>
			<lifeStageAges>
				<li>
					<def>MechanoidFullyFormed</def>
					<minAge>0</minAge>
					<soundWounded>RobCo_Assaultron_Wounded</soundWounded>
					<soundDeath>RobCo_Assaultron_Death</soundDeath>
					<soundCall>RobCo_Assaultron_Call</soundCall>
					<soundAngry>RobCo_Assaultron_Angry</soundAngry>
				</li>
			</lifeStageAges>
		</race>
		<butcherProducts>
			<Steel>20</Steel>
			<Plasteel>10</Plasteel>
		</butcherProducts>
		<tools>
			<li>
				<label>chassis</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>15.0</power>
				<cooldownTime>2.6</cooldownTime>
				<linkedBodyPartsGroup>Torso</linkedBodyPartsGroup>
				<ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
			</li>
		</tools>
	</ThingDef>
	<RecipeDef Name="RobCo_AssaultronBase_Recipe" ParentName="BaseMechanoidRecipe" Abstract="True">
		<gestationCycles>4</gestationCycles>
		<researchPrerequisite>HighMechtech</researchPrerequisite>
		<ingredients>
			<li>
				<filter>
					<thingDefs>
						<li>Steel</li>
					</thingDefs>
				</filter>
				<count>100</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>Plasteel</li>
					</thingDefs>
				</filter>
				<count>50</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>ComponentSpacer</li>
					</thingDefs>
				</filter>
				<count>1</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>PowerfocusChip</li>
					</thingDefs>
				</filter>
				<count>1</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>SubcoreHigh</li>
					</thingDefs>
				</filter>
				<count>1</count>
			</li>
		</ingredients>
		<displayPriority>300</displayPriority>
	</RecipeDef>
	<!-- Assaultron -->
	<ThingDef ParentName="RobCo_AssaultronBase">
		<defName>RobCo_Assaultron</defName>
		<label>Assaultron</label>
		<description>A bipedal combat robot manufactured by RobCo Industries for the United States military. It features an olive drab paint scheme with military markings, two claw arms for melee combat, and a head-mounted laser capable of firing a charged beam at range. Fast and aggressive, the Assaultron was designed for frontline assault roles. Some units were fitted with a stealth field generator, allowing them to cloak mid-approach.</description>
		<race>
			<body>RobCo_Assaultron</body>
			<lifeStageAges>
				<li>
					<def>MechanoidFullyFormed</def>
					<minAge>10</minAge>
					<soundWounded>RobCo_Assaultron_Wounded</soundWounded>
					<soundDeath>RobCo_Assaultron_Death</soundDeath>
					<soundCall>RobCo_Assaultron_Call</soundCall>
					<soundAngry>RobCo_Assaultron_Angry</soundAngry>
				</li>
			</lifeStageAges>
			<baseHealthScale>3</baseHealthScale>
		</race>
		<comps>
			<li Class="CompProperties_TargetingBeam" />
		</comps>
	</ThingDef>
