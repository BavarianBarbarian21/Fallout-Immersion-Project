		</descriptionHyperlinks>
	</RecipeDef>
	<!-- Collectron -->
	<ThingDef ParentName="RobCo_ProtectronBase">
		<defName>RobCo_Collectron</defName>
		<label>collectron</label>
		<description>A Protectron variant reprogrammed for resource collection and salvage. It was adopted by various post-war factions to automate the gathering of specific materials. The Collectron operates autonomously within a defined area and will defend its collection zone against interference.</description>
		<race>
			<mechEnabledWorkTypes>
				<li>Hauling</li>
				<li>PlantCutting</li>
			</mechEnabledWorkTypes>
		</race>
	</ThingDef>
