	</RecipeDef>
	<!-- Utilitron -->
	<ThingDef ParentName="RobCo_ProtectronBase">
		<defName>RobCo_Utilitron</defName>
		<label>utilitron</label>
		<description>A Protectron unit fitted with a heavy drill attachment in place of a standard hand laser, intended for mining and excavation work. It was contracted to pre-War mining operations for subterranean resource extraction. The drill arm makes it slower than a standard Protectron but gives it significant close-quarters capability.</description>
		<race>
			<mechEnabledWorkTypes>
				<li>Mining</li>
			</mechEnabledWorkTypes>
		</race>
		<tools>
			<li>
				<label>drill</label>
				<capacities>
					<li>Stab</li>
				</capacities>
				<power>10</power>
				<cooldownTime>2.0</cooldownTime>
				<linkedBodyPartsGroup>Torso</linkedBodyPartsGroup>
				<ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
			</li>
		</tools>
	</ThingDef>
