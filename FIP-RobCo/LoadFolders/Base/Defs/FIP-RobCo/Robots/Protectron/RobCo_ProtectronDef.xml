	<!-- Protectron -->
	<ThingDef ParentName="RobCo_ProtectronBase">
		<defName>RobCo_Protectron</defName>
		<label>Protectron</label>
		<description>A widely deployed pre-War utility and security robot manufactured by RobCo Industries. It features a large domed head with three optical sensors, dual hand-mounted laser emitters, and a head laser. Powered by a fission battery, the Protectron was used across offices, hospitals, and public facilities throughout the United States. It is slow and less capable in direct combat than dedicated military robots.</description>
		<race>
			<baseHealthScale>2.0</baseHealthScale>
			<lifeStageAges>
				<li>
					<def>MechanoidFullyFormed</def>
					<minAge>10</minAge>
					<soundWounded>RobCo_Protectron_Wounded</soundWounded>
					<soundDeath>RobCo_Protectron_Death</soundDeath>
					<soundCall>RobCo_Protectron_Call</soundCall>
					<soundAngry>RobCo_Protectron_Angry</soundAngry>
				</li>
			</lifeStageAges>
		</race>
	</ThingDef>
