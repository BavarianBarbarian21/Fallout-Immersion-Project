<GeneDef>
  <defName>WestTek_Gene_Courser</defName>
  <label>courser</label>
  <description>The pawn carries a stable Courser-grade synthetic framework. It preserves the benefits of synth components without unstable endogene shedding or sterility.</description>
  <iconPath>UI/Icons/Genes/WestTek_Courser</iconPath>
  <displayOrderInCategory>701</displayOrderInCategory>

  <biostatCpx>6</biostatCpx>
  <biostatMet>-4</biostatMet>
  <biostatArc>1</biostatArc>

  <statFactors>
    <ToxicResistance>0</ToxicResistance>
    <ToxicEnvironmentResistance>0</ToxicEnvironmentResistance>
  </statFactors>

  <immunityGainSpeedFactor>0</immunityGainSpeedFactor>

  <exclusionTags>
    <li>WestTek_SynthCore</li>
  </exclusionTags>
</GeneDef>
<GeneDef>
  <defName>WestTek_Gene_SystemOfCells</defName>
  <label>system of cells</label>
  <description>The pawn evaluates enclosed space and comfort as irrelevant structural data rather than emotional experience.</description>
  <iconPath>UI/Icons/Genes/WestTek_SystemOfCells</iconPath>
  <displayOrderInCategory>710</displayOrderInCategory>

  <biostatCpx>1</biostatCpx>
  <biostatMet>1</biostatMet>

  <disabledNeeds>
    <li>RoomSize</li>
    <li>Comfort</li>
  </disabledNeeds>

  <modExtensions>
    <li Class="FIP.WestTek.WestTekSynthGeneExtension">
      <isSynthEndogene>true</isSynthEndogene>
    </li>
  </modExtensions>
</GeneDef>
<GeneDef>
  <defName>WestTek_Gene_WithinOneStem</defName>
  <label>within one stem</label>
  <description>The pawn no longer distinguishes between shelter, open air, or beauty. All surroundings collapse into one continuous field of input.</description>
  <iconPath>UI/Icons/Genes/WestTek_WithinOneStem</iconPath>
  <displayOrderInCategory>711</displayOrderInCategory>

  <biostatCpx>1</biostatCpx>
  <biostatMet>1</biostatMet>

  <disabledNeeds>
    <li>Outdoors</li>
    <li>Indoors</li>
    <li>Beauty</li>
  </disabledNeeds>

  <modExtensions>
    <li Class="FIP.WestTek.WestTekSynthGeneExtension">
      <isSynthEndogene>true</isSynthEndogene>
    </li>
  </modExtensions>
</GeneDef>
<GeneDef>
  <defName>WestTek_Gene_DreadfullyDistinct</defName>
  <label>dreadfully distinct</label>
  <description>The pawn's nervous system rejects narcotic craving and suppresses pain into distant diagnostic noise.</description>
  <iconPath>UI/Icons/Genes/WestTek_DreadfullyDistinct</iconPath>
  <displayOrderInCategory>712</displayOrderInCategory>

  <biostatCpx>2</biostatCpx>
  <biostatMet>-1</biostatMet>

  <disabledNeeds>
    <li>DrugDesire</li>
  </disabledNeeds>

  <painFactor>0</painFactor>

  <modExtensions>
    <li Class="FIP.WestTek.WestTekSynthGeneExtension">
      <isSynthEndogene>true</isSynthEndogene>
    </li>
  </modExtensions>
</GeneDef>
