    </li>
  </modExtensions>
</GeneDef>
<GeneDef>
  <defName>WestTek_Gene_BloodBlackNothingness</defName>
  <label>blood-black nothingness</label>
  <description>The pawn is sustained by an internal black-cell power lattice instead of ordinary biological equilibrium.</description>
