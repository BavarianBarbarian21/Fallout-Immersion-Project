<?xml version="1.0" encoding="utf-8"?>
<Defs>
<GeneDef>
  <defName>WestTek_Gene_SynthComponents</defName>
  <label>synth components</label>
  <description>The pawn's body is maintained by unstable synthetic biocomponents. These components grant synthetic resilience and sterility, but may gradually shed unstable synth endogenes until only a Courser-grade framework remains.</description>
  <geneClass>FIP.WestTek.Gene_WestTekSynthComponents</geneClass>
  <iconPath>UI/Icons/Genes/WestTek_SynthComponents</iconPath>
  <displayOrderInCategory>700</displayOrderInCategory>

  <biostatCpx>5</biostatCpx>
  <biostatMet>-3</biostatMet>
  <biostatArc>1</biostatArc>

  <sterile>true</sterile>

  <statFactors>
    <ToxicResistance>0</ToxicResistance>
    <ToxicEnvironmentResistance>0</ToxicEnvironmentResistance>
  </statFactors>

  <immunityGainSpeedFactor>0</immunityGainSpeedFactor>

  <exclusionTags>
    <li>WestTek_SynthCore</li>
  </exclusionTags>
</GeneDef>

