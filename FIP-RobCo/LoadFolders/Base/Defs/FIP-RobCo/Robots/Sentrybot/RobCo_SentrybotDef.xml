					<texPath>FIP-RobCo/Robots/Sentrybot/SentrybotAncient/SentrybotAncient</texPath>
					<shaderType>CutoutWithOverlay</shaderType>
					<graphicClass>Graphic_Multi</graphicClass>
					<drawSize>1.9</drawSize>
					<shadowData>
						<volume>(0.3, 0.4, 0.3)</volume>
						<offset>(0,0,-0.25)</offset>
					</shadowData>
				</bodyGraphicData>
			</li>
		</lifeStages>
		<weaponTags>
			<li>RobCo_SentrybotPestcontrolExterminator</li>
		</weaponTags>
		<abilities>
			<li>RobCo_HeavyFlamer</li>
		</abilities>
	</PawnKindDef>
	<RecipeDef ParentName="RobCo_SentrybotBase_Recipe">
		<defName>RobCo_SentrybotPestcontrol_Recipe</defName>
		<label>craft a pestcontrol sentrybot</label>
		<description>Craft a Pestcontrol Sentrybot.</description>
		<products>
			<RobCo_SentrybotPestcontrol>1</RobCo_SentrybotPestcontrol>
		</products>
		<descriptionHyperlinks>
			<ThingDef>RobCo_SentrybotPestcontrol</ThingDef>
		</descriptionHyperlinks>
	</RecipeDef>
	<!-- Sentrybot Annihilator -->
	<ThingDef ParentName="RobCo_SentrybotBase">
		<defName>RobCo_SentrybotAnnihilator</defName>
		<label>annihilator sentrybot</label>
		<description>A RobCo Industries sentry bot armed with a tri-barrel minigun and Gatling laser, designed for sustained suppression of infantry and lightly armored targets. The sentry bot is RobCo's dedicated combat platform, built around a simple synthetic personality chip containing only combat routines. The Annihilator is the standard production variant of this line.</description>
		<race>
			<lifeStageAges>
				<li>
					<def>MechanoidFullyFormed</def>
					<minAge>10</minAge>
					<soundWounded>RobCo_Sentrybot_Wounded</soundWounded>
					<soundDeath>RobCo_Sentrybot_Death</soundDeath>
					<soundCall>RobCo_Sentrybot_Call</soundCall>
					<soundAngry>RobCo_Sentrybot_Angry</soundAngry>
				</li>
			</lifeStageAges>
		</race>
	</ThingDef>
