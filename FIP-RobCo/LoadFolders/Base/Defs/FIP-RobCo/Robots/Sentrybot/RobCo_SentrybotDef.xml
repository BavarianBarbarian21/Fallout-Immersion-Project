<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<!-- Sentrybot Base -->
	<ThingDef Name="RobCo_SentrybotBase" ParentName="BaseMechanoid" Abstract="True">
		<statBases>
			<MarketValue>3000</MarketValue>
			<MoveSpeed>3.0</MoveSpeed>
			<ControlTakingTime>30</ControlTakingTime>
			<BandwidthCost>5</BandwidthCost>
			<ArmorRating_Blunt>0.25</ArmorRating_Blunt>
			<ArmorRating_Sharp>0.75</ArmorRating_Sharp>
			<PsychicSensitivity>0.75</PsychicSensitivity>
			<MechEnergyLossPerHP>0.15</MechEnergyLossPerHP>
		</statBases>
		<race>
			<body>RobCo_Sentrybot</body>
			<intelligence>ToolUser</intelligence>
			<thinkTreeMain>Mechanoid</thinkTreeMain>
			<baseBodySize>1.5</baseBodySize>
			<baseHealthScale>4.5</baseHealthScale>
			<mechWeightClass>Medium</mechWeightClass>
			<lifeStageAges>
				<li>
					<def>MechanoidFullyFormed</def>
					<minAge>0</minAge>
					<soundWounded>RobCo_Sentrybot_Wounded</soundWounded>
					<soundDeath>RobCo_Sentrybot_Death</soundDeath>
					<soundCall>RobCo_Sentrybot_Call</soundCall>
					<soundAngry>RobCo_Sentrybot_Angry</soundAngry>
				</li>
			</lifeStageAges>
		</race>
		<butcherProducts>
			<Steel>10</Steel>
		</butcherProducts>
		<tools>
			<li>
				<label>chassis</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>20.0</power>
				<cooldownTime>2.6</cooldownTime>
				<linkedBodyPartsGroup>Torso</linkedBodyPartsGroup>
				<ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
			</li>
		</tools>
	</ThingDef>
	<RecipeDef Name="RobCo_SentrybotBase_Recipe" ParentName="BaseMechanoidRecipe" Abstract="True">
		<gestationCycles>12</gestationCycles>
		<researchPrerequisite>UltraMechtech</researchPrerequisite>
		<ingredients>
			<li>
				<filter>
					<thingDefs>
						<li>Steel</li>
					</thingDefs>
				</filter>
				<count>200</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>Plasteel</li>
					</thingDefs>
				</filter>
				<count>200</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>NanostructuringChip</li>
					</thingDefs>
				</filter>
				<count>1</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>ComponentSpacer</li>
					</thingDefs>
				</filter>
				<count>2</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>SubcoreHigh</li>
					</thingDefs>
				</filter>
				<count>1</count>
			</li>
		</ingredients>
		<displayPriority>400</displayPriority>
	</RecipeDef>
	<!-- Sentrybot Siegebreaker -->
	<ThingDef ParentName="RobCo_SentrybotBase">
		<defName>RobCo_SentrybotSiegebreaker</defName>
		<label>siegebreaker sentrybot</label>
		<description>A sentry bot variant configured for fortification assault and anti-armor operations. Its primary weapon system is a rack of high-yield rocket launchers suited to demolishing reinforced structures. It rides on a mecanum wheel base that allows movement across most terrain. Standard sentry bot armor and combat protocols are retained.</description>
		<race>
			<lifeStageAges>
				<li>
					<def>MechanoidFullyFormed</def>
					<minAge>10</minAge>
					<soundWounded>RobCo_Sentrybot_Wounded</soundWounded>
					<soundDeath>RobCo_Sentrybot_Death</soundDeath>
					<soundCall>RobCo_Sentrybot_Call</soundCall>
					<soundAngry>RobCo_Sentrybot_Angry</soundAngry>
				</li>
			</lifeStageAges>
		</race>
	</ThingDef>
	<PawnKindDef ParentName="RobCo_LargeRobotKind">
		<defName>RobCo_SentrybotSiegebreaker</defName>
		<label>siegebreaker sentrybot</label>
		<race>RobCo_SentrybotSiegebreaker</race>
		<combatPower>600</combatPower>
		<lifeStages>
			<li>
				<bodyGraphicData>
					<texPath>FIP-RobCo/Robots/Sentrybot/Sentrybot/Sentrybot</texPath>
					<shaderType>CutoutWithOverlay</shaderType>
					<graphicClass>Graphic_Multi</graphicClass>
					<drawSize>1.9</drawSize>
					<shadowData>
						<volume>(0.3, 0.4, 0.3)</volume>
						<offset>(0,0,-0.25)</offset>
					</shadowData>
				</bodyGraphicData>
			</li>
			<li>
				<label>pre-War siegebreaker sentrybot</label>
				<bodyGraphicData>
					<texPath>FIP-RobCo/Robots/Sentrybot/SentrybotAncient/SentrybotAncient</texPath>
					<shaderType>CutoutWithOverlay</shaderType>
					<graphicClass>Graphic_Multi</graphicClass>
					<drawSize>1.9</drawSize>
					<shadowData>
						<volume>(0.3, 0.4, 0.3)</volume>
						<offset>(0,0,-0.25)</offset>
					</shadowData>
				</bodyGraphicData>
			</li>
		</lifeStages>
		<weaponTags>
			<li>RobCo_SentrybotSiegebreakerLauncher</li>
		</weaponTags>
	</PawnKindDef>
	<RecipeDef ParentName="RobCo_SentrybotBase_Recipe">
		<defName>RobCo_SentrybotSiegebreaker_Recipe</defName>
		<label>craft a siegebreaker sentrybot</label>
		<description>Craft a Siegebreaker Sentrybot.</description>
		<products>
			<RobCo_SentrybotSiegebreaker>1</RobCo_SentrybotSiegebreaker>
		</products>
		<descriptionHyperlinks>
			<ThingDef>RobCo_SentrybotSiegebreaker</ThingDef>
		</descriptionHyperlinks>
	</RecipeDef>
	<!-- Sentrybot Pestcontrol -->
	<ThingDef ParentName="RobCo_SentrybotBase">
		<defName>RobCo_SentrybotPestcontrol</defName>
		<label>pestcontrol sentrybot</label>
		<description>A sentry bot variant equipped with an industrial flamethrower system and a reloadable fuel canister for extended operations. Originally designed for large-scale pest eradication and area denial, it is capable of sustained incendiary fire across a wide area. The Pestcontrol variant was marketed to agricultural and government clients before the war.</description>
		<race>
			<lifeStageAges>
				<li>
					<def>MechanoidFullyFormed</def>
					<minAge>10</minAge>
					<soundWounded>RobCo_Sentrybot_Wounded</soundWounded>
					<soundDeath>RobCo_Sentrybot_Death</soundDeath>
					<soundCall>RobCo_Sentrybot_Call</soundCall>
					<soundAngry>RobCo_Sentrybot_Angry</soundAngry>
				</li>
			</lifeStageAges>
		</race>
		<comps>
			<li Class="FIP.RobCo.CompProperties_AbilityReloadable" />
		</comps>
	</ThingDef>
	<PawnKindDef ParentName="RobCo_LargeRobotKind">
		<defName>RobCo_SentrybotPestcontrol</defName>
		<label>pestcontrol sentrybot</label>
		<race>RobCo_SentrybotPestcontrol</race>
		<combatPower>600</combatPower>
		<lifeStages>
			<li>
				<bodyGraphicData>
					<texPath>FIP-RobCo/Robots/Sentrybot/Sentrybot/Sentrybot</texPath>
					<shaderType>CutoutWithOverlay</shaderType>
					<graphicClass>Graphic_Multi</graphicClass>
					<drawSize>1.9</drawSize>
					<shadowData>
						<volume>(0.3, 0.4, 0.3)</volume>
						<offset>(0,0,-0.25)</offset>
					</shadowData>
				</bodyGraphicData>
			</li>
			<li>
				<label>pre-War pestcontrol sentrybot</label>
