					<graphicClass>Graphic_Multi</graphicClass>
					<drawSize>1.9</drawSize>
					<shadowData>
						<volume>(0.3, 0.4, 0.3)</volume>
						<offset>(0,0,-0.25)</offset>
					</shadowData>
				</bodyGraphicData>
			</li>
		</lifeStages>
		<weaponTags>
			<li>RobCo_SentrybotDeathbotLauncher</li>
			<li>RobCo_SentrybotDeathbotExterminator</li>
			<li>RobCo_SentrybotDeathbotMinigun</li>
		</weaponTags>
	</PawnKindDef>
