	<!-- Deathbot -->
	<ThingDef ParentName="RobCo_SentrybotBase">
		<defName>RobCo_SentrybotDeathbot</defName>
		<label>deathbot</label>
		<description>A sentry bot carrying a combined full weapons suite: minigun, rocket launcher, flamethrower, and cluster grenade launchers. It is one of the most heavily armed autonomous units encountered in the wasteland. Its central processor contains a nanostructuring chip, suggesting it was used as a testbed for advanced nanotechnology programs before or after the war.</description>
		<race>
			<body>RobCo_Sentrybot</body>
			<intelligence>ToolUser</intelligence>
			<thinkTreeMain>Mechanoid</thinkTreeMain>
			<baseBodySize>1.5</baseBodySize>
			<baseHealthScale>6.75</baseHealthScale>
			<mechWeightClass>Medium</mechWeightClass>
		</race>
		<killedLeavingsPlayerHostile>
			<NanostructuringChip>1</NanostructuringChip>
		</killedLeavingsPlayerHostile>
	</ThingDef>
