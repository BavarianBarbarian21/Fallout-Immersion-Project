<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<ThingDef Name="RobCo_SentryRocketLauncherBase" ParentName="RobCo_BaseGun" Abstract="True">
		<label>Sentrybot rocket launcher</label>
		<description>A salvo rocket launcher integrated into Sentrybot frames. It is intended to break cover, damage structures, and engage grouped targets at range.</description>
		<tickerType>Normal</tickerType>
		<statBases>
			<MarketValue>1000</MarketValue>
			<Mass>7</Mass>
			<RangedWeapon_Cooldown>4.5</RangedWeapon_Cooldown>
		</statBases>
		<verbs>
			<li>
				<verbClass>Verb_ShootOneUse</verbClass>
				<hasStandardCommand>true</hasStandardCommand>
				<defaultProjectile>RobCo_Bullet_SentryRocket</defaultProjectile>
				<forcedMissRadius>2.9</forcedMissRadius>
				<warmupTime>4.5</warmupTime>
				<ai_AvoidFriendlyFireRadius>5</ai_AvoidFriendlyFireRadius>
				<range>35.9</range>
				<ticksBetweenBurstShots>20</ticksBetweenBurstShots>
				<burstShotCount>6</burstShotCount>
				<soundCast>InfernoCannon_Fire</soundCast>
				<soundCastTail>GunTail_Heavy</soundCastTail>
				<onlyManualCast>true</onlyManualCast>
				<stopBurstWithoutLos>false</stopBurstWithoutLos>
				<targetParams>
					<canTargetLocations>true</canTargetLocations>
				</targetParams>
				<muzzleFlashScale>14</muzzleFlashScale>
			</li>
		</verbs>
		<comps>
			<li Class="CompProperties_Explosive">
				<explosiveRadius>3.9</explosiveRadius>
				<explosiveDamageType>Thump</explosiveDamageType>
				<requiredDamageTypeToExplode>Flame</requiredDamageTypeToExplode>
			</li>
			<li Class="CompProperties_Biocodable" />
		</comps>
	</ThingDef>

	<ThingDef Name="RobCo_SentryExterminatorBase" ParentName="RobCo_BaseGun" Abstract="True">
		<label>Exterminator</label>
		<description>A specialized launcher intended for pest control and area denial. It fires toxic payloads and is paired with an integrated incendiary system for close-range follow-up.</description>
		<relicChance>0</relicChance>
		<statBases>
			<MarketValue>1800</MarketValue>
			<Mass>3.4</Mass>
			<RangedWeapon_Cooldown>4.5</RangedWeapon_Cooldown>
		</statBases>
		<verbs>
			<li>
				<verbClass>Verb_Shoot</verbClass>
				<hasStandardCommand>true</hasStandardCommand>
				<defaultProjectile>Bullet_ToxbombLauncher</defaultProjectile>
				<warmupTime>3.5</warmupTime>
				<range>47.8</range>
				<forcedMissRadius>1.9</forcedMissRadius>
				<burstShotCount>1</burstShotCount>
				<soundCast>Shot_IncendiaryLauncher</soundCast>
				<soundCastTail>GunTail_Medium</soundCastTail>
				<muzzleFlashScale>14</muzzleFlashScale>
				<targetParams>
					<canTargetLocations>true</canTargetLocations>
				</targetParams>
			</li>
		</verbs>
		<comps Inherit="False">
			<li Class="CompProperties_EquippableAbilityReloadable">
				<abilityDef>RobCo_HeavyFlamer</abilityDef>
				<maxCharges>3</maxCharges>
				<soundReload>Standard_Reload</soundReload>
				<chargeNoun>heavy flamer charge</chargeNoun>
				<ammoDef>Chemfuel</ammoDef>
				<ammoCountPerCharge>20</ammoCountPerCharge>
				<baseReloadTicks>60</baseReloadTicks>
			</li>
		</comps>
	</ThingDef>

	<ThingDef Name="RobCo_SentryMinigunBase" ParentName="RobCo_BaseGun" Abstract="True">
		<label>RobCo Minigun</label>
		<description>A rapid-fire laser minigun used for sustained suppressive fire. It consumes low-beam cartridges quickly in exchange for a high volume of shots.</description>
		<statBases>
			<MarketValue>1500</MarketValue>
			<Mass>6</Mass>
			<AccuracyTouch>0.30</AccuracyTouch>
			<AccuracyShort>0.25</AccuracyShort>
			<AccuracyMedium>0.20</AccuracyMedium>
			<AccuracyLong>0.10</AccuracyLong>
			<RangedWeapon_Cooldown>0.35</RangedWeapon_Cooldown>
		</statBases>
		<verbs>
			<li>
				<verbClass>Verb_Shoot</verbClass>
				<range>25</range>
				<warmupTime>0.15</warmupTime>
				<defaultProjectile>RobCo_Bullet_LaserAuto</defaultProjectile>
				<burstShotCount>10</burstShotCount>
				<ticksBetweenBurstShots>7</ticksBetweenBurstShots>
			</li>
		</verbs>
	</ThingDef>

