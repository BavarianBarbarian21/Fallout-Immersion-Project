<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<GeneDef>
		<defName>RobCo_Gene_ThinkTankCore</defName>
		<canGenerateInGeneSet>false</canGenerateInGeneSet>
		<selectionWeight>0</selectionWeight>
		<label>think tank chassis</label>
		<description>The pawn's brain lives in a hovering armored glass vessel. Biogel performs posture and locomotion, the tank handles hearing, and dedicated monitor arms provide sight and speech. The chassis needs no food, sleeps only half as long, excels at research, and is poorly suited to physical labor.</description>
		<geneClass>FIP.RobCo.Gene_ThinkTankCore</geneClass>
		<iconPath>UI/Icons/Genes/Gene_ArchiteMetabolism</iconPath>
		<displayOrderInCategory>800</displayOrderInCategory>
		<biostatCpx>8</biostatCpx>
		<biostatMet>-6</biostatMet>
		<forcedHair>Bald</forcedHair>
		<forcedHeadTypes><li>RobCo_ThinkTankHead</li></forcedHeadTypes>
		<tattoosVisible>false</tattoosVisible>
		<hairTagFilter><whitelist>true</whitelist><tags><li>Bald</li></tags></hairTagFilter>
		<beardTagFilter><whitelist>true</whitelist><tags /></beardTagFilter>
		<disablesNeeds><li>Food</li></disablesNeeds>
		<statFactors>
			<RestRateMultiplier>2</RestRateMultiplier>
			<ResearchSpeed>2</ResearchSpeed>
			<PlantWorkSpeed>0.1</PlantWorkSpeed>
			<ConstructionSpeed>0.1</ConstructionSpeed>
			<MiningSpeed>0.1</MiningSpeed>
			<GeneralLaborSpeed>0.8</GeneralLaborSpeed>
			<CookSpeed>0.8</CookSpeed>
		</statFactors>
		<exclusionTags>
			<li>RobCo_SyntheticAppearance</li>
			<li>HeadShape</li>
			<li>HairStyle</li>
			<li>BeardStyle</li>
			<li>Fur</li>
		</exclusionTags>
	</GeneDef>

	<GeneDef>
		<defName>RobCo_Gene_Biosphere</defName>
		<canGenerateInGeneSet>false</canGenerateInGeneSet>
		<selectionWeight>0</selectionWeight>
		<label>biosphere</label>
		<labelShortAdj>biospheric</labelShortAdj>
		<description>An archite-regulated sealed biosphere stops biological aging and makes the suspended brain immune to every immunizable disease loaded by the game.</description>
		<iconPath>UI/Icons/Genes/Gene_PerfectImmunity</iconPath>
		<displayCategory>Archite</displayCategory>
		<displayOrderInCategory>801</displayOrderInCategory>
		<biostatCpx>6</biostatCpx>
		<biostatArc>2</biostatArc>
		<biologicalAgeTickFactorFromAgeCurve>
			<points><li>(0, 0)</li><li>(1000, 0)</li></points>
		</biologicalAgeTickFactorFromAgeCurve>
		<exclusionTags><li>Immunity</li></exclusionTags>
	</GeneDef>

	<GeneDef>
		<defName>RobCo_Gene_ThinkTankEyes</defName>
		<canGenerateInGeneSet>false</canGenerateInGeneSet>
		<selectionWeight>0</selectionWeight>
		<label>monitor eyes</label>
		<description>Two monitor arms display the Think Tank's independently animated artificial eyes.</description>
		<iconPath>UI/Icons/Genes/Gene_SkinColorOverride</iconPath>
		<displayOrderInCategory>802</displayOrderInCategory>
		<biostatCpx>0</biostatCpx>
		<renderNodeProperties>
			<li>
				<nodeClass>PawnRenderNode_AttachmentHead</nodeClass>
				<workerClass>PawnRenderNodeWorker_FlipWhenCrawling</workerClass>
				<parentTagDef>Head</parentTagDef>
				<texPaths>
					<li>FIP-RobCo/Robots/ThinkTank/Eyes/Thinktank_eyesA</li>
					<li>FIP-RobCo/Robots/ThinkTank/Eyes/Thinktank_eyesB</li>
					<li>FIP-RobCo/Robots/ThinkTank/Eyes/Thinktank_eyesC</li>
					<li>FIP-RobCo/Robots/ThinkTank/Eyes/Thinktank_eyesD</li>
					<li>FIP-RobCo/Robots/ThinkTank/Eyes/Thinktank_eyesE</li>
					<li>FIP-RobCo/Robots/ThinkTank/Eyes/Thinktank_eyesF</li>
					<li>FIP-RobCo/Robots/ThinkTank/Eyes/Thinktank_eyesJ</li>
				</texPaths>
				<overrideMeshSize>(1.5, 1.5)</overrideMeshSize>
				<rotDrawMode>Fresh, Rotting</rotDrawMode>
				<baseLayer>60</baseLayer>
			</li>
		</renderNodeProperties>
	</GeneDef>

