	<GeneDef>
		<defName>RobCo_Gene_Lobotomized</defName>
		<canGenerateInGeneSet>false</canGenerateInGeneSet>
		<selectionWeight>0</selectionWeight>
		<label>lobotomized</label>
		<labelShortAdj>lobotomized</labelShortAdj>
