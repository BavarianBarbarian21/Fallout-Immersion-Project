<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<!-- ================= SECURITRON BASE ================= -->
	<ThingDef Name="RobCo_SecuritronBase" ParentName="BaseMechanoid" Abstract="True">
		<statBases>
			<MarketValue>1200</MarketValue>
			<MoveSpeed>2.5</MoveSpeed>
			<ArmorRating_Blunt>0.25</ArmorRating_Blunt>
			<ArmorRating_Sharp>0.45</ArmorRating_Sharp>
			<MechEnergyLossPerHP>0.60</MechEnergyLossPerHP>
		</statBases>
		<race>
			<body>RobCo_Securitron</body>
			<intelligence>ToolUser</intelligence>
			<thinkTreeMain>Mechanoid</thinkTreeMain>
			<baseBodySize>1.0</baseBodySize>
			<baseHealthScale>1.8</baseHealthScale>
			<mechWeightClass>Light</mechWeightClass>
			<lifeStageAges>
				<li>
					<def>MechanoidFullyFormed</def>
					<minAge>0</minAge>
					<soundWounded>RobCo_Securitron_Wounded</soundWounded>
					<soundDeath>RobCo_Securitron_Death</soundDeath>
					<soundCall>RobCo_Securitron_Call</soundCall>
					<soundAngry>RobCo_Securitron_Angry</soundAngry>
				</li>
			</lifeStageAges>
		</race>
		<butcherProducts>
			<Steel>12</Steel>
		</butcherProducts>
		<tools>
			<li>
				<label>chassis</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>8</power>
				<cooldownTime>2.4</cooldownTime>
				<linkedBodyPartsGroup>Torso</linkedBodyPartsGroup>
				<ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
			</li>
		</tools>
	</ThingDef>
	<RecipeDef Name="RobCo_SecuritronBase_Recipe" ParentName="BaseMechanoidRecipe" Abstract="True">
		<researchPrerequisites>
			<li>RobCo_OS</li>
			<li>RobCo_Choice_LibertyPrime</li>
		</researchPrerequisites>
		<gestationCycles>2</gestationCycles>
		<ingredients>
			<li>
				<filter>
					<thingDefs>
						<li>Steel</li>
					</thingDefs>
				</filter>
				<count>120</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>ComponentIndustrial</li>
					</thingDefs>
				</filter>
				<count>1</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>SubcoreRegular</li>
					</thingDefs>
				</filter>
				<count>1</count>
			</li>
		</ingredients>
		<displayPriority>200</displayPriority>
	</RecipeDef>
	
	<!-- ================= SECURITRON MARK I ================= -->
	<ThingDef ParentName="RobCo_SecuritronBase">
		<defName>RobCo_SecuritronMkI</defName>
		<label>Securitron mark I</label>
		<description>A RobCo Industries PDQ-88b security robot built on a single heavy monowheel chassis. The Mark I carries a 9mm submachine gun in its right arm and displays a pre-War police officer image on its CRT screen face. It features a titanium alloy body and integrated auto-repair systems. Mark I units run basic combat software and are less effective in complex engagements than the upgraded Mark II variant.</description>
	</ThingDef>
	<PawnKindDef ParentName="RobCo_SmallRobotKind">
		<defName>RobCo_SecuritronMkI</defName>
		<label>Securitron mark I</label>
		<race>RobCo_SecuritronMkI</race>
		<combatPower>200</combatPower>
		<lifeStages>
			<li>
				<bodyGraphicData>
					<texPath>FIP-RobCo/Robots/Securitron/SecuritronMK1/SecuritronMK1</texPath>
					<shaderType>CutoutWithOverlay</shaderType>
					<graphicClass>Graphic_Multi</graphicClass>
					<drawSize>1.3</drawSize>
					<shadowData>
						<volume>(0.35, 0.35, 0.35)</volume>
						<offset>(0,0,-0.25)</offset>
					</shadowData>
				</bodyGraphicData>
			</li>
		</lifeStages>
		<weaponTags>
			<li>RobCo_SecuritronLaser</li>
		</weaponTags>
	</PawnKindDef>
	<RecipeDef ParentName="RobCo_SecuritronBase_Recipe">
		<defName>RobCo_SecuritronMkI_Recipe</defName>
		<label>craft Securitron mark I</label>
		<description>Craft a Securitron Mark I.</description>
		<products>
			<RobCo_SecuritronMkI>1</RobCo_SecuritronMkI>
		</products>
		<descriptionHyperlinks>
			<ThingDef>RobCo_SecuritronMkI</ThingDef>
		</descriptionHyperlinks>
	</RecipeDef>
	<!-- ================= SECURITRON MARK II BASE ================= -->
	<ThingDef Name="RobCo_SecuritronMkIIBase" ParentName="BaseMechanoid" Abstract="True">
		<statBases>
			<MarketValue>3500</MarketValue>
			<MoveSpeed>3.0</MoveSpeed>
			<ArmorRating_Blunt>0.40</ArmorRating_Blunt>
			<ArmorRating_Sharp>0.60</ArmorRating_Sharp>
			<MechEnergyLossPerHP>0.40</MechEnergyLossPerHP>
		</statBases>
		<race>
			<body>RobCo_Securitron</body>
			<intelligence>ToolUser</intelligence>
			<thinkTreeMain>Mechanoid</thinkTreeMain>
			<baseBodySize>1.1</baseBodySize>
			<baseHealthScale>2.5</baseHealthScale>
			<mechWeightClass>Light</mechWeightClass>
			<lifeStageAges>
				<li>
					<def>MechanoidFullyFormed</def>
					<minAge>0</minAge>
					<soundWounded>RobCo_Securitron_Wounded</soundWounded>
					<soundDeath>RobCo_Securitron_Death</soundDeath>
					<soundCall>RobCo_Securitron_Call</soundCall>
					<soundAngry>RobCo_Securitron_Angry</soundAngry>
				</li>
			</lifeStageAges>
		</race>
		<butcherProducts>
			<Steel>14</Steel>
		</butcherProducts>
		<tools>
			<li>
				<label>mechanical claws</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>9</power>
				<cooldownTime>1.5</cooldownTime>
				<linkedBodyPartsGroup>Torso</linkedBodyPartsGroup>
				<ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
			</li>
		</tools>
	</ThingDef>
	<!-- ================= SECURITRON MARK II ================= -->
	<ThingDef ParentName="RobCo_SecuritronMkIIBase">
		<defName>RobCo_SecuritronMkII</defName>
		<label>Securitron mark II</label>
		<description>A PDQ-88b Securitron running the Mark II software package, which brings its full weapons loadout online: X-25 Gatling laser, M-235 rocket launchers, and G-28 grenade launchers. Its CRT screen displays a soldier rather than a police officer. The Mark II was Robert House's intended combat-ready force for the defense of New Vegas and the Mojave.</description>
	</ThingDef>
	<PawnKindDef ParentName="RobCo_SmallRobotKind">
		<defName>RobCo_SecuritronMkII</defName>
		<label>Securitron mark II</label>
		<race>RobCo_SecuritronMkII</race>
		<combatPower>220</combatPower>
		<lifeStages>
			<li>
				<bodyGraphicData>
					<texPath>FIP-RobCo/Robots/Securitron/SecuritronMK2/SecuritronMK2</texPath>
					<shaderType>CutoutWithOverlay</shaderType>
					<graphicClass>Graphic_Multi</graphicClass>
					<drawSize>1.3</drawSize>
					<shadowData>
						<volume>(0.35, 0.35, 0.35)</volume>
						<offset>(0,0,-0.25)</offset>
					</shadowData>
				</bodyGraphicData>
			</li>
		</lifeStages>
		<weaponTags>
			<li>RobCo_SecuritronElectroshock</li>
		</weaponTags>
		<abilities>
			<li>RobCo_SecuritronRocketSalvo</li>
		</abilities>
	</PawnKindDef>
	<RecipeDef ParentName="RobCo_SecuritronBase_Recipe">
		<defName>RobCo_SecuritronMkII_Recipe</defName>
		<label>craft Securitron mark II</label>
		<description>Craft an improved Securitron Mark II.</description>
		<products>
			<RobCo_SecuritronMkII>1</RobCo_SecuritronMkII>
		</products>
		<descriptionHyperlinks>
			<ThingDef>RobCo_SecuritronMkII</ThingDef>
		</descriptionHyperlinks>
	</RecipeDef>
	<!-- ================= BERSERK SECURITRON ================= -->
	<ThingDef ParentName="RobCo_SecuritronMkIIBase">
		<defName>RobCo_BerserkSecuritron</defName>
		<label>berserk Securitron</label>
		<description>A Securitron unit whose behavioral limiters have failed, leaving it in a state of indiscriminate aggression. It retains full Mark II combat capability — Gatling laser, rocket launchers, and electroshock weapons — but without faction recognition, threat assessment, or de-escalation protocols. It attacks all targets within range without distinction.</description>
	</ThingDef>
	<PawnKindDef ParentName="RobCo_SmallRobotKind">
		<defName>RobCo_BerserkSecuritron</defName>
		<label>berserk Securitron</label>
		<race>RobCo_BerserkSecuritron</race>
		<combatPower>260</combatPower>
		<lifeStages>
			<li>
				<bodyGraphicData>
					<texPath>FIP-RobCo/Robots/Securitron/SecuritronWild/SecuritronWild</texPath>
					<shaderType>CutoutWithOverlay</shaderType>
					<graphicClass>Graphic_Multi</graphicClass>
					<drawSize>1.3</drawSize>
					<shadowData>
						<volume>(0.35, 0.35, 0.35)</volume>
						<offset>(0,0,-0.25)</offset>
					</shadowData>
				</bodyGraphicData>
			</li>
		</lifeStages>
		<weaponTags>
			<li>RobCo_SecuritronElectroshock</li>
		</weaponTags>
		<abilities>
			<li>RobCo_SecuritronRocketSalvo</li>
		</abilities>
	</PawnKindDef>


</Defs>
