<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<LetterDef ParentName="CustomChoiceLetterBase">
		<defName>RobCo_PlatinumChipOpportunity</defName>
		<letterClass>FIP_RobCo.ChoiceLetter_RobCoPlatinumChipOpportunity</letterClass>
	</LetterDef>

	<WorldObjectDef ParentName="Site">
		<defName>RobCo_CourierCamp</defName>
		<label>courier trail</label>
		<description>A temporary courier camp tied to a RobCo platinum chip transaction.</description>
		<worldObjectClass>FIP_RobCo.RobCoCourierCamp</worldObjectClass>
		<texture>World/WorldObjects/Camp</texture>
		<expandingIcon>true</expandingIcon>
		<expandingIconTexture>World/WorldObjects/Expanding/Camp</expandingIconTexture>
		<expandingIconPriority>80</expandingIconPriority>
		<expandMore>true</expandMore>
		<isTempIncidentMapOwner>true</isTempIncidentMapOwner>
		<overrideMapSize>(200, 1, 200)</overrideMapSize>
		<IncidentTargetTags>
			<li>Map_TempIncident</li>
		</IncidentTargetTags>
		<comps>
			<li Class="WorldObjectCompProperties_FormCaravan" />
			<li Class="WorldObjectCompProperties_TimedDetectionRaids" />
		</comps>
	</WorldObjectDef>

	<WorldObjectDef ParentName="Site">
		<defName>RobCo_VaultSite</defName>
		<label>RobCo vault site</label>
		<description>A sealed RobCo vault or management annex tied to a platinum chip courier route.</description>
		<worldObjectClass>FIP_RobCo.RobCoVaultSite</worldObjectClass>
		<texture>World/WorldObjects/Sites/GenericSite</texture>
	</WorldObjectDef>

	<SitePartDef>
		<defName>RobCo_AncientVault</defName>
		<label>RobCo vault</label>
		<description>An old RobCo vault facility whose internal defenses are still active.</description>
		<workerClass>SitePartWorker_AncientComplex</workerClass>
		<siteTexture>World/WorldObjects/Sites/GenericSite</siteTexture>
		<expandingIconTexture>World/WorldObjects/Expanding/Sites/AncientMechanitorComplex</expandingIconTexture>
		<approachOrderString>Investigate {0}</approachOrderString>
		<approachingReportString>Investigating {0}.</approachingReportString>
		<considerEnteringAsAttack>false</considerEnteringAsAttack>
		<arrivedLetterDef>NeutralEvent</arrivedLetterDef>
		<wantsThreatPoints>true</wantsThreatPoints>
		<gravShipsCanLandOn>true</gravShipsCanLandOn>
		<tags>
			<li>RobCo_AncientVault</li>
		</tags>
	</SitePartDef>

	<GenStepDef>
		<defName>RobCo_AncientVaultThreats</defName>
		<linkWithSite>RobCo_AncientVault</linkWithSite>
		<order>471</order>
		<genStep Class="FIP_RobCo.GenStep_RobCoVaultThreats" />
	</GenStepDef>

	<FIP_RobCo.RobCoPlatinumQuestBranchDef>
		<defName>RobCo_PlatinumBranch_CEO</defName>
		<label>CEO branch</label>
		<courierNumber>2</courierNumber>
		<chipTitle>the CEO</chipTitle>
		<stage2EnemyPawnKind>RobCo_BerserkSecuritron</stage2EnemyPawnKind>
		<stage2CorpsePawnKind>RobCo_LibertyPrime</stage2CorpsePawnKind>
		<unlockResearch>RobCo_Choice_LibertyPrime</unlockResearch>
		<stage1TargetPoints>700</stage1TargetPoints>
		<stage2ThreatPoints>3200</stage2ThreatPoints>
		<stage2LetterLabel>RobCo vault location recovered</stage2LetterLabel>
		<stage2LetterText>The dead courier carried access fragments tied to a RobCo executive archive. They point to a distant vault complex still crawling with corrupted Securitrons. Somewhere inside lies the wreck of Liberty Prime.</stage2LetterText>
	</FIP_RobCo.RobCoPlatinumQuestBranchDef>

	<FIP_RobCo.RobCoPlatinumQuestBranchDef>
		<defName>RobCo_PlatinumBranch_PRC</defName>
		<label>People's Republic branch</label>
		<courierNumber>5</courierNumber>
		<chipTitle>the People's Republic</chipTitle>
		<stage2EnemyPawnKind>RobCo_Liberator</stage2EnemyPawnKind>
		<stage2CorpsePawnKind>RobCo_WarMachine</stage2CorpsePawnKind>
		<unlockResearch>RobCo_Choice_WarMachine</unlockResearch>
		<stage1TargetPoints>700</stage1TargetPoints>
		<stage2ThreatPoints>3600</stage2ThreatPoints>
		<stage2LetterLabel>PRC cache coordinates acquired</stage2LetterLabel>
		<stage2LetterText>The courier's route logs reveal a remote RobCo cache where Chinese Liberators were stockpiled in absurd numbers. The archive also indicates that a War Machine chassis was lost there during containment failure.</stage2LetterText>
	</FIP_RobCo.RobCoPlatinumQuestBranchDef>

	<FIP_RobCo.RobCoPlatinumQuestBranchDef>
		<defName>RobCo_PlatinumBranch_Calculator</defName>
		<label>Calculator branch</label>
		<courierNumber>3</courierNumber>
		<chipTitle>the Calculator</chipTitle>
		<stage2EnemyPawnKind>RobCo_BerserkSecuritron</stage2EnemyPawnKind>
		<stage2CorpsePawnKind>RobCo_Pacificator</stage2CorpsePawnKind>
		<unlockResearch>RobCo_Choice_Pacificator</unlockResearch>
		<stage1TargetPoints>700</stage1TargetPoints>
		<stage2ThreatPoints>3400</stage2ThreatPoints>
		<stage2LetterLabel>Calculator archive recovered</stage2LetterLabel>
		<stage2LetterText>The courier carried fragments from the Calculator's command archives. They point to an abandoned RobCo data center where a Pacificator chassis was sealed beneath the steel.</stage2LetterText>
	</FIP_RobCo.RobCoPlatinumQuestBranchDef>

	<FIP_RobCo.RobCoPlatinumQuestBranchDef>
		<defName>RobCo_PlatinumBranch_ThinkTank</defName>
		<label>Think Tank branch</label>
		<courierNumber>4</courierNumber>
		<chipTitle>the Think Tank</chipTitle>
		<stage2EnemyPawnKind>RobCo_RoboScorpion</stage2EnemyPawnKind>
		<stage2CorpsePawnKind>RobCo_RoboScorpionQueen</stage2CorpsePawnKind>
		<unlockResearch>RobCo_Choice_ThinkTank</unlockResearch>
		<stage1TargetPoints>700</stage1TargetPoints>
		<stage2ThreatPoints>3800</stage2ThreatPoints>
		<stage2LetterLabel>Think tank archives recovered</stage2LetterLabel>
		<stage2LetterText>The courier's logs point to a buried Big MT think tank vault. A giant Roboscorpion queen was kept there as a testbed for post-war battlefield intelligence.</stage2LetterText>
	</FIP_RobCo.RobCoPlatinumQuestBranchDef>

	<FIP_RobCo.RobCoPlatinumQuestBranchDef>
		<defName>RobCo_PlatinumBranch_University</defName>
		<label>University branch</label>
		<courierNumber>6</courierNumber>
		<chipTitle>the University</chipTitle>
		<stage2EnemyPawnKind>RobCo_SecuritronMkII</stage2EnemyPawnKind>
		<stage2CorpsePawnKind>RobCo_Pacificator</stage2CorpsePawnKind>
		<unlockResearch>RobCo_Choice_Synths</unlockResearch>
		<stage1TargetPoints>700</stage1TargetPoints>
		<stage2ThreatPoints>3000</stage2ThreatPoints>
		<stage2LetterLabel>University vault recovered</stage2LetterLabel>
		<stage2LetterText>The courier's route points to a forgotten university vault filled with synthetic personnel archives and dormant robotic test platforms.</stage2LetterText>
	</FIP_RobCo.RobCoPlatinumQuestBranchDef>
</Defs>