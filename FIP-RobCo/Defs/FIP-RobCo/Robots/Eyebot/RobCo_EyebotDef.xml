<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<!-- Eyebot Base -->
	<ThingDef Name="RobCo_EyebotBase" ParentName="BaseMechanoid" Abstract="True">
		<statBases>
			<MarketValue>900</MarketValue>
			<MoveSpeed>5.0</MoveSpeed>
			<ArmorRating_Blunt>0.10</ArmorRating_Blunt>
			<ArmorRating_Sharp>0.20</ArmorRating_Sharp>
			<MechEnergyLossPerHP>0.66</MechEnergyLossPerHP>
		</statBases>
		<race>
			<body>RobCo_Eyebot</body>
			<intelligence>ToolUser</intelligence>
			<thinkTreeMain>Mechanoid</thinkTreeMain>
			<baseBodySize>0.7</baseBodySize>
			<baseHealthScale>0.9</baseHealthScale>
			<mechWeightClass>Light</mechWeightClass>
			<lifeStageAges>
				<li>
					<def>MechanoidFullyFormed</def>
					<minAge>0</minAge>
					<soundWounded>RobCo_Eyebot_Wounded</soundWounded>
					<soundDeath>RobCo_Eyebot_Death</soundDeath>
					<soundCall>RobCo_Eyebot_Call</soundCall>
					<soundAngry>RobCo_Eyebot_Angry</soundAngry>
				</li>
			</lifeStageAges>
			<nuzzleMtbHours>12</nuzzleMtbHours>
		</race>
		<butcherProducts>
			<Steel>10</Steel>
		</butcherProducts>
		<tools>
			<li>
				<label>chassis</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>3</power>
				<cooldownTime>2.6</cooldownTime>
				<linkedBodyPartsGroup>Torso</linkedBodyPartsGroup>
				<ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
			</li>
		</tools>
	</ThingDef>
	<RecipeDef Name="RobCo_EyebotBase_Recipe" ParentName="BaseMechanoidRecipe" Abstract="True">
		<researchPrerequisite>BasicMechtech</researchPrerequisite>
		<gestationCycles>1</gestationCycles>
		<ingredients>
			<li>
				<filter>
					<thingDefs>
						<li>Steel</li>
					</thingDefs>
				</filter>
				<count>100</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>ComponentIndustrial</li>
					</thingDefs>
				</filter>
				<count>1</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>RobCo_BrokenEyebotFrame</li>
					</thingDefs>
				</filter>
				<count>1</count>
			</li>
		</ingredients>
		<displayPriority>100</displayPriority>
	</RecipeDef>
	<!-- Eyebot -->
	<ThingDef ParentName="RobCo_EyebotBase">
		<defName>RobCo_Eyebot</defName>
		<label>Eyebot</label>
		<description>A small hovering surveillance and broadcast drone manufactured by RobCo Industries. It uses whip antennas and integrated loudspeakers to transmit radio signals and pre-recorded broadcasts, and is equipped with advanced facial recognition systems. The Eyebot carries a light laser weapon for self-defense. Widely deployed by the Enclave for propaganda and reconnaissance, it is fast and elusive but extremely fragile in direct combat.</description>
		<comps>
			<li Class="FIP_RobCo.CompProperties_NonHostilePawnAura">
				<radius>12</radius>
				<refreshTicks>30</refreshTicks>
				<hediffDef>RobCo_EyebotTargetingUplink</hediffDef>
				<toolUserOnly>true</toolUserOnly>
			</li>
		</comps>
		<race>
			<lifeStageAges>
				<li>
					<def>MechanoidFullyFormed</def>
					<minAge>10</minAge>
					<soundWounded>RobCo_Eyebot_Wounded</soundWounded>
					<soundDeath>RobCo_Eyebot_Death</soundDeath>
					<soundCall>RobCo_Eyebot_Call</soundCall>
					<soundAngry>RobCo_Eyebot_Angry</soundAngry>
				</li>
			</lifeStageAges>
		</race>
	</ThingDef>
	<PawnKindDef ParentName="RobCo_SmallRobotKind">
		<defName>RobCo_Eyebot</defName>
		<label>Eyebot</label>
		<pawnDesc>A small, spherical hovering drone manufactured by RobCo Industries. Originally designed for surveillance, propaganda broadcast, and reconnaissance, the Eyebot is equipped with advanced facial recognition systems, loudspeakers, and a weak laser weapon for self-defense. Often deployed by the Enclave to transmit radio signals and news feeds across the wasteland, Eyebots are fast and elusive but extremely fragile when engaged in direct combat. Their whip antennas and tinny broadcasts make them an iconic — if irritating — sight in the post-war world.</pawnDesc>
		<race>RobCo_Eyebot</race>
		<combatPower>50</combatPower>
		<lifeStages>
			<li>
				<bodyGraphicData>
					<texPath>FIP-RobCo/Robots/Eyebot/Eyebot/Eyebot</texPath>
					<shaderType>CutoutWithOverlay</shaderType>
					<graphicClass>Graphic_Multi</graphicClass>
					<drawSize>1.25</drawSize>
					<shadowData>
						<volume>(0.3, 0.4, 0.3)</volume>
						<offset>(0,0,-0.25)</offset>
					</shadowData>
				</bodyGraphicData>
			</li>
			<li>
				<label>pre-war Eyebot</label>
				<bodyGraphicData>
					<texPath>FIP-RobCo/Robots/Eyebot/EyebotAncient/EyebotAncient</texPath>
					<shaderType>CutoutWithOverlay</shaderType>
					<graphicClass>Graphic_Multi</graphicClass>
					<drawSize>1.25</drawSize>
					<shadowData>
						<volume>(0.3, 0.4, 0.3)</volume>
						<offset>(0,0,-0.25)</offset>
					</shadowData>
				</bodyGraphicData>
			</li>
		</lifeStages>
		<weaponTags>
			<li>RobCo_EyebotBlaster</li>
		</weaponTags>
	</PawnKindDef>
	<RecipeDef ParentName="RobCo_EyebotBase_Recipe">
		<defName>RobCo_Eyebot_Recipe</defName>
		<label>craft Eyebot</label>
		<description>Craft an Eyebot.</description>
		<products>
			<RobCo_Eyebot>1</RobCo_Eyebot>
		</products>
		<descriptionHyperlinks>
			<ThingDef>RobCo_Eyebot</ThingDef>
		</descriptionHyperlinks>
	</RecipeDef>
	<!-- Eyebot Duraframe -->
	<ThingDef ParentName="RobCo_EyebotBase">
		<defName>RobCo_EyebotDuraframe</defName>
		<label>Eyebot Duraframe</label>
		<description>An enhanced Eyebot built on the experimental Duraframe chassis. It features reinforced internal components for greater durability than a standard unit and carries a more powerful energy weapon. The most documented Duraframe unit, designated ED-E, was fitted with a Tesla cannon and carried sensitive Enclave research data across the wasteland for decades before being recovered.</description>
		<comps>
			<li Class="FIP_RobCo.CompProperties_NonHostilePawnAura">
				<radius>12</radius>
				<refreshTicks>30</refreshTicks>
				<hediffDef>RobCo_EyebotTargetingUplink</hediffDef>
				<toolUserOnly>true</toolUserOnly>
			</li>
			<li Class="FIP_RobCo.CompProperties_PawnNuzzler">
				<nuzzleMtbHours>12</nuzzleMtbHours>
				<radius>18</radius>
			</li>
		</comps>
		<race>
			<baseHealthScale>1.0</baseHealthScale>
			<mechEnabledWorkTypes>
				<li>Firefighter</li>
			</mechEnabledWorkTypes>
			<mechWorkTypePriorities>
				<Firefighter>2</Firefighter>
			</mechWorkTypePriorities>
		</race>
	</ThingDef>
	<PawnKindDef ParentName="RobCo_SmallRobotKind">
		<defName>RobCo_EyebotDuraframe</defName>
		<label>Eyebot Duraframe</label>
		<pawnDesc>An enhanced prototype Eyebot built on the experimental Duraframe chassis. Where standard Eyebots are notoriously fragile, the Duraframe design uses reinforced internal components to dramatically increase survivability. This variant also mounts a significantly more powerful energy weapon system, making it a genuine combat threat rather than a nuisance. The most notable Duraframe unit, ED-E, was fitted with a Tesla cannon and carried critical Enclave data across the wasteland for years.</pawnDesc>
		<race>RobCo_EyebotDuraframe</race>
		<combatPower>50</combatPower>
		<lifeStages>
			<li>
				<bodyGraphicData>
					<texPath>FIP-RobCo/Robots/Eyebot/EyebotDuraframe/EyebotDuraframe</texPath>
					<shaderType>CutoutWithOverlay</shaderType>
					<graphicClass>Graphic_Multi</graphicClass>
					<drawSize>1.25</drawSize>
					<shadowData>
						<volume>(0.3, 0.4, 0.3)</volume>
						<offset>(0,0,-0.25)</offset>
					</shadowData>
				</bodyGraphicData>
			</li>
		</lifeStages>
		<weaponTags>
			<li>RobCo_EyebotDuraframeBlaster</li>
		</weaponTags>
	</PawnKindDef>
	<RecipeDef ParentName="RobCo_EyebotBase_Recipe">
		<defName>RobCo_EyebotDuraframe_Recipe</defName>
		<label>craft Eyebot Duraframe</label>
		<description>Craft an Eyebot Duraframe.</description>
		<products>
			<RobCo_EyebotDuraframe>1</RobCo_EyebotDuraframe>
		</products>
		<descriptionHyperlinks>
			<ThingDef>RobCo_EyebotDuraframe</ThingDef>
		</descriptionHyperlinks>
	</RecipeDef>
	<!-- Crashed Vertibot -->
	<ThingDef ParentName="RobCo_EyebotBase">
		<defName>RobCo_EyebotCrashed</defName>
		<label>Crashed Vertibot Robot</label>
		<description>The remains of a Vertibot — a pre-war military VTOL drone — brought down and no longer capable of flight. Despite its condition, onboard weapon systems and automated defense protocols remain partially active. It will engage anything that enters its perimeter.</description>
		<race>
			<body>RobCo_Eyebot</body>
			<intelligence>ToolUser</intelligence>
			<thinkTreeMain>Mechanoid</thinkTreeMain>
			<baseBodySize>0.7</baseBodySize>
			<baseHealthScale>1.5</baseHealthScale>
			<mechWeightClass>Light</mechWeightClass>
			<nuzzleMtbHours>12</nuzzleMtbHours>
		</race>
		<killedLeavingsPlayerHostile>
			<RobCo_BrokenEyebotFrame>1</RobCo_BrokenEyebotFrame>
		</killedLeavingsPlayerHostile>
	</ThingDef>
	<PawnKindDef ParentName="RobCo_HugeRobotKind">
		<defName>RobCo_EyebotCrashed</defName>
		<label>Crashed Vertibot Robot</label>
		<pawnDesc>The wrecked remains of a pre-war Vertibot — a large military VTOL drone — repurposed or reactivated after years of decay. Though no longer airworthy, the surviving systems of this crashed machine still pose a serious threat to anyone who approaches. Its weapons and sensors remain partially functional, controlled by damaged but tenacious automated defense protocols.</pawnDesc>
		<race>RobCo_EyebotCrashed</race>
		<combatPower>300</combatPower>
		<lifeStages>
			<li>
				<bodyGraphicData>
					<texPath>FIP-RobCo/Robots/Eyebot/EyebotBoss/EyebotBoss</texPath>
					<shaderType>CutoutWithOverlay</shaderType>
					<graphicClass>Graphic_Multi</graphicClass>
					<drawSize>1.25</drawSize>
					<shadowData>
						<volume>(0.3, 0.4, 0.3)</volume>
						<offset>(0,0,-0.25)</offset>
					</shadowData>
				</bodyGraphicData>
			</li>
		</lifeStages>
		<weaponTags>
			<li>RobCo_EyebotCrashedBlaster</li>
		</weaponTags>
	</PawnKindDef>
</Defs>
