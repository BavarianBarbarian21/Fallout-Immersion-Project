<Defs>

	<!-- Handy Base -->

	<ThingDef Name="RobCo_HandyBase" ParentName="BaseMechanoid" Abstract="True">
		<statBases>
			<MarketValue>1800</MarketValue>
			<MoveSpeed>4.6</MoveSpeed>
			<ArmorRating_Blunt>0.20</ArmorRating_Blunt>
			<ArmorRating_Sharp>0.40</ArmorRating_Sharp>
			<MechEnergyLossPerHP>0.66</MechEnergyLossPerHP>
			<BandwidthCost>2</BandwidthCost>
			<ControlTakingTime>18</ControlTakingTime>
		</statBases>
		<race>
			<body>RobCo_Handy</body>
			<intelligence>ToolUser</intelligence>
			<thinkTreeMain>Mechanoid</thinkTreeMain>
			<baseBodySize>1.0</baseBodySize>
			<baseHealthScale>1.5</baseHealthScale>
			<mechWeightClass>Light</mechWeightClass>
			<lifeStageAges>
				<li>
					<def>MechanoidFullyFormed</def>
					<minAge>0</minAge>
					<soundWounded>RobCo_Handy_Wounded</soundWounded>
					<soundDeath>RobCo_Handy_Death</soundDeath>
					<soundCall>RobCo_Handy_Call</soundCall>
					<soundAngry>RobCo_Handy_Angry</soundAngry>
				</li>
			</lifeStageAges>
		</race>
		<butcherProducts>
			<Steel>10</Steel>
		</butcherProducts>
		<tools>
			<li>
				<label>chassis</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>6</power>
				<cooldownTime>2.6</cooldownTime>
				<linkedBodyPartsGroup>Torso</linkedBodyPartsGroup>
				<ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
			</li>
		</tools>
	</ThingDef>

	<RecipeDef Name="RobCo_HandyBase_Recipe" ParentName="BaseMechanoidRecipe" Abstract="True">
		<gestationCycles>2</gestationCycles>
		<researchPrerequisite>StandardMechtech</researchPrerequisite>
		<ingredients>
			<li>
				<filter>
					<thingDefs>
						<li>Steel</li>
					</thingDefs>
				</filter>
				<count>75</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>ComponentIndustrial</li>
					</thingDefs>
				</filter>
				<count>2</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>SignalChip</li>
					</thingDefs>
				</filter>
				<count>1</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>SubcoreRegular</li>
					</thingDefs>
				</filter>
				<count>1</count>
			</li>
		</ingredients>
		<displayPriority>200</displayPriority>
	</RecipeDef>

