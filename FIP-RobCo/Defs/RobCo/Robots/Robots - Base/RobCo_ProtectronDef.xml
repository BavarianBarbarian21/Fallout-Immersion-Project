<?xml version="1.0" encoding="utf-8"?>
<Defs>

	<!-- Protectron Base -->

	<ThingDef Name="RobCo_ProtectronBase" ParentName="BaseMechanoid" Abstract="True">
		<statBases>
			<MarketValue>800</MarketValue>
			<MoveSpeed>2.0</MoveSpeed>
			<ArmorRating_Blunt>0.20</ArmorRating_Blunt>
			<ArmorRating_Sharp>0.40</ArmorRating_Sharp>
			<MechEnergyLossPerHP>0.66</MechEnergyLossPerHP>
		</statBases>
		<race>
			<body>RobCo_Protectron</body>
			<intelligence>ToolUser</intelligence>
			<thinkTreeMain>Mechanoid</thinkTreeMain>
			<baseBodySize>1.0</baseBodySize>
			<baseHealthScale>1.8</baseHealthScale>
			<mechWeightClass>Light</mechWeightClass>
			<lifeStageAges>
				<li>
					<def>MechanoidFullyFormed</def>
					<minAge>0</minAge>
					<soundWounded>RobCo_Protectron_Wounded</soundWounded>
					<soundDeath>RobCo_Protectron_Death</soundDeath>
					<soundCall>RobCo_Protectron_Call</soundCall>
					<soundAngry>RobCo_Protectron_Angry</soundAngry>
				</li>
			</lifeStageAges>
		</race>
		<butcherProducts>
			<Steel>10</Steel>
		</butcherProducts>
		<tools>
			<li>
				<label>chassis</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>6</power>
				<cooldownTime>2.6</cooldownTime>
				<linkedBodyPartsGroup>Torso</linkedBodyPartsGroup>
				<ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
			</li>
		</tools>
	</ThingDef>

	<RecipeDef Name="RobCo_ProtectronBase_Recipe" ParentName="BaseMechanoidRecipe" Abstract="True">
		<researchPrerequisite>BasicMechtech</researchPrerequisite>
		<gestationCycles>1</gestationCycles>
		<ingredients>
			<li>
				<filter>
					<thingDefs>
						<li>Steel</li>
					</thingDefs>
				</filter>
				<count>100</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>ComponentIndustrial</li>
					</thingDefs>
				</filter>
				<count>1</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>SubcoreBasic</li>
					</thingDefs>
				</filter>
				<count>1</count>
			</li>
		</ingredients>
		<displayPriority>100</displayPriority>
	</RecipeDef>

	<!-- Constructron -->

	<ThingDef ParentName="RobCo_ProtectronBase">
		<defName>RobCo_Constructron</defName>
		<label>constructron</label>
		<description>Industrial-grade version, all welders and rivet guns. Once meant for building cities of old.</description>
		<race>
			<mechEnabledWorkTypes>
				<li>Construction</li>
			</mechEnabledWorkTypes>
		</race>
	</ThingDef>

	<PawnKindDef ParentName="RobCo_SmallRobotKind">
		<defName>RobCo_Constructron</defName>
		<label>constructron</label>
		<race>RobCo_Constructron</race>
		<combatPower>10</combatPower>
		<lifeStages>
			<li>
				<bodyGraphicData>
					<texPath>RobCo/ProtectronUtility/body</texPath>
					<shaderType>CutoutWithOverlay</shaderType>
					<graphicClass>Graphic_Multi</graphicClass>
					<drawSize>1.25</drawSize>
					<shadowData>
						<volume>(0.3, 0.4, 0.3)</volume>
						<offset>(0,0,-0.25)</offset>
					</shadowData>
				</bodyGraphicData>
			</li>
		</lifeStages>
		<weaponTags>
			<li>RobCo_Gun_Protectron_Nail</li>
		</weaponTags>
	</PawnKindDef>

	<RecipeDef ParentName="RobCo_ProtectronBase_Recipe">
		<defName>RobCo_Constructron_Recipe</defName>
		<label>craft constructron</label>
		<description>Craft a constructron.</description>
		<products>
			<RobCo_Constructron>1</RobCo_Constructron>
		</products>
		<descriptionHyperlinks>
			<ThingDef>RobCo_Constructron</ThingDef>
		</descriptionHyperlinks>
	</RecipeDef>

