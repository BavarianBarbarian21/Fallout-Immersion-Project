<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="PatchOperationSequence">
    <operations>
      <li Class="PatchOperationReplace" MayRequire="Ludeon.RimWorld.Anomaly">
        <xpath>Defs/FactionDef[defName="HoraxCult"]/label</xpath>
        <value>
          <label>Holy Mothman Cultsts</label>
        </value>
      </li>
      <li Class="PatchOperationAdd" MayRequire="Ludeon.RimWorld.Anomaly">
        <xpath>Defs/FactionDef[defName="HoraxCult"]</xpath>
        <value>
          <pawnSingular>Devoted Seer</pawnSingular>
        </value>
      </li>
      <li Class="PatchOperationReplace" MayRequire="Ludeon.RimWorld.Anomaly">
        <xpath>Defs/FactionDef[defName="HoraxCult"]/pawnsPlural</xpath>
        <value>
          <pawnsPlural>Devoted Seers</pawnsPlural>
        </value>
      </li>
    </operations>
  </Operation>

  <Operation Class="PatchOperationFindMod">
    <mods>
      <li>Ludeon.RimWorld.Anomaly</li>
    </mods>
    <match Class="PatchOperationSequence">
      <operations>
        <li Class="PatchOperationAdd" MayRequire="FIP.WestTek">
          <xpath>Defs/FactionDef[defName="HoraxCult"]</xpath>
          <value>
            <xenotypeSet>
              <xenotypeChances>
                <WestTek_Xenotype_Atlantic MayRequire="FIP.WestTek">0.5</WestTek_Xenotype_Atlantic>
                <WestTek_Xenotype_NatL MayRequire="FIP.WestTek">0.3</WestTek_Xenotype_NatL>
                <WestTek_Xenotype_Cascadia MayRequire="FIP.WestTek">0.2</WestTek_Xenotype_Cascadia>
              </xenotypeChances>
            </xenotypeSet>
          </value>
        </li>
      </operations>
    </match>
  </Operation>
</Patch>