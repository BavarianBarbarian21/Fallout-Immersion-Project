<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="PatchOperationSequence">
    <operations>
      <li Class="PatchOperationReplace" MayRequire="Rick.FCP.PRC">
        <xpath>Defs/FactionDef[defName="FCP_Faction_PRC"]/xenotypeSet</xpath>
        <value>
          <xenotypeSet>
            <xenotypeChances>
              <Baseliner MayRequire="Ludeon.RimWorld.Biotech">0.8</Baseliner>
              <WestTek_Xenotype_Ghoul MayRequire="FIP.WestTek">0.2</WestTek_Xenotype_Ghoul>
            </xenotypeChances>
          </xenotypeSet>
        </value>
      </li>
    </operations>
  </Operation>
  <!--Overwrite with FCP Ghouls-->
	<Operation Class="PatchOperationSequence" MayRequire="Rick.FCP.Ghouls">
    <operations>
      <li Class="PatchOperationReplace" MayRequire="Rick.FCP.Ghouls">
        <xpath>Defs/FactionDef[defName="FCP_Faction_PRC"]/xenotypeSet</xpath>
        <value>
          <xenotypeSet>
            <xenotypeChances>
              <Baseliner MayRequire="Ludeon.RimWorld.Biotech">0.8</Baseliner>
              <FCP_Xenotype_Ghoul MayRequire="Rick.FCP.Ghouls">0.2</FCP_Xenotype_Ghoul>
            </xenotypeChances>
          </xenotypeSet>
        </value>
      </li>
    </operations>
  </Operation>
</Patch>