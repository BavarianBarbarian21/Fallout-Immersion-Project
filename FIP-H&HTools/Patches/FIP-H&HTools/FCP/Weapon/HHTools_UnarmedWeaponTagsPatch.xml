<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="PatchOperationFindMod">
    <mods>
      <li>Rick.FCP.UnarmedWeapons</li>
    </mods>
    <match Class="PatchOperationSequence">
      <operations>
        <li Class="PatchOperationAdd">
          <xpath>/Defs/ThingDef[defName="FCP_Unarmed_Boxing_Glove"]/weaponTags</xpath>
          <value>
            <li>HHTools_Wasteland</li>
            <li>HHTools_Settlement</li>
            <li>HHTools_PeacefulTribe</li>
            <li>HHTools_Natl</li>
          </value>
        </li>
        <li Class="PatchOperationAdd">
          <xpath>/Defs/ThingDef[defName="FCP_Unarmed_Power_Fist"]/weaponTags</xpath>
          <value>
            <li>HHTools_Natl</li>
            <li>HHTools_Prewar</li>
            <li>HHTools_SuperMutant</li>
            <li>HHTools_Raider</li>
          </value>
        </li>
        <li Class="PatchOperationAdd">
          <xpath>/Defs/ThingDef[defName="FCP_Unarmed_Ballistic_Fist"]/weaponTags</xpath>
          <value>
            <li>HHTools_Natl</li>
            <li>HHTools_Prewar</li>
            <li>HHTools_SuperMutant</li>
            <li>HHTools_Raider</li>
          </value>
        </li>
        <li Class="PatchOperationAdd">
          <xpath>/Defs/ThingDef[defName="FCP_Unarmed_Displacer_Glove"]/weaponTags</xpath>
          <value>
            <li>HHTools_Prewar</li>
            <li>HHTools_Atlantic</li>
            <li>HHTools_Arcadian</li>
            <li>HHTools_Raider</li>
          </value>
        </li>
        <li Class="PatchOperationAdd">
          <xpath>/Defs/ThingDef[defName="FCP_Unarmed_Zap_Glove"]/weaponTags</xpath>
          <value>
            <li>HHTools_Prewar</li>
            <li>HHTools_Atlantic</li>
            <li>HHTools_Arcadian</li>
            <li>HHTools_Raider</li>
          </value>
        </li>
        <li Class="PatchOperationAdd">
          <xpath>/Defs/ThingDef[defName="FCP_Unarmed_Industrial_Fist"]/weaponTags</xpath>
          <value>
            <li>HHTools_Natl</li>
            <li>HHTools_Prewar</li>
            <li>HHTools_SuperMutant</li>
            <li>HHTools_Raider</li>
          </value>
        </li>
      </operations>
    </match>
  </Operation>
</Patch>
