        <commonality>1</commonality>
        <options>
          <HHTools_Raider_Logger>1</HHTools_Raider_Logger>
        </options>
      </li>
      <li MayRequire="Ludeon.RimWorld.Ideology">
        <kindDef>Farmers</kindDef>
        <commonality>1</commonality>
        <options>
          <HHTools_Raider_Farmer>1</HHTools_Raider_Farmer>
        </options>
      </li>
    </pawnGroupMakers>
    <!--Global-->
    <label>wasteland raider gang</label>
    <description>Ruthless scavengers and murderers who live for the thrill of domination. They often mark their armor with blood and chems, worshiping violence as the only truth.</description>
  </FactionDef>

