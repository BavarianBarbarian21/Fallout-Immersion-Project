        <carriers>
          <Muffalo>3</Muffalo>
          <Dromedary>3</Dromedary>
          <Alpaca>1</Alpaca>
        </carriers>
        <guards>
          <HHTools_Raider_Civilian>4</HHTools_Raider_Civilian>
          <HHTools_Raider_Fighter>10</HHTools_Raider_Fighter>
          <HHTools_Raider_Leader>2</HHTools_Raider_Leader>
