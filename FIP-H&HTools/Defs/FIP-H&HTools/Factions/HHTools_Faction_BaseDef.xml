          <HHTools_Raider_Fighter>12</HHTools_Raider_Fighter>
          <HHTools_Raider_Trader>2</HHTools_Raider_Trader>
          <HHTools_Raider_Leader>3</HHTools_Raider_Leader>
        </options>
      </li>
