<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <FactionDef ParentName="FactionBase" Name="HHTools_Factionbase" Abstract="True">
    <defName>HHTools_Factionbase</defName>
    <settlementGenerationWeight>1</settlementGenerationWeight>
    <requiredCountAtGameStart>1</requiredCountAtGameStart>
    <canSiege>true</canSiege>
    <canStageAttacks>true</canStageAttacks>
    <techLevel>Industrial</techLevel>
    <settlementNameMaker>HHTools_SettlementNameMaker_General</settlementNameMaker>
    <maxConfigurableAtWorldCreation>9999</maxConfigurableAtWorldCreation>
    <settlementTexturePath>World/WorldObjects/DefaultSettlement</settlementTexturePath>
    <allowedArrivalTemperatureRange>-40~45</allowedArrivalTemperatureRange>
    <maxPawnCostPerTotalPointsCurve>
      <points>
        <li>(0,35)</li>
        <li>(70, 50)</li>
        <li>(800, 100)</li>
        <li>(1300, 150)</li>
        <li>(100000, 10000)</li>
      </points>
    </maxPawnCostPerTotalPointsCurve>

  </FactionDef>


  <!-- Democratic/Despotic -->
  <FactionDef ParentName="HHTools_Factionbase" Name="HHTools_Settler_Democratic" Abstract="True">
    <defName>HHTools_Settler_Democratic</defName>
    <modExtensions>
      <li Class="FIP.HHTools.HHToolsFactionPoliticsExtension">
        <system>Civilized</system>
      </li>
    </modExtensions>
    <pawnSingular>settler</pawnSingular>
    <pawnsPlural>settlers</pawnsPlural>
    <categoryTag>Outlander</categoryTag>
    <leaderTitle>overseer</leaderTitle>
    <factionIconPath>FIP-H&amp;HTools/HHTools_Democracy</factionIconPath>
    <structureMemeWeights>
      <Greenway_Religion_ChildrenOfAtom MayRequire="FIP.Greenway">1</Greenway_Religion_ChildrenOfAtom>
      <Greenway_Religion_ChildrenOfTheCathedral MayRequire="FIP.Greenway">1</Greenway_Religion_ChildrenOfTheCathedral>
      <Greenway_Religion_Hubology MayRequire="FIP.Greenway">2</Greenway_Religion_Hubology>
      <Greenway_Religion_CanaaniteChurch MayRequire="FIP.Greenway">2</Greenway_Religion_CanaaniteChurch>
      <Greenway_Religion_AbbeyOfTheRoad MayRequire="FIP.Greenway">4</Greenway_Religion_AbbeyOfTheRoad>
      <Greenway_Religion_OrderOfOurLadyOfTheWaters MayRequire="FIP.Greenway">4</Greenway_Religion_OrderOfOurLadyOfTheWaters>
      <Greenway_Religion_FollowerOfTheApocalypse MayRequire="FIP.Greenway">4</Greenway_Religion_FollowerOfTheApocalypse>
      <Greenway_Religion_Karma MayRequire="FIP.Greenway">1</Greenway_Religion_Karma>
      <Greenway_Religion_Shi MayRequire="FIP.Greenway">1</Greenway_Religion_Shi>
    </structureMemeWeights>
    <backstoryFilters>
      <li>
        <categories>
          <li>Outlander</li>
        </categories>
      </li>
    </backstoryFilters>
    <caravanTraderKinds>
      <li>Caravan_Outlander_BulkGoods</li>
      <li>Caravan_Outlander_CombatSupplier</li>
      <li>Caravan_Outlander_Exotic</li>
      <li>Caravan_Outlander_PirateMerchant</li>
    </caravanTraderKinds>
    <visitorTraderKinds>
      <li>Visitor_Outlander_Standard</li>
    </visitorTraderKinds>
    <baseTraderKinds>
      <li>Base_Outlander_Standard</li>
    </baseTraderKinds>
    <raidLootMaker>OutlanderRaidLootMaker</raidLootMaker>
    <pawnGroupMakers>
      <li>
        <kindDef>Combat</kindDef>
        <options>
          <HHTools_Settlement_Civilian>4</HHTools_Settlement_Civilian>
          <HHTools_Settlement_Fighter>14</HHTools_Settlement_Fighter>
          <HHTools_Settlement_Trader>2</HHTools_Settlement_Trader>
          <HHTools_Settlement_Leader>1</HHTools_Settlement_Leader>
        </options>
      </li>
      <li>
        <kindDef>Peaceful</kindDef>
        <options>
          <HHTools_Settlement_Civilian>20</HHTools_Settlement_Civilian>
          <HHTools_Settlement_Child MayRequire="Ludeon.RimWorld.Biotech">10</HHTools_Settlement_Child>
          <HHTools_Settlement_Fighter>6</HHTools_Settlement_Fighter>
          <HHTools_Settlement_Trader>4</HHTools_Settlement_Trader>
          <HHTools_Settlement_Leader>2</HHTools_Settlement_Leader>
        </options>
      </li>
      <li>
        <kindDef>Trader</kindDef>
        <traders>
          <HHTools_Settlement_Trader>1</HHTools_Settlement_Trader>
        </traders>
        <carriers>
          <Muffalo>6</Muffalo>
          <Dromedary>5</Dromedary>
          <Alpaca>2</Alpaca>
          <Elephant>1</Elephant>
        </carriers>
        <guards>
          <HHTools_Settlement_Civilian>3</HHTools_Settlement_Civilian>
          <HHTools_Settlement_Fighter>10</HHTools_Settlement_Fighter>
          <HHTools_Settlement_Leader>1</HHTools_Settlement_Leader>
        </guards>
      </li>
      <li>
        <kindDef>Settlement</kindDef>
        <options>
          <HHTools_Settlement_Civilian>12</HHTools_Settlement_Civilian>
          <HHTools_Settlement_Fighter>10</HHTools_Settlement_Fighter>
          <HHTools_Settlement_Trader>3</HHTools_Settlement_Trader>
          <HHTools_Settlement_Leader>2</HHTools_Settlement_Leader>
        </options>
      </li>
      <li MayRequire="Ludeon.RimWorld.Ideology">
        <kindDef>Miners</kindDef>
        <commonality>1</commonality>
        <options>
          <HHTools_Settlement_Miner>1</HHTools_Settlement_Miner>
        </options>
      </li>
      <li MayRequire="Ludeon.RimWorld.Ideology">
        <kindDef>Hunters</kindDef>
        <commonality>1</commonality>
        <options>
          <HHTools_Settlement_Hunter>1</HHTools_Settlement_Hunter>
        </options>
      </li>
      <li MayRequire="Ludeon.RimWorld.Ideology">
        <kindDef>Loggers</kindDef>
        <commonality>1</commonality>
        <options>
          <HHTools_Settlement_Logger>1</HHTools_Settlement_Logger>
        </options>
      </li>
      <li MayRequire="Ludeon.RimWorld.Ideology">
        <kindDef>Farmers</kindDef>
        <commonality>1</commonality>
        <options>
          <HHTools_Settlement_Farmer>1</HHTools_Settlement_Farmer>
        </options>
      </li>
    </pawnGroupMakers>
    <!--Gentile/Democratic-->
    <factionNameMaker>HHTools_FactionNameMaker_Democratic</factionNameMaker>
    <classicIdeo>true</classicIdeo>
    <colorSpectrum>
      <li>(0.35, 0.30, 0.60)</li>
      <li>(0.45, 0.40, 0.90)</li>
    </colorSpectrum>
    <configurationListOrderPriority>6</configurationListOrderPriority>
    <listOrderPriority>6</listOrderPriority>
  </FactionDef>
