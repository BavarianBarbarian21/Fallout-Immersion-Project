<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  <!-- Patch: Core Storyteller Incidents_Map_Misc - add FutureTec_ equivalents to allowedBiomes -->

  <IncidentDef>
    <defName>AmbrosiaSprout</defName>
    <label>ambrosia sprout</label>
    <category>Misc</category>
    <targetTags>
      <li>Map_PlayerHome</li>
    </targetTags>
    <workerClass>IncidentWorker_AmbrosiaSprout</workerClass>
    <baseChance>1.0</baseChance>
    <letterLabel>Ambrosia sprout</letterLabel>
    <letterText>A grove of the mysterious ambrosia bush has sprouted nearby! If you wait for the plants to grow, you'll be able to harvest the delicious, pleasurable, and slightly addictive fruit.</letterText>
    <letterDef>PositiveEvent</letterDef>
    <allowedBiomes>
      <li>TropicalRainforest</li>
      <li>FutureTec_Monte</li>
      <li>TropicalSwamp</li>
      <li>FutureTec_Arroyo</li>
      <li>TemperateForest</li>
      <li>TemperateSwamp</li>
      <li>BorealForest</li>
      <li>AridShrubland</li>
    </allowedBiomes>
  </IncidentDef>

  <IncidentDef>
    <defName>HerdMigration</defName>
    <label>herd migration</label>
    <category>Misc</category>
    <targetTags>
      <li>Map_PlayerHome</li>
    </targetTags>
    <allowedBiomes>
      <li>SeaIce</li>
      <li>IceSheet</li>
      <li>Tundra</li>
      <li>FutureTec_Tundra</li>
      <li>Desert</li>
      <li>FutureTec_ScorchingWasteland</li>
      <li>ExtremeDesert</li>
      <li>FutureTec_Divide</li>
    </allowedBiomes>
    <workerClass>IncidentWorker_HerdMigration</workerClass>
    <baseChance>1.0</baseChance>
    <letterLabel>Animal migration: {0}</letterLabel>
    <letterText>A group of {0} is passing through the area.\n\nThey won't attack unless provoked.</letterText>
    <letterDef>NeutralEvent</letterDef>
  </IncidentDef>

  <IncidentDef>
    <defName>Alphabeavers</defName>
    <label>alphabeavers</label>
    <category>Misc</category>
    <allowedBiomes>
      <li>Tundra</li>
      <li>FutureTec_Tundra</li>
      <li>AridShrubland</li>
    </allowedBiomes>
    <targetTags>
      <li>Map_PlayerHome</li>
    </targetTags>
    <workerClass>IncidentWorker_Alphabeavers</workerClass>
    <baseChance>0.5</baseChance>
    <minRefireDays>30</minRefireDays>
  </IncidentDef>

    <IncidentDef>
    <defName>GauranlenPodSpawn</defName>
    <label>Gauranlen pod sprout</label>
    <category>Special</category>
    <targetTags>
      <li>Map_PlayerHome</li>
    </targetTags>
    <workerClass>IncidentWorker_GauranlenPodSpawn</workerClass>
    <letterLabel>Gauranlen pod sprout</letterLabel>
    <letterText>A Gauranlen pod has sprouted nearby!\n\nHarvest it to collect a Gauranlen seed. This special seed can be used to plant the majestic Gauranlen tree.\n\nYour colonists can connect with Gauranlen trees and make them spawn resources and helpful dryads to work or fight for you.</letterText>
    <letterDef>PositiveEvent</letterDef>
    <disallowedBiomes>
      <li>SeaIce</li>
      <li>IceSheet</li>
      <li>FutureTec_Glacier</li>
      <li>FutureTec_FreezingWasteland</li>
    </disallowedBiomes>
  </IncidentDef>

  <IncidentDef>
    <defName>VolcanicAsh</defName>
    <label>volcanic ash</label>
    <category>Misc</category>
    <targetTags>
      <li>Map_PlayerHome</li>
    </targetTags>
    <workerClass>IncidentWorker_MakeGameCondition</workerClass>
    <gameCondition>VolcanicAsh</gameCondition>
    <letterLabel>Volcanic ash</letterLabel>
    <letterDef>ThreatSmall</letterDef>
    <baseChance>1</baseChance>
    <minRefireDays>30</minRefireDays>
    <earliestDay>15</earliestDay>
    <allowedBiomes>
      <li>LavaField</li>
      <li>FutureTec_Malpais</li>
    </allowedBiomes>
    <disabledWhen>
      <extremeWeatherIncidentsDisabled>true</extremeWeatherIncidentsDisabled>
    </disabledWhen>
    <durationDays>2~4</durationDays>
  </IncidentDef>

  <IncidentDef>
    <defName>LavaEmergence</defName>
    <label>lava emergence</label>
    <category>Misc</category>
    <targetTags>
      <li>Map_PlayerHome</li>
    </targetTags>
    <workerClass>IncidentWorker_LavaEmergence</workerClass>
    <baseChance>0.5</baseChance>
    <allowedBiomes>
      <li>LavaField</li>
      <li>FutureTec_Malpais</li>
    </allowedBiomes>
  </IncidentDef>

  <IncidentDef>
    <defName>VolcanicDebris</defName>
    <label>volcanic debris</label>
    <category>Misc</category>
    <targetTags>
      <li>Map_PlayerHome</li>
    </targetTags>
    <workerClass>IncidentWorker_MakeGameCondition</workerClass>
    <gameCondition>VolcanicDebris</gameCondition>
    <letterLabel>Volcanic debris</letterLabel>
    <letterText>A nearby volcanic eruption is showering the region with molten lava!</letterText>
    <letterDef>ThreatSmall</letterDef>
    <baseChance>2.0</baseChance>
    <minRefireDays>30</minRefireDays>
    <earliestDay>15</earliestDay>
    <allowedBiomes>
      <li>LavaField</li>
      <li>FutureTec_Malpais</li>
    </allowedBiomes>
    <disabledWhen>
      <extremeWeatherIncidentsDisabled>true</extremeWeatherIncidentsDisabled>
    </disabledWhen>
  </IncidentDef>

  <IncidentDef>
    <defName>BoomshroomSprout</defName>
    <label>boomshroom sprout</label>
    <category>Misc</category>
    <targetTags>
      <li>Map_PlayerHome</li>
    </targetTags>
    <workerClass>IncidentWorker_BoomshroomSprout</workerClass>
    <baseChance>1.0</baseChance>
    <letterLabel>Boomshroom sprout</letterLabel>
    <letterText>A cluster of explosive boomshrooms has sprouted nearby!\n\nThese mushrooms only grow in darkness. Once they mature, they can be harvested for chemfuel.\n\nBe careful - mature boomshrooms explode if damaged.</letterText>
    <letterDef>PositiveEvent</letterDef>
    <allowedBiomes>
      <li>Glowforest</li>
      <li>FutureTec_ScorchedForest</li>
    </allowedBiomes>
  </IncidentDef>

  <IncidentDef>
    <defName>BioluminescentSpores</defName>
    <label>bioluminescent spores</label>
    <category>Misc</category>
    <targetTags>
      <li>Map_PlayerHome</li>
    </targetTags>
    <workerClass>IncidentWorker_MakeGameCondition</workerClass>
    <gameCondition>BioluminescentSpores</gameCondition>
    <baseChance>1.0</baseChance>
    <letterLabel>Bioluminescent spores</letterLabel>
    <letterText>Some variety of fungus is blossoming, releasing bioluminescent spores! The spores are strangely beautiful and pose no danger.</letterText>
    <letterDef>PositiveEvent</letterDef>
    <allowedBiomes>
      <li>Glowforest</li>
      <li>FutureTec_ScorchedForest</li>
    </allowedBiomes>
    <minRefireDays>15</minRefireDays>
    <durationDays>0.33~0.75</durationDays>
  </IncidentDef>

</Defs>
