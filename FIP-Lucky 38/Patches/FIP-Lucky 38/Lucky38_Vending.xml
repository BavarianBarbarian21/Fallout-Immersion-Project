<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="PatchOperationSequence" MayRequire="Adamas.VendingMachines">
    <success>Always</success>
    <operations>
      <li Class="PatchOperationReplace">
        <xpath>/Defs/*[defName="MedievalVendingMachine"]/description</xpath>
        <value>
          <description>A low-tech kiosk for patrons that needs no electricity.</description>
        </value>
      </li>
      <li Class="PatchOperationReplace">
        <xpath>/Defs/*[defName="MedievalVendingMachine"]/label</xpath>
        <value>
          <label>service kiosk</label>
        </value>
      </li>
      <li Class="PatchOperationReplace">
        <xpath>/Defs/*[defName="VendingMachine"]/description</xpath>
        <value>
          <description>A pre-War kiosk stocked for patrons, casino traffic, and idle lounge crowds.</description>
        </value>
      </li>
    </operations>
  </Operation>
</Patch>