<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="PatchOperationSequence" MayRequire="Orion.Therapy">
    <success>Always</success>
    <operations>
      <li Class="PatchOperationReplace">
        <xpath>/Defs/*[defName="Therapist"]/description</xpath>
        <value>
          <description>Help colonists and patrons work through stress, trauma, and dependency in a private counseling suite.</description>
        </value>
      </li>
      <li Class="PatchOperationReplace">
        <xpath>/Defs/*[defName="Therapist"]/gerundLabel</xpath>
        <value>
          <gerundLabel>counseling</gerundLabel>
        </value>
      </li>
      <li Class="PatchOperationReplace">
        <xpath>/Defs/*[defName="Therapist"]/labelShort</xpath>
        <value>
          <labelShort>Counsel</labelShort>
        </value>
      </li>
    </operations>
  </Operation>
</Patch>