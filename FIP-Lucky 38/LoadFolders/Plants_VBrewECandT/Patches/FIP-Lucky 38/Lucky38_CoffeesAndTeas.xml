<?xml version='1.0' encoding='UTF-8'?>
<Patch>
  <Operation Class="PatchOperationSequence">
    <success>Always</success>
    <operations>
      <li Class="PatchOperationReplace">
        <xpath>/Defs/RecipeDef[defName="VBE_MakeCoffee" or defName="VBE_MakeTea" or defName="VBE_MakeCoffeeFast" or defName="VBE_ReheatCoffee" or defName="VBE_BrewLatteCoffee" or defName="VBE_BrewMochaCoffee" or defName="VBE_BrewIrishCoffee" or defName="VBE_BrewCannibalCoffee" or defName="VBE_MakeTeaFast" or defName="VBE_MakeBlackTea" or defName="VBE_MakeYuenYeung" or defName="VBE_MakeKombucha" or defName="VBE_BrewLemonCoffee" or defName="VBE_MakeLemonTea" or defName="VBE_MakeEarlGreyTea"]/recipeUsers</xpath>
        <value>
          <recipeUsers>
            <li>VBE_EspressoMachineBuilding</li>
          </recipeUsers>
        </value>
      </li>
      <li Class="PatchOperationFindMod">
        <mods>
          <li>Vanilla Plants Expanded</li>
        </mods>
        <match Class="PatchOperationSequence">
          <success>Always</success>
          <operations>
            <li Class="PatchOperationReplace">
              <xpath>/Defs/RecipeDef[defName="VBE_BrewLemonCoffee"]/ingredients/li/filter/thingDefs/li[text()="VCE_RawLemon"]</xpath>
              <value>
                <li>FCP_Raw_Mutfruit</li>
              </value>
            </li>
            <li Class="PatchOperationReplace">
              <xpath>/Defs/RecipeDef[defName="VBE_BrewLemonCoffee"]/fixedIngredientFilter/thingDefs/li[text()="VCE_RawLemon"]</xpath>
              <value>
                <li>FCP_Raw_Mutfruit</li>
              </value>
            </li>
            <li Class="PatchOperationReplace">
              <xpath>/Defs/RecipeDef[defName="VBE_BrewLemonCoffee"]/defaultIngredientFilter/thingDefs/li[text()="VCE_RawLemon"]</xpath>
              <value>
                <li>FCP_Raw_Mutfruit</li>
              </value>
            </li>
            <li Class="PatchOperationReplace">
              <xpath>/Defs/RecipeDef[defName="VBE_MakeLemonTea"]/ingredients/li/filter/thingDefs/li[text()="VCE_RawLemon"]</xpath>
              <value>
                <li>FCP_Raw_Mutfruit</li>
              </value>
            </li>
            <li Class="PatchOperationReplace">
              <xpath>/Defs/RecipeDef[defName="VBE_MakeLemonTea"]/fixedIngredientFilter/thingDefs/li[text()="VCE_RawLemon"]</xpath>
              <value>
                <li>FCP_Raw_Mutfruit</li>
              </value>
            </li>
            <li Class="PatchOperationReplace">
              <xpath>/Defs/RecipeDef[defName="VBE_MakeLemonTea"]/defaultIngredientFilter/thingDefs/li[text()="VCE_RawLemon"]</xpath>
              <value>
                <li>FCP_Raw_Mutfruit</li>
              </value>
            </li>
            <li Class="PatchOperationReplace">
              <xpath>/Defs/RecipeDef[defName="VBE_MixLemonade"]/ingredients/li/filter/thingDefs/li[text()="VCE_RawLemon"]</xpath>
              <value>
                <li>FCP_Raw_Mutfruit</li>
              </value>
            </li>
          </operations>
        </match>
      </li>
    </operations>
  </Operation>
</Patch>