<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="PatchOperationSequence" MayRequire="VanillaExpanded.VCookESushi">
    <success>Always</success>
    <operations>
      <li Class="PatchOperationSequence" MayRequire="Rick.FCP.Plants">
        <success>Always</success>
        <operations>
          <li Class="PatchOperationReplace">
            <xpath>/Defs/ThingDef[defName="VCE_Soybean"]/plant/harvestedThingDef</xpath>
            <value>
              <harvestedThingDef>FCP_Raw_Cranberry</harvestedThingDef>
            </value>
          </li>
          <li Class="PatchOperationReplace">
            <xpath>/Defs/ThingDef[defName="VCE_Soybean"]/plant/sowTags</xpath>
            <value>
              <sowTags />
            </value>
          </li>
          <li Class="PatchOperationReplace">
            <xpath>/Defs/*[defName="VCE_SoybeansToSauce"]/items/li[text()="VCE_RawSoybean"]</xpath>
            <value>
              <li>FCP_Raw_Cranberry</li>
            </value>
          </li>
          <li Class="PatchOperationReplace">
            <xpath>/Defs/*[defName="IP_SoyFermenterFirstItem"]/items/li[text()="VCE_RawSoybean"]</xpath>
            <value>
              <li>FCP_Raw_Cranberry</li>
            </value>
          </li>
          <li Class="PatchOperationReplace">
            <xpath>/Defs/ThingDef[defName="VCE_Wasabi"]/plant/harvestedThingDef</xpath>
            <value>
              <harvestedThingDef>FCP_Raw_Xander_Root</harvestedThingDef>
            </value>
          </li>
          <li Class="PatchOperationReplace">
            <xpath>/Defs/ThingDef[defName="VCE_Wasabi"]/plant/sowTags</xpath>
            <value>
              <sowTags />
            </value>
          </li>
          <li Class="PatchOperationReplace">
            <xpath>/Defs/RecipeDef[defName="VCE_WasabiPaste"]/ingredients/li/filter/thingDefs/li[text()="VCE_RawWasabi"]</xpath>
            <value>
              <li>FCP_Raw_Xander_Root</li>
            </value>
          </li>
          <li Class="PatchOperationReplace">
            <xpath>/Defs/RecipeDef[defName="VCE_WasabiPaste"]/fixedIngredientFilter/thingDefs/li[text()="VCE_RawWasabi"]</xpath>
            <value>
              <li>FCP_Raw_Xander_Root</li>
            </value>
          </li>
        </operations>
      </li>
    </operations>
  </Operation>
</Patch>