<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="PatchOperationSequence" MayRequire="VanillaExpanded.VBrewE">
    <success>Always</success>
    <operations>
      <li Class="PatchOperationSequence" MayRequire="VanillaExpanded.VCookE">
        <success>Always</success>
        <operations>
          <li Class="PatchOperationSequence" MayRequire="Rick.FCP.Plants">
            <success>Always</success>
            <operations>
              <li Class="PatchOperationReplace">
                <xpath>/Defs/ThingDef[defName="VBE_RawCoffee"]/graphicData/texPath</xpath>
                <value>
                  <texPath>Things/Items/Condiments/Lucky38_Canned</texPath>
                </value>
              </li>
              <li Class="PatchOperationReplace">
                <xpath>/Defs/ThingDef[defName="VBE_RawTea"]/graphicData/texPath</xpath>
                <value>
                  <texPath>Things/Items/Condiments/Lucky38_Canned</texPath>
                </value>
              </li>
              <li Class="PatchOperationReplace">
                <xpath>/Defs/ThingDef[defName="VBE_RawTobacco"]/graphicData/texPath</xpath>
                <value>
                  <texPath>Things/Items/Condiments/Lucky38_Canned</texPath>
                </value>
              </li>
              <li Class="PatchOperationReplace">
                <xpath>/Defs/ThingDef[defName="VBE_Plant_Coffee"]/plant/sowTags</xpath>
                <value>
                  <sowTags />
                </value>
              </li>
              <li Class="PatchOperationReplace">
                <xpath>/Defs/ThingDef[defName="VBE_Plant_Tea"]/plant/sowTags</xpath>
                <value>
                  <sowTags />
                </value>
              </li>
              <li Class="PatchOperationReplace">
                <xpath>/Defs/ThingDef[defName="VBE_Plant_Tobacco"]/plant/sowTags</xpath>
                <value>
                  <sowTags>
                    <li>Ground</li>
                    <li>Hydroponic</li>
                  </sowTags>
                </value>
              </li>
              <li Class="PatchOperationAdd">
                <xpath>/Defs/RecipeDef/ingredients/li/filter/thingDefs[li="VBE_RawCoffee"]</xpath>
                <value>
                  <li>FCP_Raw_Honey_Mesquite</li>
                </value>
              </li>
              <li Class="PatchOperationAdd">
                <xpath>/Defs/RecipeDef/fixedIngredientFilter/thingDefs[li="VBE_RawCoffee"]</xpath>
                <value>
                  <li>FCP_Raw_Honey_Mesquite</li>
                </value>
              </li>
              <li Class="PatchOperationAdd">
                <xpath>/Defs/RecipeDef/defaultIngredientFilter/thingDefs[li="VBE_RawCoffee"]</xpath>
                <value>
                  <li>FCP_Raw_Honey_Mesquite</li>
                </value>
              </li>
              <li Class="PatchOperationAdd">
                <xpath>/Defs/RecipeDef/ingredients/li/filter/thingDefs[li="VBE_RawTea"]</xpath>
                <value>
                  <li>FCP_Raw_Mutated_Fern</li>
                </value>
              </li>
              <li Class="PatchOperationAdd">
                <xpath>/Defs/RecipeDef/fixedIngredientFilter/thingDefs[li="VBE_RawTea"]</xpath>
                <value>
                  <li>FCP_Raw_Mutated_Fern</li>
                </value>
              </li>
              <li Class="PatchOperationAdd">
                <xpath>/Defs/RecipeDef/defaultIngredientFilter/thingDefs[li="VBE_RawTea"]</xpath>
                <value>
                  <li>FCP_Raw_Mutated_Fern</li>
                </value>
              </li>
              <li Class="PatchOperationReplace">
                <xpath>/Defs/ThingDef[@Name="VBE_AmbrandyBase"]/description</xpath>
                <value>
                  <description>Also known as liquid sunshine, pungashine is a refined liquor distilled from ripe punga fruit. It is rare, expensive, and prized anywhere a properly stocked bar still exists.</description>
                </value>
              </li>
              <li Class="PatchOperationFindMod">
                <mods>
                  <li>Vanilla Factions Expanded - Settlers</li>
                </mods>
                <match Class="PatchOperationSequence">
                  <success>Always</success>
                  <operations></operations>
                </match>
              </li>
            </operations>
          </li>
        </operations>
      </li>
    </operations>
  </Operation>
</Patch>