<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <!--Add Vanilla Incidents to Arktos Biomes-->
  <Operation Class="PatchOperationSequence">
    <operations>
      <li Class="PatchOperationReplace" MayRequire="Ludeon.RimWorld.Odyssey">
        <xpath>/Defs/IncidentDef[defName="VolcanicAsh"]/allowedBiomes</xpath>
        <value>
          <allowedBiomes>
            <li>Arktos_Malpais</li>
          </allowedBiomes>
        </value>
      </li>
      <li Class="PatchOperationReplace" MayRequire="Ludeon.RimWorld.Odyssey">
        <xpath>/Defs/IncidentDef[defName="LavaEmergence"]/allowedBiomes</xpath>
        <value>
          <allowedBiomes>
            <li>Arktos_Malpais</li>
          </allowedBiomes>
        </value>
      </li>
      <li Class="PatchOperationReplace" MayRequire="Ludeon.RimWorld.Odyssey">
        <xpath>/Defs/IncidentDef[defName="LavaFlow"]/allowedBiomes</xpath>
        <value>
          <allowedBiomes>
            <li>Arktos_Malpais</li>
          </allowedBiomes>
        </value>
      </li>
      <li Class="PatchOperationReplace" MayRequire="Ludeon.RimWorld.Odyssey">
        <xpath>/Defs/IncidentDef[defName="VolcanicDebris"]/allowedBiomes</xpath>
        <value>
          <allowedBiomes>
            <li>LavaField</li>
            <li>Arktos_Malpais</li>
          </allowedBiomes>
        </value>
      </li>
      <li Class="PatchOperationReplace" MayRequire="Ludeon.RimWorld.Odyssey">
        <xpath>/Defs/IncidentDef[defName="BoomshroomSprout"]/allowedBiomes</xpath>
        <value>
          <allowedBiomes>
            <li>Arktos_CranberryBog</li>
          </allowedBiomes>
        </value>
      </li>
      <li Class="PatchOperationReplace" MayRequire="Ludeon.RimWorld.Odyssey">
        <xpath>/Defs/IncidentDef[defName="BioluminescentSpores"]/allowedBiomes</xpath>
        <value>
          <allowedBiomes>
            <li>Arktos_CranberryBog</li>
          </allowedBiomes>
        </value>
      </li>
      <li Class="PatchOperationReplace" MayRequire="Ludeon.RimWorld.Odyssey">
        <xpath>/Defs/IncidentDef[defName="DroughtInitial"]/allowedBiomes</xpath>
        <value>
          <allowedBiomes>
            <li>Arktos_CentralValley</li>
            <li>Arktos_BrahminWoods</li>
            <li>Arktos_Sequoia</li>
            <li>Arktos_Mojave</li>
          </allowedBiomes>
        </value>
      </li>
      <li Class="PatchOperationReplace" MayRequire="Ludeon.RimWorld.Odyssey">
        <xpath>/Defs/IncidentDef[defName="Drought"]/allowedBiomes</xpath>
        <value>
          <allowedBiomes>
            <li>Arktos_CentralValley</li>
            <li>Arktos_BrahminWoods</li>
            <li>Arktos_Sequoia</li>
            <li>Arktos_Mojave</li>
          </allowedBiomes>
        </value>
      </li>
    </operations>
  </Operation>
</Patch>