<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <!-- Fire ants are Arktos-owned counterparts to the vanilla insect roster.
       They are fully defined here, but vanilla infestation generation still needs a code-side hook to choose them. -->

  <FactionDef ParentName="FactionBase">
    <defName>Arktos_FireAnts</defName>
    <label>fire ant colony</label>
    <description>A divergent insect geneline adapted into aggressive fire ants. They share the same eusocial behavior as the black ant strain, but operate as a separate colony and field only ember-colored castes.</description>
    <pawnSingular>fire ant</pawnSingular>
    <pawnsPlural>fire ants</pawnsPlural>
    <requiredCountAtGameStart>1</requiredCountAtGameStart>
    <displayInFactionSelection>false</displayInFactionSelection>
    <fixedName>Fire Ant Colony</fixedName>
    <factionIconPath>World/WorldObjects/Expanding/Insects</factionIconPath>
    <colorSpectrum>
      <li>(0.51, 0.14, 0.08)</li>
      <li>(0.65, 0.18, 0.10)</li>
      <li>(0.78, 0.26, 0.14)</li>
    </colorSpectrum>
    <raidCommonalityFromPointsCurve>
      <points>
        <li>(0, 0)</li>
      </points>
    </raidCommonalityFromPointsCurve>
    <maxPawnCostPerTotalPointsCurve>
      <points>
        <li>(100,100)</li>
        <li>(10000,10000)</li>
      </points>
    </maxPawnCostPerTotalPointsCurve>
    <pawnGroupMakers>
      <li>
        <kindDef>Combat</kindDef>
        <commonality>1</commonality>
        <options>
          <Arktos_FireAnt>2</Arktos_FireAnt>
          <Arktos_FireWorkerAnt>2</Arktos_FireWorkerAnt>
          <Arktos_FireSoldierAnt>1</Arktos_FireSoldierAnt>
          <Arktos_FireAntDrone MayRequire="Ludeon.RimWorld.Odyssey">2</Arktos_FireAntDrone>
        </options>
      </li>
    </pawnGroupMakers>
    <humanlikeFaction>false</humanlikeFaction>
    <hidden>true</hidden>
    <autoFlee>false</autoFlee>
    <canUseAvoidGrid>false</canUseAvoidGrid>
    <techLevel>Animal</techLevel>
    <animalsFleeDanger>false</animalsFleeDanger>
    <permanentEnemyToEveryoneExcept>
      <li MayRequire="Ludeon.RimWorld.Anomaly">Entities</li>
    </permanentEnemyToEveryoneExcept>
    <settlementTexturePath>World/WorldObjects/DefaultSettlement</settlementTexturePath>
    <allowedArrivalTemperatureRange>0~45</allowedArrivalTemperatureRange>
    <maxConfigurableAtWorldCreation>1</maxConfigurableAtWorldCreation>
    <configurationListOrderPriority>1001</configurationListOrderPriority>
  </FactionDef>

  <PawnKindDef Name="Arktos_FireAntKindBase" ParentName="InsectKindBase" Abstract="True">
    <defaultFactionDef>Arktos_FireAnts</defaultFactionDef>
  </PawnKindDef>

  <ThingDef ParentName="BaseInsect">
    <defName>Arktos_FireWorkerAnt</defName>
    <label>fire worker ant</label>
    <description>A massive fire ant engineered for strength and resilience. Fire worker ants are fiercely territorial and maintain their hive with absolute loyalty.</description>
    <statBases>
      <MoveSpeed>3.75</MoveSpeed>
      <ArmorRating_Blunt>0.18</ArmorRating_Blunt>
      <ArmorRating_Heat>0.36</ArmorRating_Heat>
      <ArmorRating_Sharp>0.72</ArmorRating_Sharp>
      <ComfyTemperatureMin>0</ComfyTemperatureMin>
      <Flammability>0.1</Flammability>
      <MarketValue>100</MarketValue>
      <LeatherAmount>0</LeatherAmount>
      <Wildness>0.2</Wildness>
    </statBases>
    <uiIconScale>2</uiIconScale>
    <tools>
      <li>
        <label>mandibles</label>
        <capacities>
          <li>Bite</li>
        </capacities>
        <power>5</power>
        <cooldownTime>2</cooldownTime>
        <linkedBodyPartsGroup>Mouth</linkedBodyPartsGroup>
      </li>
      <li>
        <label>head</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>4</power>
        <cooldownTime>2</cooldownTime>
        <linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
        <ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
        <chanceFactor>0.1</chanceFactor>
      </li>
    </tools>
    <race>
      <body>BeetleLike</body>
      <baseBodySize>0.2</baseBodySize>
      <baseHungerRate>0.10</baseHungerRate>
      <baseHealthScale>0.4</baseHealthScale>
      <useMeatFrom>Megaspider</useMeatFrom>
      <lifeExpectancy>10</lifeExpectancy>
      <trainability>Intermediate</trainability>
      <lifeStageAges>
        <li>
          <def>EusocialInsectLarva</def>
          <minAge>0</minAge>
        </li>
        <li>
          <def>EusocialInsectJuvenile</def>
          <minAge>0.03</minAge>
        </li>
        <li>
          <def>EusocialInsectAdult</def>
          <minAge>0.4</minAge>
          <soundWounded>Pawn_Megascarab_Wounded</soundWounded>
          <soundDeath>Pawn_Megascarab_Death</soundDeath>
          <soundCall>Pawn_Megascarab_Call</soundCall>
          <soundAngry>Pawn_Megascarab_Angry</soundAngry>
        </li>
      </lifeStageAges>
      <soundMeleeHitPawn>Pawn_Melee_SmallScratch_HitPawn</soundMeleeHitPawn>
      <soundMeleeHitBuilding>Pawn_Melee_SmallScratch_HitBuilding</soundMeleeHitBuilding>
      <soundMeleeMiss>Pawn_Melee_SmallScratch_Miss</soundMeleeMiss>
      <headPosPerRotation>
        <li>(0.0, 0, 0.12)</li>
        <li>(0.07, 0, -0.05)</li>
        <li>(0.0, 0, -0.08)</li>
        <li>(-0.07, 0, -0.05)</li>
      </headPosPerRotation>
    </race>
    <tradeTags>
      <li>AnimalInsect</li>
    </tradeTags>
  </ThingDef>

