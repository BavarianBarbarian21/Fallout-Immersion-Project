<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="PatchOperationSequence">
    <operations>
      <li Class="PatchOperationReplace" MayRequire="Ludeon.RimWorld.Royalty">
        <xpath>Defs/FactionDef[defName="OutlanderRefugee"]/label</xpath>
        <value>
          <label>Escaped Slaves</label>
        </value>
      </li>
      <li Class="PatchOperationReplace" MayRequire="Ludeon.RimWorld.Royalty">
        <xpath>Defs/FactionDef[defName="OutlanderRefugee"]/description</xpath>
        <value>
          <description>Flesh freed from chains, the Escaped Slaves bear scars both seen and unseen. Bonded by suffering and driven by hope, they struggle for freedom and justice amidst the wasteland’s cruelty. Fierce and desperate, they fight for a life stolen but not forgotten.</description>
        </value>
      </li>
      <li Class="PatchOperationReplace" MayRequire="Ludeon.RimWorld.Royalty">
        <xpath>Defs/FactionDef[defName="OutlanderRefugee"]/pawnSingular</xpath>
        <value>
          <pawnSingular>Runaway</pawnSingular>
        </value>
      </li>
      <li Class="PatchOperationReplace" MayRequire="Ludeon.RimWorld.Royalty">
        <xpath>Defs/FactionDef[defName="OutlanderRefugee"]/pawnsPlural</xpath>
        <value>
          <pawnsPlural>Runaways</pawnsPlural>
        </value>
      </li>
    </operations>
  </Operation>

  <Operation Class="PatchOperationFindMod">
    <mods>
      <li>Ludeon.RimWorld.Royalty</li>
    </mods>
    <match Class="PatchOperationSequence">
      <operations>
        <li Class="PatchOperationReplace" MayRequire="FIP.WestTek">
          <xpath>Defs/FactionDef[defName="OutlanderRefugee"]/xenotypeSet</xpath>
          <value>
            <xenotypeSet>
              <xenotypeChances>
                <Baseliner MayRequire="Ludeon.RimWorld.Biotech">0.6</Baseliner>
                <WestTek_Xenotype_Atlantic MayRequire="FIP.WestTek">0.3</WestTek_Xenotype_Atlantic>
                <WestTek_Xenotype_TwoCalifornia MayRequire="FIP.WestTek">0.1</WestTek_Xenotype_TwoCalifornia>
              </xenotypeChances>
            </xenotypeSet>
          </value>
        </li>
      </operations>
    </match>
  </Operation>
</Patch>