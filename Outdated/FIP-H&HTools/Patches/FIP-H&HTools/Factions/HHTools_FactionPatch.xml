<?xml version="1.0" encoding="utf-8"?>
<!-- Remove vanilla Structure_* MemeDefs (keeps Greenway_ prefixed defs) -->
<Patch>
    <!--Remove all Structures and Cultures (Does this work?)
    <Operation Class="PatchOperationRemove">
        <xpath>//FactionDef/structureMemeWeights</xpath>
    </Operation>
    <Operation Class="PatchOperationRemove">
        <xpath>//FactionDef/factionNameMaker</xpath>
    </Operation>
    <Operation Class="PatchOperationRemove">
        <xpath>//FactionDef/settlementNameMaker</xpath>
    </Operation>
    <Operation Class="PatchOperationRemove">
        <xpath>//FactionDef/allowedCultures</xpath>
    </Operation>-->
    <!-- Structure Patch -->
    <Operation Class="PatchOperationFindMod">
        <mods>
            <li>FIP.Greenway</li>
        </mods>
        <match Class="PatchOperationAdd">
            <xpath>/Defs/FactionDef[@Name="FactionBase"]/structureMemeWeights</xpath>
            <value>
                <structureMemeWeights>
                    <Greenway_Religion_ChildrenOfAtom>1</Greenway_Religion_ChildrenOfAtom>
                    <Greenway_Religion_ChildrenOfTheCathedral>1</Greenway_Religion_ChildrenOfTheCathedral>
                    <Greenway_Religion_ChildrenOfKrvibi>1</Greenway_Religion_ChildrenOfKrvibi>
                    <Greenway_Religion_Hubology>1</Greenway_Religion_Hubology>

                    <Greenway_Religion_CanaaniteChurch>1</Greenway_Religion_CanaaniteChurch>
                    <Greenway_Religion_AbbeyOfTheRoad>1</Greenway_Religion_AbbeyOfTheRoad>
                    <Greenway_Religion_OrderOfOurLadyOfTheWaters>1</Greenway_Religion_OrderOfOurLadyOfTheWaters>
                    <Greenway_Religion_FollowerOfTheApocalypse>1</Greenway_Religion_FollowerOfTheApocalypse>

                    <Greenway_Religion_Syncretic>1</Greenway_Religion_Syncretic>
                    <Greenway_Religion_Karma>1</Greenway_Religion_Karma>
                    <Greenway_Religion_Native>1</Greenway_Religion_Native>
                    <Greenway_Religion_Shi>1</Greenway_Religion_Shi>
                </structureMemeWeights>
            </value>
        </match>
    </Operation>
    <!-- FactionNameMaker Patch (Useless?)-->
    <Operation Class="PatchOperationAdd">
        <xpath>/Defs/FactionDef[@Name="FactionBase"]</xpath>
        <value>
            <factionNameMaker>HHTools_FactionNameMaker_General</factionNameMaker>
        </value>
    </Operation>
    <!-- SettlementNameMaker Patch (Useless?)-->
    <Operation Class="PatchOperationAdd">
        <xpath>/Defs/FactionDef[@Name="FactionBase"]</xpath>
        <value>
            <settlementNameMaker>HHTools_SettlementNameMaker_General</settlementNameMaker>
        </value>
    </Operation>
    <!-- Culture (+PawnNameMaker) Patch (Useless?)-->
    <Operation Class="PatchOperationAdd">
        <xpath>/Defs/FactionDef[@Name="FactionBase"]</xpath>
        <value>
            <allowedCultures>
                <li>HHTools_Culture_American</li>
            </allowedCultures>
        </value>
    </Operation>
</Patch>