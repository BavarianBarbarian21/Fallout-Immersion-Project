<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="PatchOperationSequence" MayRequire="OskarPotocki.VanillaFactionsExpanded.Core,OskarPotocki.VFE.Medieval2">
    <success>Always</success>
    <operations>
      <li Class="PatchOperationReplace">
        <xpath>Defs/VEF.Planet.MovingBaseDef[defName="VFEM2_MerchantGuildCaravan"]/label</xpath>
        <value>
          <label>caravan company</label>
        </value>
      </li>
      <li Class="PatchOperationReplace">
        <xpath>Defs/VEF.Planet.MovingBaseDef[defName="VFEM2_MerchantGuildCaravan"]/description</xpath>
        <value>
          <description>A mobile caravan company camp moving goods, guards, and traders through the wasteland.</description>
        </value>
      </li>
      <li Class="PatchOperationReplace">
        <xpath>Defs/VEF.Planet.MovingBaseDef[defName="VFEM2_MerchantGuildCaravan"]/attackConfirmationMessage</xpath>
        <value>
          <attackConfirmationMessage>You are about to attack a caravan company, which will make that faction hostile. Are you sure you want to do that?</attackConfirmationMessage>
        </value>
      </li>
    </operations>
  </Operation>
</Patch>