<?xml version="1.0" encoding="utf-8"?>
<Patch>
    <!-- Faction: Empire -> Whitespring Enclave -->
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/FactionDef[defName="Empire"]/label</xpath>
        <value>
            <label>Whitespring Enclave</label>
        </value>
    </Operation>
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/FactionDef[defName="Empire"]/description</xpath>
        <value>
            <description>A militant enclave of survivors claiming to represent the Appalachia scientific division. They pursue research into cryptids and hoard intelligence and technology for the Whitespring Enclave.</description>
        </value>
    </Operation>
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/FactionDef[defName="Empire"]/factionIconPath</xpath>
        <value>
            <factionIconPath>FIP-Whitespring/Whitespring</factionIconPath>
        </value>
    </Operation>
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/FactionDef[defName="Empire"]/colorSpectrum</xpath>
        <value>
            <colorSpectrum>
                <li>(1, 1, 1)</li>
            </colorSpectrum>
        </value>
    </Operation>
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/FactionDef[defName="Empire"]/pawnSingular</xpath>
        <value>
            <pawnSingular>Whitespring agent</pawnSingular>
        </value>
    </Operation>
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/FactionDef[defName="Empire"]/pawnsPlural</xpath>
        <value>
            <pawnsPlural>Whitespring agents</pawnsPlural>
        </value>
    </Operation>
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/FactionDef[defName="Empire"]/leaderTitle</xpath>
        <value>
            <leaderTitle>president</leaderTitle>
        </value>
    </Operation>
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/FactionDef[defName="Empire"]/royalFavorLabel</xpath>
        <value>
            <royalFavorLabel>intel</royalFavorLabel>
        </value>
    </Operation>
    <!-- Ship / Shuttle -->
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="ShipLandingBeacon"]/label</xpath>
        <value>
            <label>Vertibird Landing Beacon</label>
        </value>
    </Operation>
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/TransportShipDef[defName="Ship_Shuttle"]/label</xpath>
        <value>
            <label>Whitespring Vertibird</label>
        </value>
    </Operation>
    <!-- Pawn kind visible label renames: imperial -> Whitespring -->
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/PawnKindDef[defName="Empire_Common_Lodger"]/label</xpath>
        <value>
            <label>Whitespring citizen</label>
        </value>
    </Operation>
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/PawnKindDef[defName="Empire_Common_Trader"]/label</xpath>
        <value>
            <label>Whitespring trader</label>
        </value>
    </Operation>
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/PawnKindDef[defName="Empire_Common_Laborer"]/label</xpath>
        <value>
            <label>Whitespring laborer</label>
        </value>
    </Operation>
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/PawnKindDef[defName="Empire_Fighter_Trooper"]/label</xpath>
        <value>
            <label>trooper</label>
        </value>
    </Operation>
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/PawnKindDef[defName="Empire_Fighter_Grenadier"]/label</xpath>
        <value>
            <label>arctic marine</label>
        </value>
    </Operation>
    <!-- RulePack: rename 'empire' token to 'whitespring' for namers -->
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/RulePackDef[defName="NamerFactionEmpire"]/rulePack/rulesStrings</xpath>
        <value>
            <rulesStrings>
                <li>r_name(p=3)->The Whitespring</li>
                <li>r_name(p=2)->The Whitespring Bunker</li>
                <li>r_name(p=3)->The Enclave</li>
                <li>r_name(p=2)->The Appalachia Enclave</li>
                <li>r_name(p=1)->The Whitespring Enclave</li>
                <li>r_name(p=1)->The Appalachia Bunker</li>
            </rulesStrings>
          </value>
        </Operation>
    </Patch>