	<!-- ================= LIBERATOR ================= -->
	<ThingDef ParentName="RobCo_LiberatorBase">
		<defName>RobCo_Liberator</defName>
		<label>Liberator</label>
		<description>A small quadrupedal combat robot associated with Chinese-aligned factions in the Commonwealth. It is built around a single integrated laser weapon and four mechanical legs for rapid movement over uneven terrain. The Liberator is lightly armored but fast, and is typically encountered in large groups that attack simultaneously from multiple directions.</description>
	</ThingDef>
	<PawnKindDef ParentName="RobCo_SmallRobotKind">
		<defName>RobCo_Liberator</defName>
		<label>Liberator</label>
		<pawnDesc>A small, aggressive combat robot associated with Jiang's faction and used widely across the Commonwealth. The Liberator is a compact quadrupedal unit built around a single overriding directive: attack. Its four mechanical legs allow rapid movement across uneven terrain, and its integrated laser weapon delivers fast, accurate bursts of fire. Individual Liberators are fragile, but they are rarely encountered alone — they operate in coordinated swarms that can overwhelm unprepared targets through sheer numbers and aggression.</pawnDesc>
		<race>RobCo_Liberator</race>
		<combatPower>50</combatPower>
		<lifeStages>
			<li>
				<bodyGraphicData>
					<texPath>FIP-RobCo/Robots/Liberator/LiberatorGreen/LiberatorGreen</texPath>
					<shaderType>CutoutWithOverlay</shaderType>
					<graphicClass>Graphic_Multi</graphicClass>
					<drawSize>1.3</drawSize>
					<shadowData>
						<volume>(0.35, 0.4, 0.35)</volume>
						<offset>(0,0,-0.25)</offset>
					</shadowData>
				</bodyGraphicData>
			</li>
		</lifeStages>
		<weaponTags>
			<li>RobCo_LiberatorLaser</li>
		</weaponTags>
	</PawnKindDef>
